{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013M7WUfWMSvSVsCbX25CrM7","type":"tool_result","content":"13:#[derive(Debug, Clone, Serialize)]\n14:pub struct PolezDetectionResult {\n15:    /// Overall probability this is AI-generated (0.0 - 1.0)\n16:    pub detection_probability: f64,\n17:    /// Confidence in the detection (0.0 - 1.0)\n18:    pub confidence: f64,\n19:    /// Individual signal scores\n20:    pub signals: PolezSignals,\n21:    /// Human-readable verdict\n22:    pub verdict: &'static str,\n23:}\n24:\n25:/// Individual detection signals.\n26:#[derive(Debug, Clone, Serialize)]\n27:pub struct PolezSignals {\n28:    /// Ratio of energy in 23-24kHz vs 15-20kHz (AI watermark: >0.1, Human: <0.02)\n29:    pub ultrasonic_ratio: f64,\n30:    /// Ultrasonic score contribution (0-1)\n31:    pub ultrasonic_score: f64,\n32:\n33:    /// Average deviation of bit planes from 0.5 (AI watermark: >0.02, Human: <0.01)\n34:    pub bit_plane_bias: f64,\n35:    /// Number of bit planes with significant bias (AI watermark: 6-8, Human: 0-2)\n36:    pub biased_planes: u8,\n37:    /// Bit plane score contribution (0-1)\n38:    pub bit_plane_score: f64,\n39:\n40:    /// Maximum autocorrelation value at tested periods\n41:    pub max_autocorr: f64,\n42:    /// Period with strongest autocorrelation\n43:    pub autocorr_period: usize,\n44:    /// Autocorrelation score contribution (0-1)\n45:    pub autocorr_score: f64,\n46:}\n47:\n48:/// AI watermark detector.\n49:pub struct PolezDetector;\n50:\n51:impl PolezDetector {\n52:    /// Analyze audio for AI watermark signatures.\n53:    pub fn detect(buffer: &AudioBuffer) -> PolezDetectionResult {\n54:        let samples = buffer.to_mono_samples();\n55:        let sample_rate = buffer.sample_rate;\n56:\n57:        // Signal 1: Ultrasonic energy analysis\n58:        let (ultrasonic_ratio, ultrasonic_score) = Self::analyze_ultrasonic(&samples, sample_rate);\n59:\n60:        // Signal 2: Bit plane bias analysis\n61:        let (bit_plane_bias, biased_planes, bit_plane_score) = Self::analyze_bit_planes(&samples);\n62:\n63:        // Signal 3: Autocorrelation analysis\n64:        let (max_autocorr, autocorr_period, autocorr_score) =\n65:            Self::analyze_autocorrelation(&samples);\n66:\n67:        // Weighted combination of signals\n68:        // Ultrasonic is strongest indicator, followed by bit planes, then autocorr\n69:        let weights = (0.45, 0.35, 0.20); // ultrasonic, bit_plane, autocorr\n70:\n71:        let raw_probability =\n72:            ultrasonic_score * weights.0 + bit_plane_score * weights.1 + autocorr_score * weights.2;\n73:\n74:        // Confidence based on signal agreement\n75:        let scores = [ultrasonic_score, bit_plane_score, autocorr_score];\n76:        let mean = scores.iter().sum::<f64>() / 3.0;\n77:        let variance = scores.iter().map(|s| (s - mean).powi(2)).sum::<f64>() / 3.0;\n78:        let confidence = 1.0 - variance.sqrt(); // Higher agreement = higher confidence\n79:\n80:        // Calibrate probability (apply sigmoid-like curve for better separation)\n81:        let detection_probability = Self::calibrate_probability(raw_probability);\n82:\n83:        let verdict = match (detection_probability, confidence) {\n84:            (p, c) if p > 0.8 && c > 0.6 => \"AI WATERMARK DETECTED - High confidence\",\n85:            (p, _) if p > 0.7 => \"LIKELY AI WATERMARK - Watermark signatures present\",\n86:            (p, _) if p > 0.5 => \"POSSIBLY AI WATERMARK - Some signatures detected\",\n87:            (p, _) if p > 0.3 => \"UNLIKELY AI WATERMARK - Few signatures\",\n88:            _ => \"NO AI WATERMARK - No watermark signatures\",\n89:        };\n90:\n91:        PolezDetectionResult {"}]},"parent_tool_use_id":null,"session_id":"c9bd7957-c8f2-4e48-8fcc-7059d242854c","uuid":"754193f3-2858-4a16-ac0f-df8f4d4e88ad","tool_use_result":{"mode":"content","numFiles":0,"filenames":[],"content":"13:#[derive(Debug, Clone, Serialize)]\n14:pub str