{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012KF66ytj2EkpwUfttvFb63","type":"tool_result","content":"     1→import { useState, useRef, useCallback } from 'react';\n     2→import type { FileInfo } from '../api/client';\n     3→import { uploadFile } from '../api/client';\n     4→\n     5→interface Props {\n     6→  fileInfo: FileInfo | null;\n     7→  onFileLoaded: (info: FileInfo) => void;\n     8→}\n     9→\n    10→export function FileHeader({ fileInfo, onFileLoaded }: Props) {\n    11→  const [loading, setLoading] = useState(false);\n    12→  const [error, setError] = useState<string | null>(null);\n    13→  const [dragOver, setDragOver] = useState(false);\n    14→  const inputRef = useRef<HTMLInputElement>(null);\n    15→\n    16→  const handleFile = useCallback(async (file: File) => {\n    17→    setLoading(true);\n    18→    setError(null);\n    19→    try {\n    20→      const info = await uploadFile(file);\n    21→      onFileLoaded(info);\n    22→    } catch (e: unknown) {\n    23→      setError(e instanceof Error ? e.message : String(e));\n    24→    } finally {\n    25→      setLoading(false);\n    26→    }\n    27→  }, [onFileLoaded]);\n    28→\n    29→  const handleDrop = useCallback((e: React.DragEvent) => {\n    30→    e.preventDefault();\n    31→    setDragOver(false);\n    32→    const file = e.dataTransfer.files[0];\n    33→    if (file) handleFile(file);\n    34→  }, [handleFile]);\n    35→\n    36→  const handleDragOver = useCallback((e: React.DragEvent) => {\n    37→    e.preventDefault();\n    38→    setDragOver(true);\n    39→  }, []);\n    40→\n    41→  const handleDragLeave = useCallback(() => {\n    42→    setDragOver(false);\n    43→  }, []);\n    44→\n    45→  const handlePickerChange = useCallback((e: React.ChangeEvent<HTMLInputElement>) => {\n    46→    const file = e.target.files?.[0];\n    47→    if (file) handleFile(file);\n    48→  }, [handleFile]);\n    49→\n    50→  const formatDuration = (secs: number) => {\n    51→    const m = Math.floor(secs / 60);\n    52→    const s = Math.floor(secs % 60);\n    53→    return `${m}:${s.toString().padStart(2, '0')}`;\n    54→  };\n    55→\n    56→  if (fileInfo && !loading) {\n    57→    return (\n    58→      <div className=\"flex items-center gap-4 bg-zinc-900 border-b border-zinc-700 px-4 py-3\">\n    59→        <span className=\"text-purple-400 font-bold text-lg tracking-wider\">POLEZ</span>\n    60→        <div className=\"flex items-center gap-4 text-zinc-400 text-sm flex-1\">\n    61→          <span className=\"text-zinc-200 font-medium\">{fileInfo.file_path.split('/').pop()}</span>\n    62→          <span>{fileInfo.format.toUpperCase()}</span>\n    63→          <span>{fileInfo.sample_rate / 1000}kHz</span>\n    64→          <span>{fileInfo.channels}ch</span>\n    65→          <span>{formatDuration(fileInfo.duration_secs)}</span>\n    66→        </div>\n    67→        <button\n    68→          onClick={() => inputRef.current?.click()}\n    69→          className=\"text-zinc-400 hover:text-zinc-200 text-sm\"\n    70→        >\n    71→          Change file\n    72→        </button>\n    73→        <input\n    74→          ref={inputRef}\n    75→          type=\"file\"\n    76→          accept=\"audio/*\"\n    77→          onChange={handlePickerChange}\n    78→          className=\"hidden\"\n    79→        />\n    80→      </div>\n    81→    );\n    82→  }\n    83→\n    84→  return (\n    85→    <div\n    86→      onDrop={handleDrop}\n    87→      onDragOver={handleDragOver}\n    88→      onDragLeave={handleDragLeave}\n    89→      className={`flex flex-col items-center justify-center gap-3 border-2 border-dashed rounded-lg mx-4 my-4 py-12 transition-colors ${\n    90→        dragOver\n    91→          ? 'border-purple-400 bg-purple-500/10'\n    92→          : 'border-zinc-600 bg-zinc-900 hover:border-zinc-500'\n    93→      }`}\n    94→    >\n    95→      <div className=\"text-purple-400 font-bold text-2xl tracking-widest mb-2\">POLEZ</div>\n    96→      <div className=\"text-zinc-500 text-xs mb-4\">Audio Forensics & Sanitization Engine</div>\n    97→      {loading ? (\n    98→        <div className=\"text-zinc-400 text-sm animate-pulse\">Loading audio...</div>\n    99→      ) : (\n   100→        <>\n   101→          <div className=\"text-zinc-400 text-sm\">\n   102→            Drag & drop an audio file here\n   103→          </div>\n   104→          <div className=\"text-zinc-500 text-xs\">or</div>\n   105→          <button\n   106→            onClick={() => inputRef.current?.click()}\n   107→            className=\"bg-purple-600 hover:bg-purple-500 text-white px-4 py-1.5 rounded text-sm font-medium\"\n   108→          >\n   109→            Choose File\n   110→          </button>\n   111→          <input\n   112→            ref={inputRef}\n   113→            type=\"file\"\n   114→            accept=\"audio/*\"\n   115→            onChange={handlePickerChange}\n   116→            className=\"hidden\"\n   117→          />\n   118→        </>\n   119→      )}\n   120→      {error && <span className=\"text-red-400 text-sm\">{error}</span>}\n   121→    </div>\n   122→  );\n   123→}\n   124→"}]},"parent_tool_use_id":null,"session_id":"c9bd7957-c8f2-4e48-8fcc-7059d242854c","uuid":"fc0b12ba-ffd7-4cf6-b39b-e4989535b45f","tool_use_result":{"type":"text","file":{"filePath":"/Users/captain/code/github.com/polez/gui/src/components/FileHeader.tsx","content":"import { useState, useRef, useCallback } from 'react';\nimport type { FileInfo } from '../api/client';\nimport { uploadFile } from '../api/client';\n\ninterface Props {\n  fileInfo: FileInfo | null;\n  onFileLoaded: (info: FileInfo) => void;\n}\n\nexport function FileHeader({ fileInfo, onFileLoaded }: Props) {\n  const [loading, setLoading] = useState(false);\n  const [error, setError] = useState<string | null>(null);\n  const [dragOver, setDragOver] = useState(false);\n  const inputRef = useRef<HTMLInputElement>(null);\n\n  const handleFile = useCallback(async (file: File) => {\n    setLoading(true);\n    setError(null);\n    try {\n      const info = await uploadFile(file);\n      onFileLoaded(info);\n    } catch (e: unknown) {\n      setError(e instanceof Error ? e.message : String(e));\n    } finally {\n      setLoading(false);\n    }\n  }, [onFileLoaded]);\n\n  const handleDrop = useCallback((e: React.DragEvent) => {\n    e.preventDefault();\n    setDragOver(false);\n    const file = e.dataTransfer.files[0];\n    if (file) handleFile(file);\n  }, [handleFile]);\n\n  const handleDragOver = useCallback((e: React.DragEvent) => {\n    e.preventDefault();\n    setDragOver(true);\n  }, []);\n\n  const handleDragLeave = useCallback(() => {\n    setDragOver(false);\n  }, []);\n\n  const handlePickerChange = useCallback((e: React.ChangeEvent<HTMLInputElement>) => {\n    const file = e.target.files?.[0];\n    if (file) handleFile(file);\n  }, [handleFile]);\n\n  const formatDuration = (secs: number) => {\n    const m = Math.floor(secs / 60);\n    const s = Math.floor(secs % 60);\n    return `${m}:${s.toString().padStart(2, '0')}`;\n  };\n\n  if (fileInfo && !loading) {\n    return (\n      <div className=\"flex items-center gap-4 bg-zinc-900 border-b border-zinc-700 px-4 py-3\">\n        <span className=\"text-purple-400 font-bold text-lg tracking-wider\">POLEZ</span>\n        <div className=\"flex items-center gap-4 text-zinc-400 text-sm flex-1\">\n          <span className=\"text-zinc-200 font-medium\">{fileInfo.file_path.split('/').pop()}</span>\n          <span>{fileInfo.format.toUpperCase()}</span>\n          <span>{fileInfo.sample_rate / 1000}kHz</span>\n          <span>{fileInfo.channels}ch</span>\n          <span>{formatDuration(fileInfo.duration_secs)}</span>\n        </div>\n        <button\n          onClick={() => inputRef.current?.click()}\n          className=\"text-zinc-400 hover:text-zinc-200 text-sm\"\n        >\n          Change file\n        </button>\n        <input\n          ref={inputRef}\n          type=\"file\"\n          accept=\"audio/*\"\n          onChange={handlePickerChange}\n          className=\"hidden\"\n        />\n      </div>\n    );\n  }\n\n  return (\n    <div\n      onDrop={handleDrop}\n      onDragOver={handleDragOver}\n      onDragLeave={handleDragLeave}\n      className={`flex flex-col items-center justify-center gap-3 border-2 border-dashed rounded-lg mx-4 my-4 py-12 transition-colors ${\n        dragOver\n          ? 'border-purple-400 bg-purple-500/10'\n          : 'border-zinc-600 bg-zinc-900 hover:border-zinc-500'\n      }`}\n    >\n      <div className=\"text-purple-400 font-bold text-2xl tracking-widest mb-2\">POLEZ</div>\n      <div className=\"text-zinc-500 text-xs mb-4\">Audio Forensics & Sanitization Engine</div>\n      {loading ? (\n        <div className=\"text-zinc-400 text-sm animate-pulse\">Loading audio...</div>\n      ) : (\n        <>\n          <div className=\"text-zinc-400 text-sm\">\n            Drag & drop an audio file here\n          </div>\n          <div className=\"text-zinc-500 text-xs\">or</div>\n          <button\n            onClick={() => inputRef.current?.click()}\n            className=\"bg-purple-600 hover:bg-purple-500 text-white px-4 py-1.5 rounded text-sm font-medium\"\n          >\n            Choose File\n          </button>\n          <input\n            ref={inputRef}\n            type=\"file\"\n            accept=\"audio/*\"\n            onChange={handlePickerChange}\n            className=\"hidden\"\n          />\n        </>\n      )}\n      {error && <span className=\"text-red-400 text-sm\">{error}</span>}\n    </div>\n  );\n}\n","numLines":124,"startLine":1,"totalLines":124}}}
