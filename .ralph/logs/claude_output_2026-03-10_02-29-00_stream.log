ePolez(): Promise<any> {\n   106→  const res = await fetch(`${BASE}/api/analyze/polez`, { method: 'POST' });\n   107→  if (!res.ok) throw new Error(await res.text());\n   108→  return res.json();\n   109→}\n   110→\n   111→export async function analyzeStatistical(): Promise<any> {\n   112→  const res = await fetch(`${BASE}/api/analyze/statistical`, { method: 'POST' });\n   113→  if (!res.ok) throw new Error(await res.text());\n   114→  return res.json();\n   115→}\n   116→\n   117→export async function analyzeMetadata(): Promise<any> {\n   118→  const res = await fetch(`${BASE}/api/analyze/metadata`, { method: 'POST' });\n   119→  if (!res.ok) throw new Error(await res.text());\n   120→  return res.json();\n   121→}\n   122→\n   123→export function getAudioUrl(): string {\n   124→  return `${BASE}/api/audio`;\n   125→}\n   126→\n   127→export interface CleanResponse {\n   128→  success: boolean;\n   129→  metadata_removed: number;\n   130→  patterns_found: number;\n   131→  patterns_suppressed: number;\n   132→  quality_loss: number;\n   133→  processing_time: number;\n   134→  before: any;\n   135→  after: any;\n   136→}\n   137→\n   138→export async function cleanFile(mode?: string): Promise<CleanResponse> {\n   139→  const res = await fetch(`${BASE}/api/clean`, {\n   140→    method: 'POST',\n   141→    headers: { 'Content-Type': 'application/json' },\n   142→    body: JSON.stringify({ mode: mode || 'standard' }),\n   143→  });\n   144→  if (!res.ok) throw new Error(await res.text());\n   145→  return res.json();\n   146→}\n   147→\n   148→export async function getCleanedWaveform(width = 1200, start?: number, end?: number): Promise<WaveformData> {\n   149→  const params = new URLSearchParams({ width: String(width) });\n   150→  if (start !== undefined) params.set('start', String(start));\n   151→  if (end !== undefined) params.set('end', String(end));\n   152→  const res = await fetch(`${BASE}/api/waveform/cleaned?${params}`);\n   153→  if (!res.ok) throw new Error(await res.text());\n   154→  return res.json();\n   155→}\n   156→\n   157→export function getCleanedAudioUrl(): string {\n   158→  return `${BASE}/api/audio/cleaned`;\n   159→}\n   160→\n   161→export async function saveCleanedFile(): Promise<void> {\n   162→  const res = await fetch(`${BASE}/api/save`, { method: 'POST' });\n   163→  if (!res.ok) throw new Error(await res.text());\n   164→  const blob = await res.blob();\n   165→  const url = URL.createObjectURL(blob);\n   166→  const a = document.createElement('a');\n   167→  a.href = url;\n   168→  a.download = 'cleaned_output.wav';\n   169→  a.click();\n   170→  URL.revokeObjectURL(url);\n   171→}\n   172→"}]},"parent_tool_use_id":null,"session_id":"c9bd7957-c8f2-4e48-8fcc-7059d242854c","uuid":"4ff79222-e690-4dc2-9fe2-e5b6c14dd148","tool_use_result":{"type":"text","file":{"filePath":"/Users/captain/code/github.com/polez/gui/src/api/client.ts","content":"const BASE = '';\n\nexport interface FileInfo {\n  file_path: string;\n  format: string;\n  duration_secs: number;\n  sample_rate: number;\n  channels: number;\n}\n\nexport interface WaveformData {\n  min: number[];\n  max: number[];\n  sample_rate: number;\n  duration_secs: number;\n  channels: number;\n}\n\nexport interface SpectrogramData {\n  magnitudes: number[][];\n  freq_min: number;\n  freq_max: number;\n  time_start: number;\n  time_end: number;\n  num_freq_bins: number;\n  num_time_frames: number;\n}\n\nexport interface PlaneSummary {\n  bit: number;\n  ones_ratio: number;\n  bias: number;\n}\n\nexport interface BitPlaneData {\n  planes: PlaneSummary[];\n}\n\nexport async function uploadFile(file: File): Promise<FileInfo> {\n  const form = new FormData();\n  form.append('file', file);\n  const res = await fetch(`${BASE}/api/upload`, {\n    method: 'POST',\n    body: form,\n  });\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport async function loadFile(path: string): Promise<FileInfo> {\n  const res = await fetch(`${BASE}/api/load`, {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ path }),\n  });\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport async function getWaveform(width = 1200, start?: number, end?: number): Promise<WaveformData> {\n  const params = new URLSearchParams({ width: String(width) });\n  if (start !== undefined) params.set('start', String(start));\n  if (end !== undefined) params.set('end', String(end));\n  const res = await fetch(`${BASE}/api/waveform?${params}`);\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport async function getSpectrogram(opts?: {\n  fft_size?: number;\n  freq_min?: number;\n  freq_max?: number;\n  start?: number;\n  duration?: number;\n}): Promise<SpectrogramData> {\n  const params = new URLSearchParams();\n  if (opts?.fft_size) params.set('fft_size', String(opts.fft_size));\n  if (opts?.freq_min !== undefined) params.set('freq_min', String(opts.freq_min));\n  if (opts?.freq_max !== undefined) params.set('freq_max', String(opts.freq_max));\n  if (opts?.start !== undefined) params.set('start', String(opts.start));\n  if (opts?.duration !== undefined) params.set('duration', String(opts.duration));\n  const res = await fetch(`${BASE}/api/spectrogram?${params}`);\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport async function getBitPlane(): Promise<BitPlaneData> {\n  const res = await fetch(`${BASE}/api/bitplane`);\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport async function analyzeAll(): Promise<any> {\n  const res = await fetch(`${BASE}/api/analyze/all`, { method: 'POST' });\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport async function analyzeWatermark(): Promise<any> {\n  const res = await fetch(`${BASE}/api/analyze/watermark`, { method: 'POST' });\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport async function analyzePolez(): Promise<any> {\n  const res = await fetch(`${BASE}/api/analyze/polez`, { method: 'POST' });\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport async function analyzeStatistical(): Promise<any> {\n  const res = await fetch(`${BASE}/api/analyze/statistical`, { method: 'POST' });\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport async function analyzeMetadata(): Promise<any> {\n  const res = await fetch(`${BASE}/api/analyze/metadata`, { method: 'POST' });\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport function getAudioUrl(): string {\n  return `${BASE}/api/audio`;\n}\n\nexport interface CleanResponse {\n  success: boolean;\n  metadata_removed: number;\n  patterns_found: number;\n  patterns_suppressed: number;\n  quality_loss: number;\n  processing_time: number;\n  before: any;\n  after: any;\n}\n\nexport async function cleanFile(mode?: string): Promise<CleanResponse> {\n  const res = await fetch(`${BASE}/api/clean`, {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ mode: mode || 'standard' }),\n  });\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport async function getCleanedWaveform(width = 1200, start?: number, end?: number): Promise<WaveformData> {\n  const params = new URLSearchParams({ width: String(width) });\n  if (start !== undefined) params.set('start', String(start));\n  if (end !== undefined) params.set('end', String(end));\n  const res = await fetch(`${BASE}/api/waveform/cleaned?${params}`);\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport function getCleanedAudioUrl(): string {\n  return `${BASE}/api/audio/cleaned`;\n}\n\nexport async function saveCleanedFile(): Promise<void> {\n  const res = await fetch(`${BASE}/api/save`, { method: 'POST' });\n  if (!res.ok) throw new Error(await res.text());\n  const blob = await res.blob();\n  const url = URL.createObjectURL(blob);\n  const a = document.createElement('a');\n  a.href = url;\n  a.download = 'cleaned_output.wav';\n  a.click();\n  URL.revokeObjectURL(url);\n}\n","numLines":172,"startLine":1,"totalLines":172}}}
