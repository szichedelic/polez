{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RBzVYWWJR3AWYtu5TWJR7d","type":"tool_result","content":"     1→use std::path::{Path, PathBuf};\n     2→use std::time::Instant;\n     3→\n     4→use crate::audio::{self, AudioBuffer, AudioFormat};\n     5→use crate::config::{AdvancedFlags, AppConfig, FingerprintRemovalConfig};\n     6→use crate::error::Result;\n     7→use crate::sanitization::fingerprint::FingerprintRemover;\n     8→use crate::sanitization::metadata::MetadataCleaner;\n     9→use crate::sanitization::spectral::SpectralCleaner;\n    10→use crate::sanitization::stealth::StealthOps;\n    11→\n    12→/// Sanitization mode - replaces the 5 separate Python sanitizer files.\n    13→#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n    14→pub enum SanitizationMode {\n    15→    /// Metadata strip + light processing\n    16→    Fast,\n    17→    /// Full pipeline, standard settings\n    18→    Standard,\n    19→    /// All stealth operations, quality-first\n    20→    Preserving,\n    21→    /// Heavy phase randomization, aggressive cleaning\n    22→    Aggressive,\n    23→}\n    24→\n    25→/// Result of a sanitization run.\n    26→#[derive(Debug, Clone)]\n    27→pub struct SanitizationResult {\n    28→    pub success: bool,\n    29→    pub output_file: PathBuf,\n    30→    pub metadata_removed: usize,\n    31→    pub patterns_found: usize,\n    32→    pub patterns_suppressed: usize,\n    33→    pub quality_loss: f64,\n    34→    pub processing_time: f64,\n    35→}\n    36→\n    37→/// Unified sanitization pipeline.\n    38→pub struct SanitizationPipeline {\n    39→    mode: SanitizationMode,\n    40→    paranoid: bool,\n    41→    flags: AdvancedFlags,\n    42→    fp_config: FingerprintRemovalConfig,\n    43→    output_format: Option<AudioFormat>,\n    44→}\n    45→\n    46→impl SanitizationPipeline {\n    47→    pub fn new(\n    48→        mode: SanitizationMode,\n    49→        paranoid: bool,\n    50→        flags: AdvancedFlags,\n    51→        fp_config: FingerprintRemovalConfig,\n    52→        output_format: Option<AudioFormat>,\n    53→    ) -> Self {\n    54→        Self {\n    55→            mode,\n    56→            paranoid,\n    57→            flags,\n    58→            fp_config,\n    59→            output_format,\n    60→        }\n    61→    }\n    62→\n    63→    /// Determine the mode based on config.\n    64→    pub fn mode_from_config(config: &AppConfig) -> SanitizationMode {\n    65→        match config.paranoia_level {\n    66→            crate::config::ParanoiaLevel::Low => SanitizationMode::Fast,\n    67→            crate::config::ParanoiaLevel::Medium => SanitizationMode::Standard,\n    68→            crate::config::ParanoiaLevel::High => SanitizationMode::Preserving,\n    69→            crate::config::ParanoiaLevel::Maximum => SanitizationMode::Aggressive,\n    70→        }\n    71→    }\n    72→\n    73→    /// Run the sanitization pipeline.\n    74→    pub fn run(&self, input: &Path, output: &Path) -> Result<SanitizationResult> {\n    75→        let start = Instant::now();\n    76→\n    77→        let metadata_removed = MetadataCleaner::strip_to(input, output)?;\n    78→\n    79→        let (mut buffer, source_format) = audio::load_audio(output)?;\n    80→        let original_rms = buffer.rms();\n    81→\n    82→        let (patterns_found, patterns_suppressed) = match self.mode {\n    83→            SanitizationMode::Fast => (0, 0),\n    84→            SanitizationMode::Standard => self.run_standard(&mut buffer)?,\n    85→            SanitizationMode::Preserving => self.run_preserving(&mut buffer)?,\n    86→            SanitizationMode::Aggressive => self.run_aggressive(&mut buffer)?,\n    87→        };\n    88→\n    89→        // Paranoid multi-pass runs spectral cleaning extra times; fingerprint/stealth run once\n    90→        // to avoid compounding artifacts that would degrade perceptual quality.\n    91→        if self.paranoid && self.mode != SanitizationMode::Fast {\n    92→            for _pass in 0..2 {\n    93→                SpectralCleaner::clean(&mut buffer, self.paranoid, &self.flags)?;\n    94→            }\n    95→        }\n    96→\n    97→        // Adaptive notch runs last — STFT operations in earlier passes would undo its work.\n    98→        let (mut patterns_found, mut patterns_suppressed) = (patterns_found, patterns_suppressed);\n    99→        if self.flags.adaptive_notch && self.mode != SanitizationMode::Fast {\n   100→            let notched = SpectralCleaner::adaptive_notch_pass(&mut buffer, self.paranoid)?;\n   101→            patterns_found += notched;\n   102→            patterns_suppressed += notched;\n   103→        }\n   104→\n   105→        let processed_rms = buffer.rms();\n   106→        if processed_rms > 1e-10 && original_rms > 1e-10 {\n   107→            buffer.normalize_rms(original_rms);\n   108→        }\n   109→\n   110→        buffer.soft_clip(0.99);\n   111→\n   112→        let quality_loss = if original_rms > 1e-10 {\n   113→            ((original_rms - buffer.rms()).abs() / original_rms * 100.0) as f64\n   114→        } else {\n   115→            0.0\n   116→        };\n   117→\n   118→        let out_format = self.output_format.unwrap_or(source_format);\n   119→        // Fall back to WAV if the source format has no encoder\n   120→        let out_format = if out_format.has_encoder() {\n   121→            out_format\n   122→        } else {\n   123→            audio::AudioFormat::Wav\n   124→        };\n   125→        audio::save_audio(&buffer, output, out_format)?;\n   126→\n   127→        let elapsed = start.elapsed().as_secs_f64();\n   128→\n   129→        Ok(SanitizationResult {\n   130→            success: true,\n   131→            output_file: output.to_path_buf(),\n   132→            metadata_removed,\n   133→            patterns_found,\n   134→            patterns_suppressed,\n   135→            quality_loss,\n   136→            processing_time: elapsed,\n   137→        })\n   138→    }\n   139→\n   140→    fn run_standard(&self, buffer: &mut AudioBuffer) -> Result<(usize, usize)> {\n   141→        let (found, suppressed) = SpectralCleaner::clean(buffer, self.paranoid, &self.flags)?;\n   142→        FingerprintRemover::remove(buffer, self.paranoid, &self.fp_config)?;\n   143→        Ok((found, suppressed))\n   144→    }\n   145→\n   146→    fn run_preserving(&self, buffer: &mut AudioBuffer) -> Result<(usize, usize)> {\n   147→        let (found, suppressed) = SpectralCleaner::clean(buffer, self.paranoid, &self.flags)?;\n   148→        FingerprintRemover::remove(buffer, self.paranoid, &self.fp_config)?;\n   149→        StealthOps::apply(buffer, &self.flags, self.paranoid)?;\n   150→        Ok((found, suppressed))\n   151→    }\n   152→\n   153→    fn run_aggressive(&self, buffer: &mut AudioBuffer) -> Result<(usize, usize)> {\n   154→        let (found, suppressed) = SpectralCleaner::clean(buffer, true, &self.flags)?;\n   155→        FingerprintRemover::remove(buffer, true, &self.fp_config)?;\n   156→        StealthOps::apply(buffer, &self.flags, true)?;\n   157→        Ok((found, suppressed))\n   158→    }\n   159→}\n   160→"}]},"parent_tool_use_id":null,"session_id":"c9bd7957-c8f2-4e48-8fcc-7059d242854c","uuid":"8fd50efc-f8cf-421e-9def-e798553895ab","tool_use_result":{"type":"text","file":{"filePath":"/Users/captain/code/github.com/polez/src/sanitization/pipeline.rs","content":"use std::path::{Path, PathBuf};\nuse std::time::Instant;\n\nuse crate::audio::{self, AudioBuffer, AudioFormat};\nuse crate::config::{AdvancedFlags, AppConfig, FingerprintRemovalConfig};\nuse crate::error::Result;\nuse crate::sanitization::fingerprint::FingerprintRemover;\nuse crate::sanitization::metadata::MetadataCleaner;\nuse crate::sanitization::spectral::SpectralCleaner;\nuse crate::sanitization::stealth::StealthOps;\n\n/// Sanitization mode - replaces the 5 separate Python sanitizer files.\n#[derive(Debug, Clone, Copy, PartialEq, Eq)]\npub enum SanitizationMode {\n    /// Metadata strip + light processing\n    Fast,\n    /// Full pipeline, standard settings\n    Standard,\n    /// All stealth operations, quality-first\n    Preserving,\n    /// Heavy phase randomization, aggressive cleaning\n    Aggressive,\n}\n\n/// Result of a sanitization run.\n#[derive(Debug, Clone)]\npub struct SanitizationResult {\n    pub success: bool,\n    pub output_file: PathBuf,\n    pub metadata_removed: usize,\n    pub patterns_found: usize,\n    pub patterns_suppressed: usize,\n    pub quality_loss: f64,\n    pub processing_time: f64,\n}\n\n/// Unified sanitization pipeline.\npub struct SanitizationPipeline {\n    mode: SanitizationMode,\n    paranoid: bool,\n    flags: AdvancedFlags,\n    fp_config: FingerprintRemovalConfig,\n    output_format: Option<AudioFormat>,\n}\n\nimpl SanitizationPipeline {\n    pub fn new(\n        mode: SanitizationMode,\n        paranoid: bool,\n        flags: AdvancedFlags,\n        fp_config: FingerprintRemovalConfig,\n        output_format: Option<AudioFormat>,\n    ) -> Self {\n        Self {\n            mode,\n            paranoid,\n            flags,\n            fp_config,\n            output_format,\n        }\n    }\n\n    /// Determine the mode based on config.\n    pub fn mode_from_config(config: &AppConfig) -> SanitizationMode {\n        match config.paranoia_level {\n            crate::config::ParanoiaLevel::Low => SanitizationMode::Fast,\n            crate::config::ParanoiaLevel::Medium => SanitizationMode::Standard,\n            crate::config::ParanoiaLevel::High => SanitizationMode::Preserving,\n            crate::config::ParanoiaLevel::Maximum => SanitizationMode::Aggressive,\n        }\n    }\n\n    /// Run the sanitization pipeline.\n    pub fn run(&self, input: &Path, output: &Path) -> Result<SanitizationResult> {\n        let start = Instant::now();\n\n        let metadata_removed = MetadataCleaner::strip_to(input, output)?;\n\n        let (mut buffer, source_format) = audio::load_audio(output)?;\n        let original_rms = buffer.rms();\n\n        let (patterns_found, patterns_suppressed) = match self.mode {\n            SanitizationMode::Fast => (0, 0),\n            SanitizationMode::Standard => self.run_standard(&mut buffer)?,\n            SanitizationMode::Preserving => self.run_preserving(&mut buffer)?,\n            SanitizationMode::Aggressive => self.run_aggressive(&mut buffer)?,\n        };\n\n        // Paranoid multi-pass runs spectral cleaning extra times; fingerprint/stealth run once\n        // to avoid compounding artifacts that would degrade perceptual quality.\n        if self.paranoid && self.mode != SanitizationMode::Fast {\n            for _pass in 0..2 {\n                SpectralCleaner::clean(&mut buffer, self.paranoid, &self.flags)?;\n            }\n        }\n\n        // Adaptive notch runs last — STFT operations in earlier passes would undo its work.\n        let (mut patterns_found, mut patterns_suppressed) = (patterns_found, patterns_suppressed);\n        if self.flags.adaptive_notch && self.mode != SanitizationMode::Fast {\n            let notched = SpectralCleaner::adaptive_notch_pass(&mut buffer, self.paranoid)?;\n            patterns_found += notched;\n            patterns_suppressed += notched;\n        }\n\n        let processed_rms = buffer.rms();\n        if processed_rms > 1e-10 && original_rms > 1e-10 {\n            buffer.normalize_rms(original_rms);\n        }\n\n        buffer.soft_clip(0.99);\n\n        let quality_loss = if original_rms > 1e-10 {\n            ((original_rms - buffer.rms()).abs() / original_rms * 100.0) as f64\n        } else {\n            0.0\n        };\n\n        let out_format = self.output_format.unwrap_or(source_format);\n        // Fall back to WAV if the source format has no encoder\n        let out_format = if out_format.has_encoder() {\n            out_format\n        } else {\n            audio::AudioFormat::Wav\n        };\n        audio::save_audio(&buffer, output, out_format)?;\n\n        let elapsed = start.elapsed().as_secs_f64();\n\n        Ok(SanitizationResult {\n            success: true,\n            output_file: output.to_path_buf(),\n            metadata_removed,\n            patterns_found,\n            patterns_suppressed,\n            quality_loss,\n            processing_time: elapsed,\n        })\n    }\n\n    fn run_standard(&self, buffer: &mut AudioBuffer) -> Result<(usize, usize)> {\n        let (found, suppressed) = SpectralCleaner::clean(buffer, self.paranoid, &self.flags)?;\n        FingerprintRemover::remove(buffer, self.paranoid, &self.fp_config)?;\n        Ok((found, suppressed))\n    }\n\n    fn run_preserving(&self, buffer: &mut AudioBuffer) -> Result<(usize, usize)> {\n        let (found, suppressed) = SpectralCleaner::clean(buffer, self.paranoid, &self.flags)?;\n        FingerprintRemover::remove(buffer, self.paranoid, &self.fp_config)?;\n        StealthOps::apply(buffer, &self.flags, self.paranoid)?;\n        Ok((found, suppressed))\n    }\n\n    fn run_aggressive(&self, buffer: &mut AudioBuffer) -> Result<(usize, usize)> {\n        let (found, suppressed) = SpectralCleaner::clean(buffer, true, &self.flags)?;\n        FingerprintRemover::remove(buffer, true, &self.fp_config)?;\n        StealthOps::apply(buffer, &self.flags, true)?;\n        Ok((found, suppressed))\n    }\n}\n","numLines":160,"startLine":1,"totalLines":160}}}
