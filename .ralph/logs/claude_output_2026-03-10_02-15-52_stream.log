= { version = \"5\", optional = true }\n    67→mime_guess = { version = \"2\", optional = true }\n    68→tempfile = { version = \"3\", optional = true }\n    69→\n    70→[features]\n    71→default = [\"gui\"]\n    72→gui = [\"dep:axum\", \"dep:tokio\", \"dep:tower-http\", \"dep:rust-embed\", \"dep:serde_json\", \"dep:open\", \"dep:mime_guess\", \"dep:tempfile\"]\n    73→\n    74→[dev-dependencies]\n    75→assert_cmd = \"2\"\n    76→predicates = \"3\"\n    77→tempfile = \"3\"\n    78→\n    79→[[bin]]\n    80→name = \"polez\"\n    81→path = \"src/main.rs\"\n    82→"}]},"parent_tool_use_id":null,"session_id":"c9bd7957-c8f2-4e48-8fcc-7059d242854c","uuid":"b6536e8f-6dd5-4925-8c45-cc6a6a2f9044","tool_use_result":{"type":"text","file":{"filePath":"/Users/captain/code/github.com/polez/Cargo.toml","content":"[package]\nname = \"polez\"\nversion = \"2.0.0\"\nedition = \"2021\"\ndescription = \"Polez - Audio forensics and sanitization engine\"\nlicense = \"MIT\"\n\n[dependencies]\n# CLI\nclap = { version = \"4\", features = [\"derive\", \"color\", \"wrap_help\"] }\n\n# Audio metadata\nlofty = \"0.21\"\n\n# Audio I/O\nhound = \"3.5\"\nsymphonia = { version = \"0.5\", features = [\"mp3\", \"wav\", \"pcm\", \"isomp4\", \"aac\"] }\nmp3lame-encoder = \"0.2\"\n\n# DSP / FFT\nrustfft = \"6\"\nrealfft = \"3\"\nndarray = \"0.16\"\n\n# Resampling\nrubato = \"0.15\"\n\n# Numeric\nnum-complex = \"0.4\"\nrand = \"0.8\"\nrand_distr = \"0.4\"\n\n# Parallelism\nrayon = \"1.10\"\n\n# Config\nserde = { version = \"1\", features = [\"derive\"] }\nserde_yaml = \"0.9\"\ndirs = \"5\"\n\n# UI\nindicatif = \"0.17\"\nconsole = \"0.15\"\ncolored = \"2\"\n\n# Logging\ntracing = \"0.1\"\ntracing-subscriber = { version = \"0.3\", features = [\"env-filter\"] }\n\n# Error handling\nanyhow = \"1\"\nthiserror = \"2\"\n\n# Hashing\nsha2 = \"0.10\"\n\n# Misc\nwalkdir = \"2\"\n\n# GUI (optional)\naxum = { version = \"0.8\", features = [\"multipart\"], optional = true }\ntokio = { version = \"1\", features = [\"full\"], optional = true }\ntower-http = { version = \"0.6\", features = [\"cors\", \"fs\"], optional = true }\nrust-embed = { version = \"8\", optional = true }\nserde_json = { version = \"1\", optional = true }\nopen = { version = \"5\", optional = true }\nmime_guess = { version = \"2\", optional = true }\ntempfile = { version = \"3\", optional = true }\n\n[features]\ndefault = [\"gui\"]\ngui = [\"dep:axum\", \"dep:tokio\", \"dep:tower-http\", \"dep:rust-embed\", \"dep:serde_json\", \"dep:open\", \"dep:mime_guess\", \"dep:tempfile\"]\n\n[dev-dependencies]\nassert_cmd = \"2\"\npredicates = \"3\"\ntempfile = \"3\"\n\n[[bin]]\nname = \"polez\"\npath = \"src/main.rs\"\n","numLines":82,"startLine":1,"totalLines":82}}}
