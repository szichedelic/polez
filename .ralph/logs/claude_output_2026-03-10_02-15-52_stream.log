{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RDJTUWsGX5ehx716jC1vDF","type":"tool_result","content":"     1→use std::path::Path;\n     2→\n     3→use crate::audio::AudioBuffer;\n     4→use crate::error::{PolezError, Result};\n     5→\n     6→#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n     7→pub enum AudioFormat {\n     8→    Wav,\n     9→    Mp3,\n    10→}\n    11→\n    12→impl AudioFormat {\n    13→    pub fn extension(&self) -> &str {\n    14→        match self {\n    15→            AudioFormat::Wav => \"wav\",\n    16→            AudioFormat::Mp3 => \"mp3\",\n    17→        }\n    18→    }\n    19→}\n    20→\n    21→impl std::fmt::Display for AudioFormat {\n    22→    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {\n    23→        match self {\n    24→            AudioFormat::Wav => write!(f, \"WAV\"),\n    25→            AudioFormat::Mp3 => write!(f, \"MP3\"),\n    26→        }\n    27→    }\n    28→}\n    29→\n    30→/// Detect audio format from file extension.\n    31→pub fn detect_format(path: &Path) -> Result<AudioFormat> {\n    32→    match path\n    33→        .extension()\n    34→        .and_then(|e| e.to_str())\n    35→        .map(|e| e.to_lowercase())\n    36→        .as_deref()\n    37→    {\n    38→        Some(\"wav\") => Ok(AudioFormat::Wav),\n    39→        Some(\"mp3\") => Ok(AudioFormat::Mp3),\n    40→        Some(ext) => Err(PolezError::UnsupportedFormat(ext.to_string())),\n    41→        None => Err(PolezError::UnsupportedFormat(\"no extension\".to_string())),\n    42→    }\n    43→}\n    44→\n    45→/// Load an audio file into an AudioBuffer.\n    46→pub fn load_audio(path: &Path) -> Result<(AudioBuffer, AudioFormat)> {\n    47→    let format = detect_format(path)?;\n    48→    match format {\n    49→        AudioFormat::Wav => load_wav(path).map(|buf| (buf, format)),\n    50→        AudioFormat::Mp3 => load_mp3(path).map(|buf| (buf, format)),\n    51→    }\n    52→}\n    53→\n    54→/// Save an AudioBuffer to a file in the specified format.\n    55→pub fn save_audio(buffer: &AudioBuffer, path: &Path, format: AudioFormat) -> Result<()> {\n    56→    match format {\n    57→        AudioFormat::Wav => save_wav(buffer, path),\n    58→        AudioFormat::Mp3 => save_mp3(buffer, path),\n    59→    }\n    60→}\n    61→\n    62→// --- WAV ---\n    63→\n    64→fn load_wav(path: &Path) -> Result<AudioBuffer> {\n    65→    let reader = hound::WavReader::open(path)\n    66→        .map_err(|e| PolezError::AudioIo(format!(\"Failed to open WAV: {e}\")))?;\n    67→\n    68→    let spec = reader.spec();\n    69→    let channels = spec.channels as usize;\n    70→    let sample_rate = spec.sample_rate;\n    71→\n    72→    let samples_f32: Vec<f32> = match spec.sample_format {\n    73→        hound::SampleFormat::Int => {\n    74→            let max_val = (1u32 << (spec.bits_per_sample - 1)) as f32;\n    75→            reader\n    76→                .into_samples::<i32>()\n    77→                .map(|s| s.map(|v| v as f32 / max_val))\n    78→                .collect::<std::result::Result<Vec<_>, _>>()\n    79→                .map_err(|e| PolezError::AudioIo(format!(\"WAV decode error: {e}\")))?\n    80→        }\n    81→        hound::SampleFormat::Float => reader\n    82→            .into_samples::<f32>()\n    83→            .collect::<std::result::Result<Vec<_>, _>>()\n    84→            .map_err(|e| PolezError::AudioIo(format!(\"WAV decode error: {e}\")))?,\n    85→    };\n    86→\n    87→    Ok(AudioBuffer::from_interleaved(\n    88→        &samples_f32,\n    89→        channels,\n    90→        sample_rate,\n    91→    ))\n    92→}\n    93→\n    94→fn save_wav(buffer: &AudioBuffer, path: &Path) -> Result<()> {\n    95→    let spec = hound::WavSpec {\n    96→        channels: buffer.num_channels() as u16,\n    97→        sample_rate: buffer.sample_rate,\n    98→        bits_per_sample: 24,\n    99→        sample_format: hound::SampleFormat::Int,\n   100→    };\n   101→\n   102→    let mut writer = hound::WavWriter::create(path, spec)\n   103→        .map_err(|e| PolezError::AudioIo(format!(\"Failed to create WAV: {e}\")))?;\n   104→\n   105→    let max_val = (1u32 << 23) as f32; // 24-bit\n   106→    let interleaved = buffer.to_interleaved();\n   107→    for sample in interleaved {\n   108→        let clamped = sample.clamp(-1.0, 1.0);\n   109→        let int_sample = (clamped * max_val) as i32;\n   110→        writer\n   111→            .write_sample(int_sample)\n   112→            .map_err(|e| PolezError::AudioIo(format!(\"WAV write error: {e}\")))?;\n   113→    }\n   114→\n   115→    writer\n   116→        .finalize()\n   117→        .map_err(|e| PolezError::AudioIo(format!(\"WAV finalize error: {e}\")))?;\n   118→\n   119→    Ok(())\n   120→}\n   121→\n   122→// --- MP3 ---\n   123→\n   124→fn load_mp3(path: &Path) -> Result<AudioBuffer> {\n   125→    use symphonia::core::audio::SampleBuffer;\n   126→    use symphonia::core::codecs::DecoderOptions;\n   127→    use symphonia::core::formats::FormatOptions;\n   128→    use symphonia::core::io::MediaSourceStream;\n   129→    use symphonia::core::meta::MetadataOptions;\n   130→    use symphonia::core::probe::Hint;\n   131→\n   132→    let file = std::fs::File::open(path)\n   133→        .map_err(|e| PolezError::AudioIo(format!(\"Failed to open MP3: {e}\")))?;\n   134→    let mss = MediaSourceStream::new(Box::new(file), Default::default());\n   135→\n   136→    let mut hint = Hint::new();\n   137→    hint.with_extension(\"mp3\");\n   138→\n   139→    let probed = symphonia::default::get_probe()\n   140→        .format(\n   141→            &hint,\n   142→            mss,\n   143→            &FormatOptions::default(),\n   144→            &MetadataOptions::default(),\n   145→        )\n   146→        .map_err(|e| PolezError::AudioIo(format!(\"MP3 probe error: {e}\")))?;\n   147→\n   148→    let mut format_reader = probed.format;\n   149→    let track = format_reader\n   150→        .default_track()\n   151→        .ok_or_else(|| PolezError::AudioIo(\"No audio track found\".to_string()))?;\n   152→\n   153→    let track_id = track.id;\n   154→    let channels = track.codec_params.channels.map(|c| c.count()).unwrap_or(2);\n   155→    let sample_rate = track.codec_params.sample_rate.unwrap_or(44100);\n   156→\n   157→    let mut decoder = symphonia::default::get_codecs()\n   158→        .make(&track.codec_params, &DecoderOptions::default())\n   159→        .map_err(|e| PolezError::AudioIo(format!(\"MP3 decoder error: {e}\")))?;\n   160→\n   161→    let mut all_samples: Vec<f32> = Vec::new();\n   162→\n   163→    loop {\n   164→        let packet = match format_reader.next_packet() {\n   165→            Ok(p) => p,\n   166→            Err(symphonia::core::errors::Error::IoError(ref e))\n   167→                if e.kind() == std::io::ErrorKind::UnexpectedEof =>\n   168→            {\n   169→                break;\n   170→            }\n   171→            Err(_) => break,\n   172→        };\n   173→\n   174→        if packet.track_id() != track_id {\n   175→            continue;\n   176→        }\n   177→\n   178→        let decoded = match decoder.decode(&packet) {\n   179→            Ok(d) => d,\n   180→            Err(_) => continue,\n   181→        };\n   182→\n   183→        let spec = *decoded.spec();\n   184→        let num_frames = decoded.capacity();\n   185→        let mut sample_buf = SampleBuffer::<f32>::new(num_frames as u64, spec);\n   186→        sample_buf.copy_interleaved_ref(decoded);\n   187→        all_samples.extend_from_slice(sample_buf.samples());\n   188→    }\n   189→\n   190→    if all_samples.is_empty() {\n   191→        return Err(PolezError::AudioIo(\"No audio samples decoded\".to_string()));\n   192→    }\n   193→\n   194→    Ok(AudioBuffer::from_interleaved(\n   195→        &all_samples,\n   196→        channels,\n   197→        sample_rate,\n   198→    ))\n   199→}\n   200→\n   201→fn save_mp3(buffer: &AudioBuffer, path: &Path) -> Result<()> {\n   202→    use mp3lame_encoder::{Builder, FlushNoGap, InterleavedPcm};\n   203→\n   204→    let channels = buffer.num_channels();\n   205→    let mut builder = Builder::new()\n   206→        .ok_or_else(|| PolezError::AudioIo(\"Failed to create MP3 encoder\".to_string()))?;\n   207→\n   208→    builder\n   209→        .set_sample_rate(buffer.sample_rate)\n   210→        .map_err(|e| PolezError::AudioIo(format!(\"MP3 encoder config error: {e:?}\")))?;\n   211→\n   212→    builder\n   213→        .set_num_channels(channels as u8)\n   214→        .map_err(|e| PolezError::AudioIo(format!(\"MP3 encoder config error: {e:?}\")))?;\n   215→\n   216→    builder\n   217→        .set_brate(mp3lame_encoder::Bitrate::Kbps320)\n   218→        .map_err(|e| PolezError::AudioIo(format!(\"MP3 encoder config error: {e:?}\")))?;\n   219→\n   220→    builder\n   221→        .set_quality(mp3lame_encoder::Quality::Best)\n   222→        .map_err(|e| PolezError::AudioIo(format!(\"MP3 encoder config error: {e:?}\")))?;\n   223→\n   224→    let mut encoder = builder\n   225→        .build()\n   226→        .map_err(|e| PolezError::AudioIo(format!(\"MP3 encoder build error: {e:?}\")))?;\n   227→\n   228→    // Convert f32 [-1,1] to i16 for LAME\n   229→    let interleaved = buffer.to_interleaved();\n   230→    let pcm_i16: Vec<i16> = interleaved\n   231→        .iter()\n   232→        .map(|&s| (s.clamp(-1.0, 1.0) * 32767.0) as i16)\n   233→        .collect();\n   234→\n   235→    let input = InterleavedPcm(&pcm_i16);\n   236→\n   237→    let mut mp3_out = Vec::with_capacity(pcm_i16.len());\n   238→    encoder\n   239→        .encode_to_vec(input, &mut mp3_out)\n   240→        .map_err(|e| PolezError::AudioIo(format!(\"MP3 encode error: {e:?}\")))?;\n   241→\n   242→    encoder\n   243→        .flush_to_vec::<FlushNoGap>(&mut mp3_out)\n   244→        .map_err(|e| PolezError::AudioIo(format!(\"MP3 flush error: {e:?}\")))?;\n   245→\n   246→    std::fs::write(path, &mp3_out)\n   247→        .map_err(|e| PolezError::AudioIo(format!(\"Failed to write MP3: {e}\")))?;\n   248→\n   249→    Ok(())\n   250→}\n   251→"}]},"parent_tool_use_id":null,"session_id":"c9bd7957-c8f2-4e48-8fcc-7059d242854c","uuid":"8a18e9da-28d2-4eed-92ad-e6006acb79f5","tool_use_result":{"type":"text","file":{"filePath":"/Users/captain/code/github.com/polez/src/audio/io.rs","content":"use std::path::Path;\n\nuse crate::audio::AudioBuffer;\nuse crate::error::{PolezError, Result};\n\n#[derive(Debug, Clone, Copy, PartialEq, Eq)]\npub enum AudioFormat {\n    Wav,\n    Mp3,\n}\n\nimpl AudioFormat {\n    pub fn extension(&self) -> &str {\n        match self {\n            AudioFormat::Wav => \"wav\",\n            AudioFormat::Mp3 => \"mp3\",\n        }\n    }\n}\n\nimpl std::fmt::Display for AudioFormat {\n    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {\n        match self {\n            AudioFormat::Wav => write!(f, \"WAV\"),\n            AudioFormat::Mp3 => write!(f, \"MP3\"),\n        }\n    }\n}\n\n/// Detect audio format from file extension.\npub fn detect_format(path: &Path) -> Result<AudioFormat> {\n    match path\n        .extension()\n        .and_then(|e| e.to_str())\n        .map(|e| e.to_lowercase())\n        .as_deref()\n    {\n        Some(\"wav\") => Ok(AudioFormat::Wav),\n        Some(\"mp3\") => Ok(AudioFormat::Mp3),\n        Some(ext) => Err(PolezError::UnsupportedFormat(ext.to_string())),\n        None => Err(PolezError::UnsupportedFormat(\"no extension\".to_string())),\n    }\n}\n\n/// Load an audio file into an AudioBuffer.\npub fn load_audio(path: &Path) -> Result<(AudioBuffer, AudioFormat)> {\n    let format = detect_format(path)?;\n    match format {\n        AudioFormat::Wav => load_wav(path).map(|buf| (buf, format)),\n        AudioFormat::Mp3 => load_mp3(path).map(|buf| (buf, format)),\n    }\n}\n\n/// Save an AudioBuffer to a file in the specified format.\npub fn save_audio(buffer: &AudioBuffer, path: &Path, format: AudioFormat) -> Result<()> {\n    match format {\n        AudioFormat::Wav => save_wav(buffer, path),\n        AudioFormat::Mp3 => save_mp3(buffer, path),\n    }\n}\n\n// --- WAV ---\n\nfn load_wav(path: &Path) -> Result<AudioBuffer> {\n    let reader = hound::WavReader::open(path)\n        .map_err(|e| PolezError::AudioIo(format!(\"Failed to open WAV: {e}\")))?;\n\n    let spec = reader.spec();\n    let channels = spec.channels as usize;\n    let sample_rate = spec.sample_rate;\n\n    let samples_f32: Vec<f32> = match spec.sample_format {\n        hound::SampleFormat::Int => {\n            let max_val = (1u32 << (spec.bits_per_sample - 1)) as f32;\n            reader\n                .into_samples::<i32>()\n                .map(|s| s.map(|v| v as f32 / max_val))\n                .collect::<std::result::Result<Vec<_>, _>>()\n                .map_err(|e| PolezError::AudioIo(format!(\"WAV decode error: {e}\")))?\n        }\n        hound::SampleFormat::Float => reader\n            .into_samples::<f32>()\n            .collect::<std::result::Result<Vec<_>, _>>()\n            .map_err(|e| PolezError::AudioIo(format!(\"WAV decode error: {e}\")))?,\n    };\n\n    Ok(AudioBuffer::from_interleaved(\n        &samples_f32,\n        channels,\n        sample_rate,\n    ))\n}\n\nfn save_wav(buffer: &AudioBuffer, path: &Path) -> Result<()> {\n    let spec = hound::WavSpec {\n        channels: buffer.num_channels() as u16,\n        sample_rate: buffer.sample_rate,\n        bits_per_sample: 24,\n        sample_format: hound::SampleFormat::Int,\n    };\n\n    let mut writer = hound::WavWriter::create(path, spec)\n        .map_err(|e| PolezError::AudioIo(format!(\"Failed to create WAV: {e}\")))?;\n\n    let max_val = (1u32 << 23) as f32; // 24-bit\n    let interleaved = buffer.to_interleaved();\n    for sample in interleaved {\n        let clamped = sample.clamp(-1.0, 1.0);\n        let int_sample = (clamped * max_val) as i32;\n        writer\n            .write_sample(int_sample)\n            .map_err(|e| PolezError::AudioIo(format!(\"WAV write error: {e}\")))?;\n    }\n\n    writer\n        .finalize()\n        .map_err(|e| PolezError::AudioIo(format!(\"WAV finalize error: {e}\")))?;\n\n    Ok(())\n}\n\n// --- MP3 ---\n\nfn load_mp3(path: &Path) -> Result<AudioBuffer> {\n    use symphonia::core::audio::SampleBuffer;\n    use symphonia::core::codecs::DecoderOptions;\n    use symphonia::core::formats::FormatOptions;\n    use symphonia::core::io::MediaSourceStream;\n    use symphonia::core::meta::MetadataOptions;\n    use symphonia::core::probe::Hint;\n\n    let file = std::fs::File::open(path)\n        .map_err(|e| PolezError::AudioIo(format!(\"Failed to open MP3: {e}\")))?;\n    let mss = MediaSourceStream::new(Box::new(file), Default::default());\n\n    let mut hint = Hint::new();\n    hint.with_extension(\"mp3\");\n\n    let probed = symphonia::default::get_probe()\n        .format(\n            &hint,\n            mss,\n            &FormatOptions::default(),\n            &MetadataOptions::default(),\n        )\n        .map_err(|e| PolezError::AudioIo(format!(\"MP3 probe error: {e}\")))?;\n\n    let mut format_reader = probed.format;\n    let track = format_reader\n        .default_track()\n        .ok_or_else(|| PolezError::AudioIo(\"No audio track found\".to_string()))?;\n\n    let track_id = track.id;\n    let channels = track.codec_params.channels.map(|c| c.count()).unwrap_or(2);\n    let sample_rate = track.codec_params.sample_rate.unwrap_or(44100);\n\n    let mut decoder = symphonia::default::get_codecs()\n        .make(&track.codec_params, &DecoderOptions::default())\n        .map_err(|e| PolezError::AudioIo(format!(\"MP3 decoder error: {e}\")))?;\n\n    let mut all_samples: Vec<f32> = Vec::new();\n\n    loop {\n        let packet = match format_reader.next_packet() {\n            Ok(p) => p,\n            Err(symphonia::core::errors::Error::IoError(ref e))\n                if e.kind() == std::io::ErrorKind::UnexpectedEof =>\n            {\n                break;\n            }\n            Err(_) => break,\n        };\n\n        if packet.track_id() != track_id {\n            continue;\n        }\n\n        let decoded = match decoder.decode(&packet) {\n            Ok(d) => d,\n            Err(_) => continue,\n        };\n\n        let spec = *decoded.spec();\n        let num_frames = decoded.capacity();\n        let mut sample_buf = SampleBuffer::<f32>::new(num_frames as u64, spec);\n        sample_buf.copy_interleaved_ref(decoded);\n        all_samples.extend_from_slice(sample_buf.samples());\n    }\n\n    if all_samples.is_empty() {\n        return Err(PolezError::AudioIo(\"No audio samples decoded\".to_string()));\n    }\n\n    Ok(AudioBuffer::from_interleaved(\n        &all_samples,\n        channels,\n        sample_rate,\n    ))\n}\n\nfn save_mp3(buffer: &AudioBuffer, path: &Path) -> Result<()> {\n    use mp3lame_encoder::{Builder, FlushNoGap, InterleavedPcm};\n\n    let channels = buffer.num_channels();\n    let mut builder = Builder::new()\n        .ok_or_else(|| PolezError::AudioIo(\"Failed to create MP3 encoder\".to_string()))?;\n\n    builder\n        .set_sample_rate(buffer.sample_rate)\n        .map_err(|e| PolezError::AudioIo(format!(\"MP3 encoder config error: {e:?}\")))?;\n\n    builder\n        .set_num_channels(channels as u8)\n        .map_err(|e| PolezError::AudioIo(format!(\"MP3 encoder config error: {e:?}\")))?;\n\n    builder\n        .set_brate(mp3lame_encoder::Bitrate::Kbps320)\n        .map_err(|e| PolezError::AudioIo(format!(\"MP3 encoder config error: {e:?}\")))?;\n\n    builder\n        .set_quality(mp3lame_encoder::Quality::Best)\n        .map_err(|e| PolezError::AudioIo(format!(\"MP3 encoder config error: {e:?}\")))?;\n\n    let mut encoder = builder\n        .build()\n        .map_err(|e| PolezError::AudioIo(format!(\"MP3 encoder build error: {e:?}\")))?;\n\n    // Convert f32 [-1,1] to i16 for LAME\n    let interleaved = buffer.to_interleaved();\n    let pcm_i16: Vec<i16> = interleaved\n        .iter()\n        .map(|&s| (s.clamp(-1.0, 1.0) * 32767.0) as i16)\n        .collect();\n\n    let input = InterleavedPcm(&pcm_i16);\n\n    let mut mp3_out = Vec::with_capacity(pcm_i16.len());\n    encoder\n        .encode_to_vec(input, &mut mp3_out)\n        .map_err(|e| PolezError::AudioIo(format!(\"MP3 encode error: {e:?}\")))?;\n\n    encoder\n        .flush_to_vec::<FlushNoGap>(&mut mp3_out)\n        .map_err(|e| PolezError::AudioIo(format!(\"MP3 flush error: {e:?}\")))?;\n\n    std::fs::write(path, &mp3_out)\n        .map_err(|e| PolezError::AudioIo(format!(\"Failed to write MP3: {e}\")))?;\n\n    Ok(())\n}\n","numLines":251,"startLine":1,"totalLines":251}}}
