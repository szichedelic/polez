r(sr / 2.0);\n   403→    let start_sec = query.start.unwrap_or(0.0).max(0.0);\n   404→    let dur = query.duration.unwrap_or(total_duration - start_sec);\n   405→    let end_sec = (start_sec + dur).min(total_duration);\n   406→\n   407→    let start_idx = (start_sec * sr) as usize;\n   408→    let end_idx = ((end_sec * sr) as usize).min(samples.len());\n   409→\n   410→    if start_idx >= end_idx || end_idx - start_idx < fft_size {\n   411→        return Err((\n   412→            StatusCode::BAD_REQUEST,\n   413→            \"Not enough samples for FFT\".to_string(),\n   414→        ));\n   415→    }\n   416→\n   417→    let slice = &samples[start_idx..end_idx];\n   418→\n   419→    // Build Hann window\n   420→    let window: Vec<f64> = (0..fft_size)\n   421→        .map(|i| {\n   422→            0.5 * (1.0 - (2.0 * std::f64::consts::PI * i as f64 / (fft_size as f64 - 1.0)).cos())\n   423→        })\n   424→        .collect();\n   425→\n   426→    let mut planner = FftPlanner::<f64>::new();\n   427→    let fft = planner.plan_fft_forward(fft_size);\n   428→\n   429→    // Frequency bin indices for the requested range\n   430→    let bin_min = ((freq_min * fft_size as f64 / sr).floor() as usize).min(fft_size / 2);\n   431→    let bin_max = ((freq_max * fft_size as f64 / sr).ceil() as usize).min(fft_size / 2);\n   432→    let num_freq_bins = bin_max - bin_min;\n   433→\n   434→    if num_freq_bins == 0 {\n   435→        return Err((\n   436→            StatusCode::BAD_REQUEST,\n   437→            \"Invalid frequency range\".to_string(),\n   438→        ));\n   439→    }\n   440→\n   441→    let mut magnitudes: Vec<Vec<f64>> = Vec::new();\n   442→\n   443→    let mut pos = 0;\n   444→    while pos + fft_size <= slice.len() {\n   445→        let mut fft_buf: Vec<Complex64> = slice[pos..pos + fft_size]\n   446→            .iter()\n   447→            .enumerate()\n   448→            .map(|(i, &s)| Complex64::new(s as f64 * window[i], 0.0))\n   449→            .collect();\n   450→\n   451→        fft.process(&mut fft_buf);\n   452→"}]},"parent_tool_use_id":null,"session_id":"c9bd7957-c8f2-4e48-8fcc-7059d242854c","uuid":"3e7e65a0-446f-479c-950d-d84b4bbb878e","tool_use_result":{"type":"text","file":{"filePath":"/Users/captain/code/github.com/polez/src/gui/routes.rs","content":"    let mut max_vals = Vec::with_capacity(width);\n\n    for chunk in slice.chunks(chunk_size) {\n        let mut lo = f32::MAX;\n        let mut hi = f32::MIN;\n        for &s in chunk {\n            if s < lo {\n                lo = s;\n            }\n            if s > hi {\n                hi = s;\n            }\n        }\n        min_vals.push(lo);\n        max_vals.push(hi);\n    }\n\n    Ok(Json(WaveformData {\n        min: min_vals,\n        max: max_vals,\n        sample_rate: buffer.sample_rate,\n        duration_secs,\n        channels: buffer.num_channels(),\n    }))\n}\n\n// --- Spectrogram endpoint ---\n\n#[derive(Deserialize)]\nstruct SpectrogramQuery {\n    fft_size: Option<usize>,\n    freq_min: Option<f64>,\n    freq_max: Option<f64>,\n    start: Option<f64>,\n    duration: Option<f64>,\n}\n\nasync fn get_spectrogram(\n    State(state): State<SharedState>,\n    Query(query): Query<SpectrogramQuery>,\n) -> Result<Json<SpectrogramData>, (StatusCode, String)> {\n    let state = state.read().await;\n    let buffer = state\n        .buffer\n        .as_ref()\n        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n\n    let samples = buffer.to_mono_samples();\n    let sr = buffer.sample_rate as f64;\n    let total_duration = samples.len() as f64 / sr;\n\n    let fft_size = query.fft_size.unwrap_or(2048);\n    let hop = fft_size / 4;\n    let freq_min = query.freq_min.unwrap_or(0.0);\n    let freq_max = query.freq_max.unwrap_or(sr / 2.0);\n    let start_sec = query.start.unwrap_or(0.0).max(0.0);\n    let dur = query.duration.unwrap_or(total_duration - start_sec);\n    let end_sec = (start_sec + dur).min(total_duration);\n\n    let start_idx = (start_sec * sr) as usize;\n    let end_idx = ((end_sec * sr) as usize).min(samples.len());\n\n    if start_idx >= end_idx || end_idx - start_idx < fft_size {\n        return Err((\n            StatusCode::BAD_REQUEST,\n            \"Not enough samples for FFT\".to_string(),\n        ));\n    }\n\n    let slice = &samples[start_idx..end_idx];\n\n    // Build Hann window\n    let window: Vec<f64> = (0..fft_size)\n        .map(|i| {\n            0.5 * (1.0 - (2.0 * std::f64::consts::PI * i as f64 / (fft_size as f64 - 1.0)).cos())\n        })\n        .collect();\n\n    let mut planner = FftPlanner::<f64>::new();\n    let fft = planner.plan_fft_forward(fft_size);\n\n    // Frequency bin indices for the requested range\n    let bin_min = ((freq_min * fft_size as f64 / sr).floor() as usize).min(fft_size / 2);\n    let bin_max = ((freq_max * fft_size as f64 / sr).ceil() as usize).min(fft_size / 2);\n    let num_freq_bins = bin_max - bin_min;\n\n    if num_freq_bins == 0 {\n        return Err((\n            StatusCode::BAD_REQUEST,\n            \"Invalid frequency range\".to_string(),\n        ));\n    }\n\n    let mut magnitudes: Vec<Vec<f64>> = Vec::new();\n\n    let mut pos = 0;\n    while pos + fft_size <= slice.len() {\n        let mut fft_buf: Vec<Complex64> = slice[pos..pos + fft_size]\n            .iter()\n            .enumerate()\n            .map(|(i, &s)| Complex64::new(s as f64 * window[i], 0.0))\n            .collect();\n\n        fft.process(&mut fft_buf);\n","numLines":105,"startLine":348,"totalLines":821}}}
