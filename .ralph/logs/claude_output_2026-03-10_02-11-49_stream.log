{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014CZL5iKAhywFzQ9cPuhGfj","type":"tool_result","content":"     1→use axum::extract::DefaultBodyLimit;\n     2→use axum::{\n     3→    extract::{Multipart, Query, State},\n     4→    http::{header, StatusCode},\n     5→    response::{IntoResponse, Response},\n     6→    routing::{get, post},\n     7→    Json, Router,\n     8→};\n     9→use rustfft::num_complex::Complex64;\n    10→use rustfft::FftPlanner;\n    11→use serde::Deserialize;\n    12→use std::io::Write;\n    13→use std::path::Path;\n    14→use tower_http::cors::{Any, CorsLayer};\n    15→\n    16→use crate::config::{defaults::default_config, AdvancedFlags};\n    17→use crate::detection::{MetadataScanner, PolezDetector, StatisticalAnalyzer, WatermarkDetector};\n    18→use crate::sanitization::pipeline::SanitizationMode;\n    19→use crate::sanitization::SanitizationPipeline;\n    20→\n    21→use super::types::{\n    22→    AllAnalysisResult, BitPlaneData, CleanRequest, CleanResponse, FileInfo, PlaneSummary,\n    23→    SpectrogramData, WaveformData,\n    24→};\n    25→use super::SharedState;\n    26→\n    27→pub fn create_router(state: SharedState) -> Router {\n    28→    let cors = CorsLayer::new()\n    29→        .allow_origin(Any)\n    30→        .allow_methods(Any)\n    31→        .allow_headers(Any);\n    32→\n    33→    Router::new()\n    34→        .route(\"/api/health\", get(health))\n    35→        .route(\"/api/load\", post(load_file))\n    36→        .route(\"/api/upload\", post(upload_file))\n    37→        .route(\"/api/waveform\", get(get_waveform))\n    38→        .route(\"/api/spectrogram\", get(get_spectrogram))\n    39→        .route(\"/api/bitplane\", get(get_bitplane))\n    40→        .route(\"/api/audio\", get(serve_audio))\n    41→        .route(\"/api/analyze/watermark\", post(analyze_watermark))\n    42→        .route(\"/api/analyze/polez\", post(analyze_polez))\n    43→        .route(\"/api/analyze/statistical\", post(analyze_statistical))\n    44→        .route(\"/api/analyze/metadata\", post(analyze_metadata))\n    45→        .route(\"/api/analyze/all\", post(analyze_all))\n    46→        .route(\"/api/clean\", post(clean_file))\n    47→        .route(\"/api/audio/cleaned\", get(serve_cleaned_audio))\n    48→        .route(\"/api/waveform/cleaned\", get(get_cleaned_waveform))\n    49→        .route(\"/api/save\", post(save_cleaned_file))\n    50→        .fallback(get(static_handler))\n    51→        .layer(DefaultBodyLimit::max(500 * 1024 * 1024)) // 500MB\n    52→        .layer(cors)\n    53→        .with_state(state)\n    54→}\n    55→\n    56→async fn static_handler(uri: axum::http::Uri) -> Response {\n    57→    let path = uri.path().trim_start_matches('/');\n    58→    let path = if path.is_empty() { \"index.html\" } else { path };\n    59→\n    60→    match super::Assets::get(path) {\n    61→        Some(content) => {\n    62→            let mime = mime_guess::from_path(path).first_or_octet_stream();\n    63→            (\n    64→                [(header::CONTENT_TYPE, mime.as_ref())],\n    65→                content.data.to_vec(),\n    66→            )\n    67→                .into_response()\n    68→        }\n    69→        None => {\n    70→            // SPA fallback: serve index.html for all non-API routes\n    71→            match super::Assets::get(\"index.html\") {\n    72→                Some(content) => {\n    73→                    ([(header::CONTENT_TYPE, \"text/html\")], content.data.to_vec()).into_response()\n    74→                }\n    75→                None => (StatusCode::NOT_FOUND, \"Not found\").into_response(),\n    76→            }\n    77→        }\n    78→    }\n    79→}\n    80→\n    81→async fn health() -> &'static str {\n    82→    \"ok\"\n    83→}\n    84→\n    85→#[derive(Deserialize)]\n    86→struct LoadRequest {\n    87→    path: String,\n    88→}\n    89→\n    90→async fn load_file(\n    91→    State(state): State<SharedState>,\n    92→    Json(req): Json<LoadRequest>,\n    93→) -> Result<Json<FileInfo>, (StatusCode, String)> {\n    94→    let path = Path::new(&req.path);\n    95→\n    96→    if !path.exists() {\n    97→        return Err((\n    98→            StatusCode::NOT_FOUND,\n    99→            format!(\"File not found: {}\", req.path),\n   100→        ));\n   101→    }\n   102→\n   103→    let (buffer, format) = crate::audio::load_audio(path).map_err(|e| {\n   104→        (\n   105→            StatusCode::INTERNAL_SERVER_ERROR,\n   106→            format!(\"Load error: {e}\"),\n   107→        )\n   108→    })?;\n   109→\n   110→    let info = FileInfo {\n   111→        file_path: req.path.clone(),\n   112→        format: format.to_string(),\n   113→        duration_secs: buffer.duration_secs(),\n   114→        sample_rate: buffer.sample_rate,\n   115→        channels: buffer.num_channels(),\n   116→    };\n   117→\n   118→    let mut state = state.write().await;\n   119→    state.file_path = Some(req.path);\n   120→    state.format = Some(info.format.clone());\n   121→    state.buffer = Some(buffer);\n   122→\n   123→    Ok(Json(info))\n   124→}\n   125→\n   126→async fn upload_file(\n   127→    State(state): State<SharedState>,\n   128→    mut multipart: Multipart,\n   129→) -> Result<Json<FileInfo>, (StatusCode, String)> {\n   130→    let field = multipart\n   131→        .next_field()\n   132→        .await\n   133→        .map_err(|e| (StatusCode::BAD_REQUEST, format!(\"Multipart error: {e}\")))?\n   134→        .ok_or((StatusCode::BAD_REQUEST, \"No file field found\".to_string()))?;\n   135→\n   136→    let file_name = field.file_name().unwrap_or(\"upload.wav\").to_string();\n   137→\n   138→    let ext = Path::new(&file_name)\n   139→        .extension()\n   140→        .and_then(|e| e.to_str())\n   141→        .unwrap_or(\"wav\");\n   142→\n   143→    let mut tmp = tempfile::Builder::new()\n   144→        .suffix(&format!(\".{ext}\"))\n   145→        .tempfile()\n   146→        .map_err(|e| {\n   147→            (\n   148→                StatusCode::INTERNAL_SERVER_ERROR,\n   149→                format!(\"Temp file error: {e}\"),\n   150→            )\n   151→        })?;\n   152→\n   153→    let bytes = field\n   154→        .bytes()\n   155→        .await\n   156→        .map_err(|e| (StatusCode::BAD_REQUEST, format!(\"Read error: {e}\")))?;\n   157→\n   158→    tmp.write_all(&bytes).map_err(|e| {\n   159→        (\n   160→            StatusCode::INTERNAL_SERVER_ERROR,\n   161→            format!(\"Write error: {e}\"),\n   162→        )\n   163→    })?;\n   164→\n   165→    let tmp_path = tmp.into_temp_path();\n   166→    let path_str = tmp_path.to_string_lossy().to_string();\n   167→\n   168→    // Leak the temp path so the file persists for the session\n   169→    let leaked: &'static std::path::Path = Box::leak(tmp_path.to_path_buf().into_boxed_path());\n   170→    std::mem::forget(tmp_path);\n   171→    let _ = leaked;\n   172→\n   173→    let (buffer, format) = crate::audio::load_audio(Path::new(&path_str)).map_err(|e| {\n   174→        (\n   175→            StatusCode::INTERNAL_SERVER_ERROR,\n   176→            format!(\"Load error: {e}\"),\n   177→        )\n   178→    })?;\n   179→\n   180→    let info = FileInfo {\n   181→        file_path: file_name,\n   182→        format: format.to_string(),\n   183→        duration_secs: buffer.duration_secs(),\n   184→        sample_rate: buffer.sample_rate,\n   185→        channels: buffer.num_channels(),\n   186→    };\n   187→\n   188→    let mut app_state = state.write().await;\n   189→    app_state.file_path = Some(path_str);\n   190→    app_state.format = Some(info.format.clone());\n   191→    app_state.buffer = Some(buffer);\n   192→\n   193→    Ok(Json(info))\n   194→}\n   195→\n   196→// --- Analysis endpoints ---\n   197→\n   198→async fn analyze_watermark(\n   199→    State(state): State<SharedState>,\n   200→) -> Result<Json<serde_json::Value>, (StatusCode, String)> {\n   201→    let state = state.read().await;\n   202→    let buffer = state\n   203→        .buffer\n   204→        .as_ref()\n   205→        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   206→    let result = WatermarkDetector::detect_all(buffer);\n   207→    Ok(Json(serde_json::to_value(result).unwrap()))\n   208→}\n   209→\n   210→async fn analyze_polez(\n   211→    State(state): State<SharedState>,\n   212→) -> Result<Json<serde_json::Value>, (StatusCode, String)> {\n   213→    let state = state.read().await;\n   214→    let buffer = state\n   215→        .buffer\n   216→        .as_ref()\n   217→        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   218→    let result = PolezDetector::detect(buffer);\n   219→    Ok(Json(serde_json::to_value(result).unwrap()))\n   220→}\n   221→\n   222→async fn analyze_statistical(\n   223→    State(state): State<SharedState>,\n   224→) -> Result<Json<serde_json::Value>, (StatusCode, String)> {\n   225→    let state = state.read().await;\n   226→    let buffer = state\n   227→        .buffer\n   228→        .as_ref()\n   229→        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   230→    let result = StatisticalAnalyzer::analyze(buffer);\n   231→    Ok(Json(serde_json::to_value(result).unwrap()))\n   232→}\n   233→\n   234→async fn analyze_metadata(\n   235→    State(state): State<SharedState>,\n   236→) -> Result<Json<serde_json::Value>, (StatusCode, String)> {\n   237→    let state = state.read().await;\n   238→    let file_path = state\n   239→        .file_path\n   240→        .as_ref()\n   241→        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   242→    let result = MetadataScanner::scan(Path::new(file_path)).map_err(|e| {\n   243→        (\n   244→            StatusCode::INTERNAL_SERVER_ERROR,\n   245→            format!(\"Scan error: {e}\"),\n   246→        )\n   247→    })?;\n   248→    Ok(Json(serde_json::to_value(result).unwrap()))\n   249→}\n   250→\n   251→async fn analyze_all(\n   252→    State(state): State<SharedState>,\n   253→) -> Result<Json<AllAnalysisResult>, (StatusCode, String)> {\n   254→    let state = state.read().await;\n   255→    let buffer = state\n   256→        .buffer\n   257→        .as_ref()\n   258→        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   259→    let file_path = state\n   260→        .file_path\n   261→        .as_ref()\n   262→        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   263→\n   264→    let watermark = WatermarkDetector::detect_all(buffer);\n   265→    let polez = PolezDetector::detect(buffer);\n   266→    let statistical = StatisticalAnalyzer::analyze(buffer);\n   267→    let metadata = MetadataScanner::scan(Path::new(file_path)).map_err(|e| {\n   268→        (\n   269→            StatusCode::INTERNAL_SERVER_ERROR,\n   270→            format!(\"Scan error: {e}\"),\n   271→        )\n   272→    })?;\n   273→\n   274→    Ok(Json(AllAnalysisResult {\n   275→        watermark,\n   276→        polez,\n   277→        statistical,\n   278→        metadata,\n   279→    }))\n   280→}\n   281→\n   282→// --- Waveform endpoint ---\n   283→\n   284→#[derive(Deserialize)]\n   285→struct WaveformQuery {\n   286→    width: Option<usize>,\n   287→    start: Option<f64>,\n   288→    end: Option<f64>,\n   289→}\n   290→\n   291→async fn get_waveform(\n   292→    State(state): State<SharedState>,\n   293→    Query(query): Query<WaveformQuery>,\n   294→) -> Result<Json<WaveformData>, (StatusCode, String)> {\n   295→    let state = state.read().await;\n   296→    let buffer = state\n   297→        .buffer\n   298→        .as_ref()\n   299→        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   300→\n   301→    let samples = buffer.to_mono_samples();\n   302→    let sr = buffer.sample_rate as f64;\n   303→    let total_samples = samples.len();\n   304→    let duration_secs = total_samples as f64 / sr;\n   305→\n   306→    let start_sec = query.start.unwrap_or(0.0).max(0.0);\n   307→    let end_sec = query.end.unwrap_or(duration_secs).min(duration_secs);\n   308→    let start_idx = (start_sec * sr) as usize;\n   309→    let end_idx = ((end_sec * sr) as usize).min(total_samples);\n   310→\n   311→    if start_idx >= end_idx {\n   312→        return Err((StatusCode::BAD_REQUEST, \"Invalid time range\".to_string()));\n   313→    }\n   314→\n   315→    let slice = &samples[start_idx..end_idx];\n   316→    let width = query.width.unwrap_or(1024).max(1);\n   317→    let chunk_size = (slice.len() / width).max(1);\n   318→\n   319→    let mut min_vals = Vec::with_capacity(width);\n   320→    let mut max_vals = Vec::with_capacity(width);\n   321→\n   322→    for chunk in slice.chunks(chunk_size) {\n   323→        let mut lo = f32::MAX;\n   324→        let mut hi = f32::MIN;\n   325→        for &s in chunk {\n   326→            if s < lo {\n   327→                lo = s;\n   328→            }\n   329→            if s > hi {\n   330→                hi = s;\n   331→            }\n   332→        }\n   333→        min_vals.push(lo);\n   334→        max_vals.push(hi);\n   335→    }\n   336→\n   337→    Ok(Json(WaveformData {\n   338→        min: min_vals,\n   339→        max: max_vals,\n   340→        sample_rate: buffer.sample_rate,\n   341→        duration_secs,\n   342→        channels: buffer.num_channels(),\n   343→    }))\n   344→}\n   345→\n   346→// --- Spectrogram endpoint ---\n   347→\n   348→#[derive(Deserialize)]\n   349→struct SpectrogramQuery {\n   350→    fft_size: Option<usize>,\n   351→    freq_min: Option<f64>,\n   352→    freq_max: Option<f64>,\n   353→    start: Option<f64>,\n   354→    duration: Option<f64>,\n   355→}\n   356→\n   357→async fn get_spectrogram(\n   358→    State(state): State<SharedState>,\n   359→    Query(query): Query<SpectrogramQuery>,\n   360→) -> Result<Json<SpectrogramData>, (StatusCode, String)> {\n   361→    let state = state.read().await;\n   362→    let buffer = state\n   363→        .buffer\n   364→        .as_ref()\n   365→        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   366→\n   367→    let samples = buffer.to_mono_samples();\n   368→    let sr = buffer.sample_rate as f64;\n   369→    let total_duration = samples.len() as f64 / sr;\n   370→\n   371→    let fft_size = query.fft_size.unwrap_or(2048);\n   372→    let hop = fft_size / 4;\n   373→    let freq_min = query.freq_min.unwrap_or(0.0);\n   374→    let freq_max = query.freq_max.unwrap_or(sr / 2.0);\n   375→    let start_sec = query.start.unwrap_or(0.0).max(0.0);\n   376→    let dur = query.duration.unwrap_or(total_duration - start_sec);\n   377→    let end_sec = (start_sec + dur).min(total_duration);\n   378→\n   379→    let start_idx = (start_sec * sr) as usize;\n   380→    let end_idx = ((end_sec * sr) as usize).min(samples.len());\n   381→\n   382→    if start_idx >= end_idx || end_idx - start_idx < fft_size {\n   383→        return Err((\n   384→            StatusCode::BAD_REQUEST,\n   385→            \"Not enough samples for FFT\".to_string(),\n   386→        ));\n   387→    }\n   388→\n   389→    let slice = &samples[start_idx..end_idx];\n   390→\n   391→    // Build Hann window\n   392→    let window: Vec<f64> = (0..fft_size)\n   393→        .map(|i| {\n   394→            0.5 * (1.0 - (2.0 * std::f64::consts::PI * i as f64 / (fft_size as f64 - 1.0)).cos())\n   395→        })\n   396→        .collect();\n   397→\n   398→    let mut planner = FftPlanner::<f64>::new();\n   399→    let fft = planner.plan_fft_forward(fft_size);\n   400→\n   401→    // Frequency bin indices for the requested range\n   402→    let bin_min = ((freq_min * fft_size as f64 / sr).floor() as usize).min(fft_size / 2);\n   403→    let bin_max = ((freq_max * fft_size as f64 / sr).ceil() as usize).min(fft_size / 2);\n   404→    let num_freq_bins = bin_max - bin_min;\n   405→\n   406→    if num_freq_bins == 0 {\n   407→        return Err((\n   408→            StatusCode::BAD_REQUEST,\n   409→            \"Invalid frequency range\".to_string(),\n   410→        ));\n   411→    }\n   412→\n   413→    let mut magnitudes: Vec<Vec<f64>> = Vec::new();\n   414→\n   415→    let mut pos = 0;\n   416→    while pos + fft_size <= slice.len() {\n   417→        let mut fft_buf: Vec<Complex64> = slice[pos..pos + fft_size]\n   418→            .iter()\n   419→            .enumerate()\n   420→            .map(|(i, &s)| Complex64::new(s as f64 * window[i], 0.0))\n   421→            .collect();\n   422→\n   423→        fft.process(&mut fft_buf);\n   424→\n   425→        let frame: Vec<f64> = (bin_min..bin_max)\n   426→            .map(|bin| {\n   427→                let mag = fft_buf[bin].norm();\n   428→                // Convert to dB, floor at -120 dB\n   429→                let db = 20.0 * mag.max(1e-12).log10();\n   430→                db.max(-120.0)\n   431→            })\n   432→            .collect();\n   433→\n   434→        magnitudes.push(frame);\n   435→        pos += hop;\n   436→    }\n   437→\n   438→    let num_time_frames = magnitudes.len();\n   439→\n   440→    Ok(Json(SpectrogramData {\n   441→        magnitudes,\n   442→        freq_min,\n   443→        freq_max,\n   444→        time_start: start_sec,\n   445→        time_end: end_sec,\n   446→        num_freq_bins,\n   447→        num_time_frames,\n   448→    }))\n   449→}\n   450→\n   451→// --- Bitplane endpoint ---\n   452→\n   453→async fn get_bitplane(\n   454→    State(state): State<SharedState>,\n   455→) -> Result<Json<BitPlaneData>, (StatusCode, String)> {\n   456→    let state = state.read().await;\n   457→    let buffer = state\n   458→        .buffer\n   459→        .as_ref()\n   460→        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   461→\n   462→    let samples = buffer.to_mono_samples();\n   463→    let total = samples.len() as f64;\n   464→\n   465→    let planes: Vec<PlaneSummary> = (0..8u8)\n   466→        .map(|bit| {\n   467→            let mut ones = 0u64;\n   468→            for &s in &samples {\n   469→                let val = (s * 32767.0) as i16;\n   470→                if (val >> bit) & 1 == 1 {\n   471→                    ones += 1;\n   472→                }\n   473→            }\n   474→            let ones_ratio = ones as f64 / total;\n   475→            let bias = (ones_ratio - 0.5).abs();\n   476→            PlaneSummary {\n   477→                bit,\n   478→                ones_ratio,\n   479→                bias,\n   480→            }\n   481→        })\n   482→        .collect();\n   483→\n   484→    Ok(Json(BitPlaneData { planes }))\n   485→}\n   486→\n   487→// --- Audio serving endpoint ---\n   488→\n   489→async fn serve_audio(State(state): State<SharedState>) -> Result<Response, (StatusCode, String)> {\n   490→    let state = state.read().await;\n   491→    let file_path = state\n   492→        .file_path\n   493→        .as_ref()\n   494→        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   495→\n   496→    let bytes = std::fs::read(file_path).map_err(|e| {\n   497→        (\n   498→            StatusCode::INTERNAL_SERVER_ERROR,\n   499→            format!(\"Read error: {e}\"),\n   500→        )\n   501→    })?;\n   502→\n   503→    let content_type = if file_path.ends_with(\".mp3\") {\n   504→        \"audio/mpeg\"\n   505→    } else {\n   506→        \"audio/wav\"\n   507→    };\n   508→\n   509→    Ok(([(header::CONTENT_TYPE, content_type)], bytes).into_response())\n   510→}\n   511→\n   512→// --- Clean endpoint ---\n   513→\n   514→async fn clean_file(\n   515→    State(state): State<SharedState>,\n   516→    Json(req): Json<CleanRequest>,\n   517→) -> Result<Json<CleanResponse>, (StatusCode, String)> {\n   518→    let mode = match req.mode.as_deref().unwrap_or(\"standard\") {\n   519→        \"fast\" => SanitizationMode::Fast,\n   520→        \"standard\" => SanitizationMode::Standard,\n   521→        \"preserving\" => SanitizationMode::Preserving,\n   522→        \"aggressive\" => SanitizationMode::Aggressive,\n   523→        other => return Err((StatusCode::BAD_REQUEST, format!(\"Unknown mode: {other}\"))),\n   524→    };\n   525→\n   526→    // Read source info from state\n   527→    let (file_path, format_str) = {\n   528→        let s = state.read().await;\n   529→        let fp = s\n   530→            .file_path\n   531→            .clone()\n   532→            .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   533→        let fmt = s\n   534→            .format\n   535→            .clone()\n   536→            .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   537→        (fp, fmt)\n   538→    };\n   539→\n   540→    let ext = if format_str == \"mp3\" { \"mp3\" } else { \"wav\" };\n   541→\n   542→    // Create temp output file\n   543→    let tmp = tempfile::Builder::new()\n   544→        .suffix(&format!(\"_cleaned.{ext}\"))\n   545→        .tempfile()\n   546→        .map_err(|e| {\n   547→            (\n   548→                StatusCode::INTERNAL_SERVER_ERROR,\n   549→                format!(\"Temp file error: {e}\"),\n   550→            )\n   551→        })?;\n   552→    let tmp_path = tmp.into_temp_path();\n   553→    let output_path = tmp_path.to_path_buf();\n   554→    // Leak so it persists for the session\n   555→    std::mem::forget(tmp_path);\n   556→\n   557→    let input_path = std::path::PathBuf::from(&file_path);\n   558→    let out = output_path.clone();\n   559→\n   560→    // Run sanitization in blocking thread (CPU-bound)\n   561→    let san_result = tokio::task::spawn_blocking(move || {\n   562→        let cfg = default_config();\n   563→        let pipeline = SanitizationPipeline::new(\n   564→            mode,\n   565→            false,\n   566→            AdvancedFlags::default(),\n   567→            cfg.fingerprint_removal,\n   568→            None,\n   569→        );\n   570→        pipeline.run(&input_path, &out)\n   571→    })\n   572→    .await\n   573→    .map_err(|e| {\n   574→        (\n   575→            StatusCode::INTERNAL_SERVER_ERROR,\n   576→            format!(\"Task join error: {e}\"),\n   577→        )\n   578→    })?\n   579→    .map_err(|e| {\n   580→        (\n   581→            StatusCode::INTERNAL_SERVER_ERROR,\n   582→            format!(\"Sanitization error: {e}\"),\n   583→        )\n   584→    })?;\n   585→\n   586→    // Load cleaned audio\n   587→    let (cleaned_buffer, cleaned_fmt) = crate::audio::load_audio(&output_path).map_err(|e| {\n   588→        (\n   589→            StatusCode::INTERNAL_SERVER_ERROR,\n   590→            format!(\"Load cleaned error: {e}\"),\n   591→        )\n   592→    })?;\n   593→\n   594→    // Run detection on original (before)\n   595→    let before = {\n   596→        let s = state.read().await;\n   597→        let buf = s.buffer.as_ref().unwrap();\n   598→        let fp = s.file_path.as_ref().unwrap();\n   599→        let watermark = WatermarkDetector::detect_all(buf);\n   600→        let polez = PolezDetector::detect(buf);\n   601→        let statistical = StatisticalAnalyzer::analyze(buf);\n   602→        let metadata = MetadataScanner::scan(Path::new(fp)).map_err(|e| {\n   603→            (\n   604→                StatusCode::INTERNAL_SERVER_ERROR,\n   605→                format!(\"Scan error: {e}\"),\n   606→            )\n   607→        })?;\n   608→        AllAnalysisResult {\n   609→            watermark,\n   610→            polez,\n   611→            statistical,\n   612→            metadata,\n   613→        }\n   614→    };\n   615→\n   616→    // Run detection on cleaned (after)\n   617→    let output_path_str = output_path.to_string_lossy().to_string();\n   618→    let watermark = WatermarkDetector::detect_all(&cleaned_buffer);\n   619→    let polez_result = PolezDetector::detect(&cleaned_buffer);\n   620→    let statistical = StatisticalAnalyzer::analyze(&cleaned_buffer);\n   621→    let metadata = MetadataScanner::scan(&output_path).map_err(|e| {\n   622→        (\n   623→            StatusCode::INTERNAL_SERVER_ERROR,\n   624→            format!(\"Scan error: {e}\"),\n   625→        )\n   626→    })?;\n   627→    let after = AllAnalysisResult {\n   628→        watermark,\n   629→        polez: polez_result,\n   630→        statistical,\n   631→        metadata,\n   632→    };\n   633→\n   634→    // Store cleaned state\n   635→    {\n   636→        let mut s = state.write().await;\n   637→        s.cleaned_buffer = Some(cleaned_buffer);\n   638→        s.cleaned_file_path = Some(output_path_str);\n   639→        s.cleaned_format = Some(cleaned_fmt.to_string());\n   640→    }\n   641→\n   642→    Ok(Json(CleanResponse {\n   643→        success: san_result.success,\n   644→        metadata_removed: san_result.metadata_removed,\n   645→        patterns_found: san_result.patterns_found,\n   646→        patterns_suppressed: san_result.patterns_suppressed,\n   647→        quality_loss: san_result.quality_loss,\n   648→        processing_time: san_result.processing_time,\n   649→        before,\n   650→        after,\n   651→    }))\n   652→}\n   653→\n   654→// --- Serve cleaned audio ---\n   655→\n   656→async fn serve_cleaned_audio(\n   657→    State(state): State<SharedState>,\n   658→) -> Result<Response, (StatusCode, String)> {\n   659→    let state = state.read().await;\n   660→    let file_path = state.cleaned_file_path.as_ref().ok_or((\n   661→        StatusCode::BAD_REQUEST,\n   662→        \"No cleaned file available\".to_string(),\n   663→    ))?;\n   664→\n   665→    let bytes = std::fs::read(file_path).map_err(|e| {\n   666→        (\n   667→            StatusCode::INTERNAL_SERVER_ERROR,\n   668→            format!(\"Read error: {e}\"),\n   669→        )\n   670→    })?;\n   671→\n   672→    let content_type = if file_path.ends_with(\".mp3\") {\n   673→        \"audio/mpeg\"\n   674→    } else {\n   675→        \"audio/wav\"\n   676→    };\n   677→\n   678→    Ok(([(header::CONTENT_TYPE, content_type)], bytes).into_response())\n   679→}\n   680→\n   681→// --- Cleaned waveform endpoint ---\n   682→\n   683→async fn get_cleaned_waveform(\n   684→    State(state): State<SharedState>,\n   685→    Query(query): Query<WaveformQuery>,\n   686→) -> Result<Json<WaveformData>, (StatusCode, String)> {\n   687→    let state = state.read().await;\n   688→    let buffer = state.cleaned_buffer.as_ref().ok_or((\n   689→        StatusCode::BAD_REQUEST,\n   690→        \"No cleaned file available\".to_string(),\n   691→    ))?;\n   692→\n   693→    let samples = buffer.to_mono_samples();\n   694→    let sr = buffer.sample_rate as f64;\n   695→    let total_samples = samples.len();\n   696→    let duration_secs = total_samples as f64 / sr;\n   697→\n   698→    let start_sec = query.start.unwrap_or(0.0).max(0.0);\n   699→    let end_sec = query.end.unwrap_or(duration_secs).min(duration_secs);\n   700→    let start_idx = (start_sec * sr) as usize;\n   701→    let end_idx = ((end_sec * sr) as usize).min(total_samples);\n   702→\n   703→    if start_idx >= end_idx {\n   704→        return Err((StatusCode::BAD_REQUEST, \"Invalid time range\".to_string()));\n   705→    }\n   706→\n   707→    let slice = &samples[start_idx..end_idx];\n   708→    let width = query.width.unwrap_or(1024).max(1);\n   709→    let chunk_size = (slice.len() / width).max(1);\n   710→\n   711→    let mut min_vals = Vec::with_capacity(width);\n   712→    let mut max_vals = Vec::with_capacity(width);\n   713→\n   714→    for chunk in slice.chunks(chunk_size) {\n   715→        let mut lo = f32::MAX;\n   716→        let mut hi = f32::MIN;\n   717→        for &s in chunk {\n   718→            if s < lo {\n   719→                lo = s;\n   720→            }\n   721→            if s > hi {\n   722→                hi = s;\n   723→            }\n   724→        }\n   725→        min_vals.push(lo);\n   726→        max_vals.push(hi);\n   727→    }\n   728→\n   729→    Ok(Json(WaveformData {\n   730→        min: min_vals,\n   731→        max: max_vals,\n   732→        sample_rate: buffer.sample_rate,\n   733→        duration_secs,\n   734→        channels: buffer.num_channels(),\n   735→    }))\n   736→}\n   737→\n   738→// --- Save/download cleaned file ---\n   739→\n   740→async fn save_cleaned_file(\n   741→    State(state): State<SharedState>,\n   742→) -> Result<Response, (StatusCode, String)> {\n   743→    let state = state.read().await;\n   744→    let file_path = state.cleaned_file_path.as_ref().ok_or((\n   745→        StatusCode::BAD_REQUEST,\n   746→        \"No cleaned file available\".to_string(),\n   747→    ))?;\n   748→\n   749→    let bytes = std::fs::read(file_path).map_err(|e| {\n   750→        (\n   751→            StatusCode::INTERNAL_SERVER_ERROR,\n   752→            format!(\"Read error: {e}\"),\n   753→        )\n   754→    })?;\n   755→\n   756→    let ext = if file_path.ends_with(\".mp3\") {\n   757→        \"mp3\"\n   758→    } else {\n   759→        \"wav\"\n   760→    };\n   761→\n   762→    let filename = format!(\"cleaned_output.{ext}\");\n   763→    let content_type = if ext == \"mp3\" {\n   764→        \"audio/mpeg\"\n   765→    } else {\n   766→        \"audio/wav\"\n   767→    };\n   768→\n   769→    Ok((\n   770→        [\n   771→            (header::CONTENT_TYPE, content_type),\n   772→            (\n   773→                header::CONTENT_DISPOSITION,\n   774→                &format!(\"attachment; filename=\\\"{filename}\\\"\"),\n   775→            ),\n   776→        ],\n   777→        bytes,\n   778→    )\n   779→        .into_response())\n   780→}\n   781→"}]},"parent_tool_use_id":null,"session_id":"c9bd7957-c8f2-4e48-8fcc-7059d242854c","uuid":"d158fbe9-9009-49bf-b32d-66ca54523463","tool_use_result":{"type":"text","file":{"filePath":"/Users/captain/code/github.com/polez/src/gui/routes.rs","content":"use axum::extract::DefaultBodyLimit;\nuse axum::{\n    extract::{Multipart, Query, State},\n    http::{header, StatusCode},\n    response::{IntoResponse, Response},\n    routing::{get, post},\n    Json, Router,\n};\nuse rustfft::num_complex::Complex64;\nuse rustfft::FftPlanner;\nuse serde::Deserialize;\nuse std::io::Write;\nuse std::path::Path;\nuse tower_http::cors::{Any, CorsLayer};\n\nuse crate::config::{defaults::default_config, AdvancedFlags};\nuse crate::detection::{MetadataScanner, PolezDetector, StatisticalAnalyzer, WatermarkDetector};\nuse crate::sanitization::pipeline::SanitizationMode;\nuse crate::sanitization::SanitizationPipeline;\n\nuse super::types::{\n    AllAnalysisResult, BitPlaneData, CleanRequest, CleanResponse, FileInfo, PlaneSummary,\n    SpectrogramData, WaveformData,\n};\nuse super::SharedState;\n\npub fn create_router(state: SharedState) -> Router {\n    let cors = CorsLayer::new()\n        .allow_origin(Any)\n        .allow_methods(Any)\n        .allow_headers(Any);\n\n    Router::new()\n        .route(\"/api/health\", get(health))\n        .route(\"/api/load\", post(load_file))\n        .route(\"/api/upload\", post(upload_file))\n        .route(\"/api/waveform\", get(get_waveform))\n        .route(\"/api/spectrogram\", get(get_spectrogram))\n        .route(\"/api/bitplane\", get(get_bitplane))\n        .route(\"/api/audio\", get(serve_audio))\n        .route(\"/api/analyze/watermark\", post(analyze_watermark))\n        .route(\"/api/analyze/polez\", post(analyze_polez))\n        .route(\"/api/analyze/statistical\", post(analyze_statistical))\n        .route(\"/api/analyze/metadata\", post(analyze_metadata))\n        .route(\"/api/analyze/all\", post(analyze_all))\n        .route(\"/api/clean\", post(clean_file))\n        .route(\"/api/audio/cleaned\", get(serve_cleaned_audio))\n        .route(\"/api/waveform/cleaned\", get(get_cleaned_waveform))\n        .route(\"/api/save\", post(save_cleaned_file))\n        .fallback(get(static_handler))\n        .layer(DefaultBodyLimit::max(500 * 1024 * 1024)) // 500MB\n        .layer(cors)\n        .with_state(state)\n}\n\nasync fn static_handler(uri: axum::http::Uri) -> Response {\n    let path = uri.path().trim_start_matches('/');\n    let path = if path.is_empty() { \"index.html\" } else { path };\n\n    match super::Assets::get(path) {\n        Some(content) => {\n            let mime = mime_guess::from_path(path).first_or_octet_stream();\n            (\n                [(header::CONTENT_TYPE, mime.as_ref())],\n                content.data.to_vec(),\n            )\n                .into_response()\n        }\n        None => {\n            // SPA fallback: serve index.html for all non-API routes\n            match super::Assets::get(\"index.html\") {\n                Some(content) => {\n                    ([(header::CONTENT_TYPE, \"text/html\")], content.data.to_vec()).into_response()\n                }\n                None => (StatusCode::NOT_FOUND, \"Not found\").into_response(),\n            }\n        }\n    }\n}\n\nasync fn health() -> &'static str {\n    \"ok\"\n}\n\n#[derive(Deserialize)]\nstruct LoadRequest {\n    path: String,\n}\n\nasync fn load_file(\n    State(state): State<SharedState>,\n    Json(req): Json<LoadRequest>,\n) -> Result<Json<FileInfo>, (StatusCode, String)> {\n    let path = Path::new(&req.path);\n\n    if !path.exists() {\n        return Err((\n            StatusCode::NOT_FOUND,\n            format!(\"File not found: {}\", req.path),\n        ));\n    }\n\n    let (buffer, format) = crate::audio::load_audio(path).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Load error: {e}\"),\n        )\n    })?;\n\n    let info = FileInfo {\n        file_path: req.path.clone(),\n        format: format.to_string(),\n        duration_secs: buffer.duration_secs(),\n        sample_rate: buffer.sample_rate,\n        channels: buffer.num_channels(),\n    };\n\n    let mut state = state.write().await;\n    state.file_path = Some(req.path);\n    state.format = Some(info.format.clone());\n    state.buffer = Some(buffer);\n\n    Ok(Json(info))\n}\n\nasync fn upload_file(\n    State(state): State<SharedState>,\n    mut multipart: Multipart,\n) -> Result<Json<FileInfo>, (StatusCode, String)> {\n    let field = multipart\n        .next_field()\n        .await\n        .map_err(|e| (StatusCode::BAD_REQUEST, format!(\"Multipart error: {e}\")))?\n        .ok_or((StatusCode::BAD_REQUEST, \"No file field found\".to_string()))?;\n\n    let file_name = field.file_name().unwrap_or(\"upload.wav\").to_string();\n\n    let ext = Path::new(&file_name)\n        .extension()\n        .and_then(|e| e.to_str())\n        .unwrap_or(\"wav\");\n\n    let mut tmp = tempfile::Builder::new()\n        .suffix(&format!(\".{ext}\"))\n        .tempfile()\n        .map_err(|e| {\n            (\n                StatusCode::INTERNAL_SERVER_ERROR,\n                format!(\"Temp file error: {e}\"),\n            )\n        })?;\n\n    let bytes = field\n        .bytes()\n        .await\n        .map_err(|e| (StatusCode::BAD_REQUEST, format!(\"Read error: {e}\")))?;\n\n    tmp.write_all(&bytes).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Write error: {e}\"),\n        )\n    })?;\n\n    let tmp_path = tmp.into_temp_path();\n    let path_str = tmp_path.to_string_lossy().to_string();\n\n    // Leak the temp path so the file persists for the session\n    let leaked: &'static std::path::Path = Box::leak(tmp_path.to_path_buf().into_boxed_path());\n    std::mem::forget(tmp_path);\n    let _ = leaked;\n\n    let (buffer, format) = crate::audio::load_audio(Path::new(&path_str)).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Load error: {e}\"),\n        )\n    })?;\n\n    let info = FileInfo {\n        file_path: file_name,\n        format: format.to_string(),\n        duration_secs: buffer.duration_secs(),\n        sample_rate: buffer.sample_rate,\n        channels: buffer.num_channels(),\n    };\n\n    let mut app_state = state.write().await;\n    app_state.file_path = Some(path_str);\n    app_state.format = Some(info.format.clone());\n    app_state.buffer = Some(buffer);\n\n    Ok(Json(info))\n}\n\n// --- Analysis endpoints ---\n\nasync fn analyze_watermark(\n    State(state): State<SharedState>,\n) -> Result<Json<serde_json::Value>, (StatusCode, String)> {\n    let state = state.read().await;\n    let buffer = state\n        .buffer\n        .as_ref()\n        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n    let result = WatermarkDetector::detect_all(buffer);\n    Ok(Json(serde_json::to_value(result).unwrap()))\n}\n\nasync fn analyze_polez(\n    State(state): State<SharedState>,\n) -> Result<Json<serde_json::Value>, (StatusCode, String)> {\n    let state = state.read().await;\n    let buffer = state\n        .buffer\n        .as_ref()\n        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n    let result = PolezDetector::detect(buffer);\n    Ok(Json(serde_json::to_value(result).unwrap()))\n}\n\nasync fn analyze_statistical(\n    State(state): State<SharedState>,\n) -> Result<Json<serde_json::Value>, (StatusCode, String)> {\n    let state = state.read().await;\n    let buffer = state\n        .buffer\n        .as_ref()\n        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n    let result = StatisticalAnalyzer::analyze(buffer);\n    Ok(Json(serde_json::to_value(result).unwrap()))\n}\n\nasync fn analyze_metadata(\n    State(state): State<SharedState>,\n) -> Result<Json<serde_json::Value>, (StatusCode, String)> {\n    let state = state.read().await;\n    let file_path = state\n        .file_path\n        .as_ref()\n        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n    let result = MetadataScanner::scan(Path::new(file_path)).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Scan error: {e}\"),\n        )\n    })?;\n    Ok(Json(serde_json::to_value(result).unwrap()))\n}\n\nasync fn analyze_all(\n    State(state): State<SharedState>,\n) -> Result<Json<AllAnalysisResult>, (StatusCode, String)> {\n    let state = state.read().await;\n    let buffer = state\n        .buffer\n        .as_ref()\n        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n    let file_path = state\n        .file_path\n        .as_ref()\n        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n\n    let watermark = WatermarkDetector::detect_all(buffer);\n    let polez = PolezDetector::detect(buffer);\n    let statistical = StatisticalAnalyzer::analyze(buffer);\n    let metadata = MetadataScanner::scan(Path::new(file_path)).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Scan error: {e}\"),\n        )\n    })?;\n\n    Ok(Json(AllAnalysisResult {\n        watermark,\n        polez,\n        statistical,\n        metadata,\n    }))\n}\n\n// --- Waveform endpoint ---\n\n#[derive(Deserialize)]\nstruct WaveformQuery {\n    width: Option<usize>,\n    start: Option<f64>,\n    end: Option<f64>,\n}\n\nasync fn get_waveform(\n    State(state): State<SharedState>,\n    Query(query): Query<WaveformQuery>,\n) -> Result<Json<WaveformData>, (StatusCode, String)> {\n    let state = state.read().await;\n    let buffer = state\n        .buffer\n        .as_ref()\n        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n\n    let samples = buffer.to_mono_samples();\n    let sr = buffer.sample_rate as f64;\n    let total_samples = samples.len();\n    let duration_secs = total_samples as f64 / sr;\n\n    let start_sec = query.start.unwrap_or(0.0).max(0.0);\n    let end_sec = query.end.unwrap_or(duration_secs).min(duration_secs);\n    let start_idx = (start_sec * sr) as usize;\n    let end_idx = ((end_sec * sr) as usize).min(total_samples);\n\n    if start_idx >= end_idx {\n        return Err((StatusCode::BAD_REQUEST, \"Invalid time range\".to_string()));\n    }\n\n    let slice = &samples[start_idx..end_idx];\n    let width = query.width.unwrap_or(1024).max(1);\n    let chunk_size = (slice.len() / width).max(1);\n\n    let mut min_vals = Vec::with_capacity(width);\n    let mut max_vals = Vec::with_capacity(width);\n\n    for chunk in slice.chunks(chunk_size) {\n        let mut lo = f32::MAX;\n        let mut hi = f32::MIN;\n        for &s in chunk {\n            if s < lo {\n                lo = s;\n            }\n            if s > hi {\n                hi = s;\n            }\n        }\n        min_vals.push(lo);\n        max_vals.push(hi);\n    }\n\n    Ok(Json(WaveformData {\n        min: min_vals,\n        max: max_vals,\n        sample_rate: buffer.sample_rate,\n        duration_secs,\n        channels: buffer.num_channels(),\n    }))\n}\n\n// --- Spectrogram endpoint ---\n\n#[derive(Deserialize)]\nstruct SpectrogramQuery {\n    fft_size: Option<usize>,\n    freq_min: Option<f64>,\n    freq_max: Option<f64>,\n    start: Option<f64>,\n    duration: Option<f64>,\n}\n\nasync fn get_spectrogram(\n    State(state): State<SharedState>,\n    Query(query): Query<SpectrogramQuery>,\n) -> Result<Json<SpectrogramData>, (StatusCode, String)> {\n    let state = state.read().await;\n    let buffer = state\n        .buffer\n        .as_ref()\n        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n\n    let samples = buffer.to_mono_samples();\n    let sr = buffer.sample_rate as f64;\n    let total_duration = samples.len() as f64 / sr;\n\n    let fft_size = query.fft_size.unwrap_or(2048);\n    let hop = fft_size / 4;\n    let freq_min = query.freq_min.unwrap_or(0.0);\n    let freq_max = query.freq_max.unwrap_or(sr / 2.0);\n    let start_sec = query.start.unwrap_or(0.0).max(0.0);\n    let dur = query.duration.unwrap_or(total_duration - start_sec);\n    let end_sec = (start_sec + dur).min(total_duration);\n\n    let start_idx = (start_sec * sr) as usize;\n    let end_idx = ((end_sec * sr) as usize).min(samples.len());\n\n    if start_idx >= end_idx || end_idx - start_idx < fft_size {\n        return Err((\n            StatusCode::BAD_REQUEST,\n            \"Not enough samples for FFT\".to_string(),\n        ));\n    }\n\n    let slice = &samples[start_idx..end_idx];\n\n    // Build Hann window\n    let window: Vec<f64> = (0..fft_size)\n        .map(|i| {\n            0.5 * (1.0 - (2.0 * std::f64::consts::PI * i as f64 / (fft_size as f64 - 1.0)).cos())\n        })\n        .collect();\n\n    let mut planner = FftPlanner::<f64>::new();\n    let fft = planner.plan_fft_forward(fft_size);\n\n    // Frequency bin indices for the requested range\n    let bin_min = ((freq_min * fft_size as f64 / sr).floor() as usize).min(fft_size / 2);\n    let bin_max = ((freq_max * fft_size as f64 / sr).ceil() as usize).min(fft_size / 2);\n    let num_freq_bins = bin_max - bin_min;\n\n    if num_freq_bins == 0 {\n        return Err((\n            StatusCode::BAD_REQUEST,\n            \"Invalid frequency range\".to_string(),\n        ));\n    }\n\n    let mut magnitudes: Vec<Vec<f64>> = Vec::new();\n\n    let mut pos = 0;\n    while pos + fft_size <= slice.len() {\n        let mut fft_buf: Vec<Complex64> = slice[pos..pos + fft_size]\n            .iter()\n            .enumerate()\n            .map(|(i, &s)| Complex64::new(s as f64 * window[i], 0.0))\n            .collect();\n\n        fft.process(&mut fft_buf);\n\n        let frame: Vec<f64> = (bin_min..bin_max)\n            .map(|bin| {\n                let mag = fft_buf[bin].norm();\n                // Convert to dB, floor at -120 dB\n                let db = 20.0 * mag.max(1e-12).log10();\n                db.max(-120.0)\n            })\n            .collect();\n\n        magnitudes.push(frame);\n        pos += hop;\n    }\n\n    let num_time_frames = magnitudes.len();\n\n    Ok(Json(SpectrogramData {\n        magnitudes,\n        freq_min,\n        freq_max,\n        time_start: start_sec,\n        time_end: end_sec,\n        num_freq_bins,\n        num_time_frames,\n    }))\n}\n\n// --- Bitplane endpoint ---\n\nasync fn get_bitplane(\n    State(state): State<SharedState>,\n) -> Result<Json<BitPlaneData>, (StatusCode, String)> {\n    let state = state.read().await;\n    let buffer = state\n        .buffer\n        .as_ref()\n        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n\n    let samples = buffer.to_mono_samples();\n    let total = samples.len() as f64;\n\n    let planes: Vec<PlaneSummary> = (0..8u8)\n        .map(|bit| {\n            let mut ones = 0u64;\n            for &s in &samples {\n                let val = (s * 32767.0) as i16;\n                if (val >> bit) & 1 == 1 {\n                    ones += 1;\n                }\n            }\n            let ones_ratio = ones as f64 / total;\n            let bias = (ones_ratio - 0.5).abs();\n            PlaneSummary {\n                bit,\n                ones_ratio,\n                bias,\n            }\n        })\n        .collect();\n\n    Ok(Json(BitPlaneData { planes }))\n}\n\n// --- Audio serving endpoint ---\n\nasync fn serve_audio(State(state): State<SharedState>) -> Result<Response, (StatusCode, String)> {\n    let state = state.read().await;\n    let file_path = state\n        .file_path\n        .as_ref()\n        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n\n    let bytes = std::fs::read(file_path).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Read error: {e}\"),\n        )\n    })?;\n\n    let content_type = if file_path.ends_with(\".mp3\") {\n        \"audio/mpeg\"\n    } else {\n        \"audio/wav\"\n    };\n\n    Ok(([(header::CONTENT_TYPE, content_type)], bytes).into_response())\n}\n\n// --- Clean endpoint ---\n\nasync fn clean_file(\n    State(state): State<SharedState>,\n    Json(req): Json<CleanRequest>,\n) -> Result<Json<CleanResponse>, (StatusCode, String)> {\n    let mode = match req.mode.as_deref().unwrap_or(\"standard\") {\n        \"fast\" => SanitizationMode::Fast,\n        \"standard\" => SanitizationMode::Standard,\n        \"preserving\" => SanitizationMode::Preserving,\n        \"aggressive\" => SanitizationMode::Aggressive,\n        other => return Err((StatusCode::BAD_REQUEST, format!(\"Unknown mode: {other}\"))),\n    };\n\n    // Read source info from state\n    let (file_path, format_str) = {\n        let s = state.read().await;\n        let fp = s\n            .file_path\n            .clone()\n            .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n        let fmt = s\n            .format\n            .clone()\n            .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n        (fp, fmt)\n    };\n\n    let ext = if format_str == \"mp3\" { \"mp3\" } else { \"wav\" };\n\n    // Create temp output file\n    let tmp = tempfile::Builder::new()\n        .suffix(&format!(\"_cleaned.{ext}\"))\n        .tempfile()\n        .map_err(|e| {\n            (\n                StatusCode::INTERNAL_SERVER_ERROR,\n                format!(\"Temp file error: {e}\"),\n            )\n        })?;\n    let tmp_path = tmp.into_temp_path();\n    let output_path = tmp_path.to_path_buf();\n    // Leak so it persists for the session\n    std::mem::forget(tmp_path);\n\n    let input_path = std::path::PathBuf::from(&file_path);\n    let out = output_path.clone();\n\n    // Run sanitization in blocking thread (CPU-bound)\n    let san_result = tokio::task::spawn_blocking(move || {\n        let cfg = default_config();\n        let pipeline = SanitizationPipeline::new(\n            mode,\n            false,\n            AdvancedFlags::default(),\n            cfg.fingerprint_removal,\n            None,\n        );\n        pipeline.run(&input_path, &out)\n    })\n    .await\n    .map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Task join error: {e}\"),\n        )\n    })?\n    .map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Sanitization error: {e}\"),\n        )\n    })?;\n\n    // Load cleaned audio\n    let (cleaned_buffer, cleaned_fmt) = crate::audio::load_audio(&output_path).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Load cleaned error: {e}\"),\n        )\n    })?;\n\n    // Run detection on original (before)\n    let before = {\n        let s = state.read().await;\n        let buf = s.buffer.as_ref().unwrap();\n        let fp = s.file_path.as_ref().unwrap();\n        let watermark = WatermarkDetector::detect_all(buf);\n        let polez = PolezDetector::detect(buf);\n        let statistical = StatisticalAnalyzer::analyze(buf);\n        let metadata = MetadataScanner::scan(Path::new(fp)).map_err(|e| {\n            (\n                StatusCode::INTERNAL_SERVER_ERROR,\n                format!(\"Scan error: {e}\"),\n            )\n        })?;\n        AllAnalysisResult {\n            watermark,\n            polez,\n            statistical,\n            metadata,\n        }\n    };\n\n    // Run detection on cleaned (after)\n    let output_path_str = output_path.to_string_lossy().to_string();\n    let watermark = WatermarkDetector::detect_all(&cleaned_buffer);\n    let polez_result = PolezDetector::detect(&cleaned_buffer);\n    let statistical = StatisticalAnalyzer::analyze(&cleaned_buffer);\n    let metadata = MetadataScanner::scan(&output_path).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Scan error: {e}\"),\n        )\n    })?;\n    let after = AllAnalysisResult {\n        watermark,\n        polez: polez_result,\n        statistical,\n        metadata,\n    };\n\n    // Store cleaned state\n    {\n        let mut s = state.write().await;\n        s.cleaned_buffer = Some(cleaned_buffer);\n        s.cleaned_file_path = Some(output_path_str);\n        s.cleaned_format = Some(cleaned_fmt.to_string());\n    }\n\n    Ok(Json(CleanResponse {\n        success: san_result.success,\n        metadata_removed: san_result.metadata_removed,\n        patterns_found: san_result.patterns_found,\n        patterns_suppressed: san_result.patterns_suppressed,\n        quality_loss: san_result.quality_loss,\n        processing_time: san_result.processing_time,\n        before,\n        after,\n    }))\n}\n\n// --- Serve cleaned audio ---\n\nasync fn serve_cleaned_audio(\n    State(state): State<SharedState>,\n) -> Result<Response, (StatusCode, String)> {\n    let state = state.read().await;\n    let file_path = state.cleaned_file_path.as_ref().ok_or((\n        StatusCode::BAD_REQUEST,\n        \"No cleaned file available\".to_string(),\n    ))?;\n\n    let bytes = std::fs::read(file_path).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Read error: {e}\"),\n        )\n    })?;\n\n    let content_type = if file_path.ends_with(\".mp3\") {\n        \"audio/mpeg\"\n    } else {\n        \"audio/wav\"\n    };\n\n    Ok(([(header::CONTENT_TYPE, content_type)], bytes).into_response())\n}\n\n// --- Cleaned waveform endpoint ---\n\nasync fn get_cleaned_waveform(\n    State(state): State<SharedState>,\n    Query(query): Query<WaveformQuery>,\n) -> Result<Json<WaveformData>, (StatusCode, String)> {\n    let state = state.read().await;\n    let buffer = state.cleaned_buffer.as_ref().ok_or((\n        StatusCode::BAD_REQUEST,\n        \"No cleaned file available\".to_string(),\n    ))?;\n\n    let samples = buffer.to_mono_samples();\n    let sr = buffer.sample_rate as f64;\n    let total_samples = samples.len();\n    let duration_secs = total_samples as f64 / sr;\n\n    let start_sec = query.start.unwrap_or(0.0).max(0.0);\n    let end_sec = query.end.unwrap_or(duration_secs).min(duration_secs);\n    let start_idx = (start_sec * sr) as usize;\n    let end_idx = ((end_sec * sr) as usize).min(total_samples);\n\n    if start_idx >= end_idx {\n        return Err((StatusCode::BAD_REQUEST, \"Invalid time range\".to_string()));\n    }\n\n    let slice = &samples[start_idx..end_idx];\n    let width = query.width.unwrap_or(1024).max(1);\n    let chunk_size = (slice.len() / width).max(1);\n\n    let mut min_vals = Vec::with_capacity(width);\n    let mut max_vals = Vec::with_capacity(width);\n\n    for chunk in slice.chunks(chunk_size) {\n        let mut lo = f32::MAX;\n        let mut hi = f32::MIN;\n        for &s in chunk {\n            if s < lo {\n                lo = s;\n            }\n            if s > hi {\n                hi = s;\n            }\n        }\n        min_vals.push(lo);\n        max_vals.push(hi);\n    }\n\n    Ok(Json(WaveformData {\n        min: min_vals,\n        max: max_vals,\n        sample_rate: buffer.sample_rate,\n        duration_secs,\n        channels: buffer.num_channels(),\n    }))\n}\n\n// --- Save/download cleaned file ---\n\nasync fn save_cleaned_file(\n    State(state): State<SharedState>,\n) -> Result<Response, (StatusCode, String)> {\n    let state = state.read().await;\n    let file_path = state.cleaned_file_path.as_ref().ok_or((\n        StatusCode::BAD_REQUEST,\n        \"No cleaned file available\".to_string(),\n    ))?;\n\n    let bytes = std::fs::read(file_path).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Read error: {e}\"),\n        )\n    })?;\n\n    let ext = if file_path.ends_with(\".mp3\") {\n        \"mp3\"\n    } else {\n        \"wav\"\n    };\n\n    let filename = format!(\"cleaned_output.{ext}\");\n    let content_type = if ext == \"mp3\" {\n        \"audio/mpeg\"\n    } else {\n        \"audio/wav\"\n    };\n\n    Ok((\n        [\n            (header::CONTENT_TYPE, content_type),\n            (\n                header::CONTENT_DISPOSITION,\n                &format!(\"attachment; filename=\\\"{filename}\\\"\"),\n            ),\n        ],\n        bytes,\n    )\n        .into_response())\n}\n","numLines":781,"startLine":1,"totalLines":781}}}
