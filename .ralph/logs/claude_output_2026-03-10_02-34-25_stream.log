{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MnxFDHAm26JyYhJw2ReHrb","type":"tool_result","content":"     1→use axum::extract::DefaultBodyLimit;\n     2→use axum::{\n     3→    extract::{Multipart, Query, State},\n     4→    http::{header, StatusCode},\n     5→    response::{IntoResponse, Response},\n     6→    routing::{get, post},\n     7→    Json, Router,\n     8→};\n     9→use rustfft::num_complex::Complex64;\n    10→use rustfft::FftPlanner;\n    11→use serde::Deserialize;\n    12→use std::io::Write;\n    13→use std::path::Path;\n    14→use tower_http::cors::{Any, CorsLayer};\n    15→\n    16→use crate::config::{defaults::default_config, AdvancedFlags};\n    17→use crate::detection::{MetadataScanner, PolezDetector, StatisticalAnalyzer, WatermarkDetector};\n    18→use crate::sanitization::pipeline::SanitizationMode;\n    19→use crate::sanitization::SanitizationPipeline;\n    20→\n    21→use super::types::{\n    22→    AllAnalysisResult, BitPlaneData, CleanRequest, CleanResponse, FileInfo, PlaneSummary,\n    23→    SpectrogramData, WaveformData,\n    24→};\n    25→use super::SharedState;\n    26→\n    27→pub fn create_router(state: SharedState) -> Router {\n    28→    let cors = CorsLayer::new()\n    29→        .allow_origin(Any)\n    30→        .allow_methods(Any)\n    31→        .allow_headers(Any);\n    32→\n    33→    Router::new()\n    34→        .route(\"/api/health\", get(health))\n    35→        .route(\"/api/limits\", get(get_limits))\n    36→        .route(\"/api/load\", post(load_file))\n    37→        .route(\"/api/upload\", post(upload_file))\n    38→        .route(\"/api/waveform\", get(get_waveform))\n    39→        .route(\"/api/spectrogram\", get(get_spectrogram))\n    40→        .route(\"/api/bitplane\", get(get_bitplane))\n    41→        .route(\"/api/audio\", get(serve_audio))\n    42→        .route(\"/api/analyze/watermark\", post(analyze_watermark))\n    43→        .route(\"/api/analyze/polez\", post(analyze_polez))\n    44→        .route(\"/api/analyze/statistical\", post(analyze_statistical))\n    45→        .route(\"/api/analyze/metadata\", post(analyze_metadata))\n    46→        .route(\"/api/analyze/all\", post(analyze_all))\n    47→        .route(\"/api/clean\", post(clean_file))\n    48→        .route(\"/api/audio/cleaned\", get(serve_cleaned_audio))\n    49→        .route(\"/api/waveform/cleaned\", get(get_cleaned_waveform))\n    50→        .route(\"/api/spectrogram/cleaned\", get(get_cleaned_spectrogram))\n    51→        .route(\"/api/save\", post(save_cleaned_file))\n    52→        .fallback(get(static_handler))\n    53→        .layer(DefaultBodyLimit::max(MAX_UPLOAD_BYTES))\n    54→        .layer(cors)\n    55→        .with_state(state)\n    56→}\n    57→\n    58→async fn static_handler(uri: axum::http::Uri) -> Response {\n    59→    let path = uri.path().trim_start_matches('/');\n    60→    let path = if path.is_empty() { \"index.html\" } else { path };\n    61→\n    62→    match super::Assets::get(path) {\n    63→        Some(content) => {\n    64→            let mime = mime_guess::from_path(path).first_or_octet_stream();\n    65→            (\n    66→                [(header::CONTENT_TYPE, mime.as_ref())],\n    67→                content.data.to_vec(),\n    68→            )\n    69→                .into_response()\n    70→        }\n    71→        None => {\n    72→            // SPA fallback: serve index.html for all non-API routes\n    73→            match super::Assets::get(\"index.html\") {\n    74→                Some(content) => {\n    75→                    ([(header::CONTENT_TYPE, \"text/html\")], content.data.to_vec()).into_response()\n    76→                }\n    77→                None => (StatusCode::NOT_FOUND, \"Not found\").into_response(),\n    78→            }\n    79→        }\n    80→    }\n    81→}\n    82→\n    83→async fn health() -> &'static str {\n    84→    \"ok\"\n    85→}\n    86→\n    87→const MAX_UPLOAD_BYTES: usize = 500 * 1024 * 1024; // 500MB\n    88→\n    89→async fn get_limits() -> Json<serde_json::Value> {\n    90→    Json(serde_json::json!({\n    91→        \"max_upload_bytes\": MAX_UPLOAD_BYTES,\n    92→        \"supported_formats\": [\"wav\", \"mp3\", \"flac\", \"aac\", \"m4a\"]\n    93→    }))\n    94→}\n    95→\n    96→#[derive(Deserialize)]\n    97→struct LoadRequest {\n    98→    path: String,\n    99→}\n   100→\n   101→async fn load_file(\n   102→    State(state): State<SharedState>,\n   103→    Json(req): Json<LoadRequest>,\n   104→) -> Result<Json<FileInfo>, (StatusCode, String)> {\n   105→    let path = Path::new(&req.path);\n   106→\n   107→    if !path.exists() {\n   108→        return Err((\n   109→            StatusCode::NOT_FOUND,\n   110→            format!(\"File not found: {}\", req.path),\n   111→        ));\n   112→    }\n   113→\n   114→    let (buffer, format) = crate::audio::load_audio(path).map_err(|e| {\n   115→        (\n   116→            StatusCode::INTERNAL_SERVER_ERROR,\n   117→            format!(\"Load error: {e}\"),\n   118→        )\n   119→    })?;\n   120→\n   121→    let info = FileInfo {\n   122→        file_path: req.path.clone(),\n   123→        format: format.to_string(),\n   124→        duration_secs: buffer.duration_secs(),\n   125→        sample_rate: buffer.sample_rate,\n   126→        channels: buffer.num_channels(),\n   127→    };\n   128→\n   129→    let mut state = state.write().await;\n   130→    state.file_path = Some(req.path);\n   131→    state.format = Some(info.format.clone());\n   132→    state.buffer = Some(buffer);\n   133→\n   134→    Ok(Json(info))\n   135→}\n   136→\n   137→async fn upload_file(\n   138→    State(state): State<SharedState>,\n   139→    mut multipart: Multipart,\n   140→) -> Result<Json<FileInfo>, (StatusCode, String)> {\n   141→    let field = multipart\n   142→        .next_field()\n   143→        .await\n   144→        .map_err(|e| (StatusCode::BAD_REQUEST, format!(\"Multipart error: {e}\")))?\n   145→        .ok_or((StatusCode::BAD_REQUEST, \"No file field found\".to_string()))?;\n   146→\n   147→    let file_name = field.file_name().unwrap_or(\"upload.wav\").to_string();\n   148→\n   149→    let ext = Path::new(&file_name)\n   150→        .extension()\n   151→        .and_then(|e| e.to_str())\n   152→        .unwrap_or(\"wav\");\n   153→\n   154→    let mut tmp = tempfile::Builder::new()\n   155→        .suffix(&format!(\".{ext}\"))\n   156→        .tempfile()\n   157→        .map_err(|e| {\n   158→            (\n   159→                StatusCode::INTERNAL_SERVER_ERROR,\n   160→                format!(\"Temp file error: {e}\"),\n   161→            )\n   162→        })?;\n   163→\n   164→    let bytes = field\n   165→        .bytes()\n   166→        .await\n   167→        .map_err(|e| (StatusCode::BAD_REQUEST, format!(\"Read error: {e}\")))?;\n   168→\n   169→    tmp.write_all(&bytes).map_err(|e| {\n   170→        (\n   171→            StatusCode::INTERNAL_SERVER_ERROR,\n   172→            format!(\"Write error: {e}\"),\n   173→        )\n   174→    })?;\n   175→\n   176→    let tmp_path = tmp.into_temp_path();\n   177→    let persisted_path = tmp_path.to_path_buf();\n   178→    // Keep the file on disk by persisting the TempPath (consumes it without deleting)\n   179→    tmp_path.keep().map_err(|e| {\n   180→        (\n   181→            StatusCode::INTERNAL_SERVER_ERROR,\n   182→            format!(\"Temp path persist error: {e}\"),\n   183→        )\n   184→    })?;\n   185→    let path_str = persisted_path.to_string_lossy().to_string();\n   186→\n   187→    let (buffer, format) = crate::audio::load_audio(&persisted_path).map_err(|e| {\n   188→        (\n   189→            StatusCode::INTERNAL_SERVER_ERROR,\n   190→            format!(\"Load error: {e}\"),\n   191→        )\n   192→    })?;\n   193→\n   194→    let info = FileInfo {\n   195→        file_path: file_name,\n   196→        format: format.to_string(),\n   197→        duration_secs: buffer.duration_secs(),\n   198→        sample_rate: buffer.sample_rate,\n   199→        channels: buffer.num_channels(),\n   200→    };\n   201→\n   202→    let mut app_state = state.write().await;\n   203→    app_state.temp_paths.push(persisted_path);\n   204→    app_state.file_path = Some(path_str);\n   205→    app_state.format = Some(info.format.clone());\n   206→    app_state.buffer = Some(buffer);\n   207→\n   208→    Ok(Json(info))\n   209→}\n   210→\n   211→// --- Analysis endpoints ---\n   212→\n   213→async fn analyze_watermark(\n   214→    State(state): State<SharedState>,\n   215→) -> Result<Json<serde_json::Value>, (StatusCode, String)> {\n   216→    let state = state.read().await;\n   217→    let buffer = state\n   218→        .buffer\n   219→        .as_ref()\n   220→        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   221→    let result = WatermarkDetector::detect_all(buffer);\n   222→    let value = serde_json::to_value(result).map_err(|e| {\n   223→        (\n   224→            StatusCode::INTERNAL_SERVER_ERROR,\n   225→            format!(\"Serialization error: {e}\"),\n   226→        )\n   227→    })?;\n   228→    Ok(Json(value))\n   229→}\n   230→\n   231→async fn analyze_polez(\n   232→    State(state): State<SharedState>,\n   233→) -> Result<Json<serde_json::Value>, (StatusCode, String)> {\n   234→    let state = state.read().await;\n   235→    let buffer = state\n   236→        .buffer\n   237→        .as_ref()\n   238→        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   239→    let result = PolezDetector::detect(buffer);\n   240→    let value = serde_json::to_value(result).map_err(|e| {\n   241→        (\n   242→            StatusCode::INTERNAL_SERVER_ERROR,\n   243→            format!(\"Serialization error: {e}\"),\n   244→        )\n   245→    })?;\n   246→    Ok(Json(value))\n   247→}\n   248→\n   249→async fn analyze_statistical(\n   250→    State(state): State<SharedState>,\n   251→) -> Result<Json<serde_json::Value>, (StatusCode, String)> {\n   252→    let state = state.read().await;\n   253→    let buffer = state\n   254→        .buffer\n   255→        .as_ref()\n   256→        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   257→    let result = StatisticalAnalyzer::analyze(buffer);\n   258→    let value = serde_json::to_value(result).map_err(|e| {\n   259→        (\n   260→            StatusCode::INTERNAL_SERVER_ERROR,\n   261→            format!(\"Serialization error: {e}\"),\n   262→        )\n   263→    })?;\n   264→    Ok(Json(value))\n   265→}\n   266→\n   267→async fn analyze_metadata(\n   268→    State(state): State<SharedState>,\n   269→) -> Result<Json<serde_json::Value>, (StatusCode, String)> {\n   270→    let state = state.read().await;\n   271→    let file_path = state\n   272→        .file_path\n   273→        .as_ref()\n   274→        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   275→    let result = MetadataScanner::scan(Path::new(file_path)).map_err(|e| {\n   276→        (\n   277→            StatusCode::INTERNAL_SERVER_ERROR,\n   278→            format!(\"Scan error: {e}\"),\n   279→        )\n   280→    })?;\n   281→    let value = serde_json::to_value(result).map_err(|e| {\n   282→        (\n   283→            StatusCode::INTERNAL_SERVER_ERROR,\n   284→            format!(\"Serialization error: {e}\"),\n   285→        )\n   286→    })?;\n   287→    Ok(Json(value))\n   288→}\n   289→\n   290→async fn analyze_all(\n   291→    State(state): State<SharedState>,\n   292→) -> Result<Json<AllAnalysisResult>, (StatusCode, String)> {\n   293→    let state = state.read().await;\n   294→    let buffer = state\n   295→        .buffer\n   296→        .as_ref()\n   297→        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   298→    let file_path = state\n   299→        .file_path\n   300→        .as_ref()\n   301→        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   302→\n   303→    let watermark = WatermarkDetector::detect_all(buffer);\n   304→    let polez = PolezDetector::detect(buffer);\n   305→    let statistical = StatisticalAnalyzer::analyze(buffer);\n   306→    let metadata = MetadataScanner::scan(Path::new(file_path)).map_err(|e| {\n   307→        (\n   308→            StatusCode::INTERNAL_SERVER_ERROR,\n   309→            format!(\"Scan error: {e}\"),\n   310→        )\n   311→    })?;\n   312→\n   313→    Ok(Json(AllAnalysisResult {\n   314→        watermark,\n   315→        polez,\n   316→        statistical,\n   317→        metadata,\n   318→    }))\n   319→}\n   320→\n   321→// --- Waveform endpoint ---\n   322→\n   323→#[derive(Deserialize)]\n   324→struct WaveformQuery {\n   325→    width: Option<usize>,\n   326→    start: Option<f64>,\n   327→    end: Option<f64>,\n   328→}\n   329→\n   330→async fn get_waveform(\n   331→    State(state): State<SharedState>,\n   332→    Query(query): Query<WaveformQuery>,\n   333→) -> Result<Json<WaveformData>, (StatusCode, String)> {\n   334→    let state = state.read().await;\n   335→    let buffer = state\n   336→        .buffer\n   337→        .as_ref()\n   338→        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   339→\n   340→    let samples = buffer.to_mono_samples();\n   341→    let sr = buffer.sample_rate as f64;\n   342→    let total_samples = samples.len();\n   343→    let duration_secs = total_samples as f64 / sr;\n   344→\n   345→    let start_sec = query.start.unwrap_or(0.0).max(0.0);\n   346→    let end_sec = query.end.unwrap_or(duration_secs).min(duration_secs);\n   347→    let start_idx = (start_sec * sr) as usize;\n   348→    let end_idx = ((end_sec * sr) as usize).min(total_samples);\n   349→\n   350→    if start_idx >= end_idx {\n   351→        return Err((StatusCode::BAD_REQUEST, \"Invalid time range\".to_string()));\n   352→    }\n   353→\n   354→    let slice = &samples[start_idx..end_idx];\n   355→    let width = query.width.unwrap_or(1024).max(1);\n   356→    let chunk_size = (slice.len() / width).max(1);\n   357→\n   358→    let mut min_vals = Vec::with_capacity(width);\n   359→    let mut max_vals = Vec::with_capacity(width);\n   360→\n   361→    for chunk in slice.chunks(chunk_size) {\n   362→        let mut lo = f32::MAX;\n   363→        let mut hi = f32::MIN;\n   364→        for &s in chunk {\n   365→            if s < lo {\n   366→                lo = s;\n   367→            }\n   368→            if s > hi {\n   369→                hi = s;\n   370→            }\n   371→        }\n   372→        min_vals.push(lo);\n   373→        max_vals.push(hi);\n   374→    }\n   375→\n   376→    Ok(Json(WaveformData {\n   377→        min: min_vals,\n   378→        max: max_vals,\n   379→        sample_rate: buffer.sample_rate,\n   380→        duration_secs,\n   381→        channels: buffer.num_channels(),\n   382→    }))\n   383→}\n   384→\n   385→// --- Spectrogram endpoint ---\n   386→\n   387→#[derive(Deserialize)]\n   388→struct SpectrogramQuery {\n   389→    fft_size: Option<usize>,\n   390→    freq_min: Option<f64>,\n   391→    freq_max: Option<f64>,\n   392→    start: Option<f64>,\n   393→    duration: Option<f64>,\n   394→}\n   395→\n   396→fn compute_spectrogram(\n   397→    buffer: &crate::audio::AudioBuffer,\n   398→    query: &SpectrogramQuery,\n   399→) -> Result<SpectrogramData, (StatusCode, String)> {\n   400→    let samples = buffer.to_mono_samples();\n   401→    let sr = buffer.sample_rate as f64;\n   402→    let total_duration = samples.len() as f64 / sr;\n   403→\n   404→    let fft_size = query.fft_size.unwrap_or(2048);\n   405→    let hop = fft_size / 4;\n   406→    let freq_min = query.freq_min.unwrap_or(0.0);\n   407→    let freq_max = query.freq_max.unwrap_or(sr / 2.0);\n   408→    let start_sec = query.start.unwrap_or(0.0).max(0.0);\n   409→    let dur = query.duration.unwrap_or(total_duration - start_sec);\n   410→    let end_sec = (start_sec + dur).min(total_duration);\n   411→\n   412→    let start_idx = (start_sec * sr) as usize;\n   413→    let end_idx = ((end_sec * sr) as usize).min(samples.len());\n   414→\n   415→    if start_idx >= end_idx || end_idx - start_idx < fft_size {\n   416→        return Err((\n   417→            StatusCode::BAD_REQUEST,\n   418→            \"Not enough samples for FFT\".to_string(),\n   419→        ));\n   420→    }\n   421→\n   422→    let slice = &samples[start_idx..end_idx];\n   423→\n   424→    // Build Hann window\n   425→    let window: Vec<f64> = (0..fft_size)\n   426→        .map(|i| {\n   427→            0.5 * (1.0 - (2.0 * std::f64::consts::PI * i as f64 / (fft_size as f64 - 1.0)).cos())\n   428→        })\n   429→        .collect();\n   430→\n   431→    let mut planner = FftPlanner::<f64>::new();\n   432→    let fft = planner.plan_fft_forward(fft_size);\n   433→\n   434→    // Frequency bin indices for the requested range\n   435→    let bin_min = ((freq_min * fft_size as f64 / sr).floor() as usize).min(fft_size / 2);\n   436→    let bin_max = ((freq_max * fft_size as f64 / sr).ceil() as usize).min(fft_size / 2);\n   437→    let num_freq_bins = bin_max - bin_min;\n   438→\n   439→    if num_freq_bins == 0 {\n   440→        return Err((\n   441→            StatusCode::BAD_REQUEST,\n   442→            \"Invalid frequency range\".to_string(),\n   443→        ));\n   444→    }\n   445→\n   446→    let mut magnitudes: Vec<Vec<f64>> = Vec::new();\n   447→\n   448→    let mut pos = 0;\n   449→    while pos + fft_size <= slice.len() {\n   450→        let mut fft_buf: Vec<Complex64> = slice[pos..pos + fft_size]\n   451→            .iter()\n   452→            .enumerate()\n   453→            .map(|(i, &s)| Complex64::new(s as f64 * window[i], 0.0))\n   454→            .collect();\n   455→\n   456→        fft.process(&mut fft_buf);\n   457→\n   458→        let frame: Vec<f64> = (bin_min..bin_max)\n   459→            .map(|bin| {\n   460→                let mag = fft_buf[bin].norm();\n   461→                let db = 20.0 * mag.max(1e-12).log10();\n   462→                db.max(-120.0)\n   463→            })\n   464→            .collect();\n   465→\n   466→        magnitudes.push(frame);\n   467→        pos += hop;\n   468→    }\n   469→\n   470→    let num_time_frames = magnitudes.len();\n   471→\n   472→    Ok(SpectrogramData {\n   473→        magnitudes,\n   474→        freq_min,\n   475→        freq_max,\n   476→        time_start: start_sec,\n   477→        time_end: end_sec,\n   478→        num_freq_bins,\n   479→        num_time_frames,\n   480→    })\n   481→}\n   482→\n   483→async fn get_spectrogram(\n   484→    State(state): State<SharedState>,\n   485→    Query(query): Query<SpectrogramQuery>,\n   486→) -> Result<Json<SpectrogramData>, (StatusCode, String)> {\n   487→    let state = state.read().await;\n   488→    let buffer = state\n   489→        .buffer\n   490→        .as_ref()\n   491→        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   492→    compute_spectrogram(buffer, &query).map(Json)\n   493→}\n   494→\n   495→// --- Bitplane endpoint ---\n   496→\n   497→async fn get_bitplane(\n   498→    State(state): State<SharedState>,\n   499→) -> Result<Json<BitPlaneData>, (StatusCode, String)> {\n   500→    let state = state.read().await;\n   501→    let buffer = state\n   502→        .buffer\n   503→        .as_ref()\n   504→        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   505→\n   506→    let samples = buffer.to_mono_samples();\n   507→    let total = samples.len() as f64;\n   508→\n   509→    let planes: Vec<PlaneSummary> = (0..8u8)\n   510→        .map(|bit| {\n   511→            let mut ones = 0u64;\n   512→            for &s in &samples {\n   513→                let val = (s * 32767.0) as i16;\n   514→                if (val >> bit) & 1 == 1 {\n   515→                    ones += 1;\n   516→                }\n   517→            }\n   518→            let ones_ratio = ones as f64 / total;\n   519→            let bias = (ones_ratio - 0.5).abs();\n   520→            PlaneSummary {\n   521→                bit,\n   522→                ones_ratio,\n   523→                bias,\n   524→            }\n   525→        })\n   526→        .collect();\n   527→\n   528→    Ok(Json(BitPlaneData { planes }))\n   529→}\n   530→\n   531→// --- Audio serving endpoint ---\n   532→\n   533→async fn serve_audio(State(state): State<SharedState>) -> Result<Response, (StatusCode, String)> {\n   534→    let state = state.read().await;\n   535→    let file_path = state\n   536→        .file_path\n   537→        .as_ref()\n   538→        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   539→\n   540→    let bytes = std::fs::read(file_path).map_err(|e| {\n   541→        (\n   542→            StatusCode::INTERNAL_SERVER_ERROR,\n   543→            format!(\"Read error: {e}\"),\n   544→        )\n   545→    })?;\n   546→\n   547→    let content_type = if file_path.ends_with(\".mp3\") {\n   548→        \"audio/mpeg\"\n   549→    } else {\n   550→        \"audio/wav\"\n   551→    };\n   552→\n   553→    Ok(([(header::CONTENT_TYPE, content_type)], bytes).into_response())\n   554→}\n   555→\n   556→// --- Clean endpoint ---\n   557→\n   558→async fn clean_file(\n   559→    State(state): State<SharedState>,\n   560→    Json(req): Json<CleanRequest>,\n   561→) -> Result<Json<CleanResponse>, (StatusCode, String)> {\n   562→    let mode = match req.mode.as_deref().unwrap_or(\"standard\") {\n   563→        \"fast\" => SanitizationMode::Fast,\n   564→        \"standard\" => SanitizationMode::Standard,\n   565→        \"preserving\" => SanitizationMode::Preserving,\n   566→        \"aggressive\" => SanitizationMode::Aggressive,\n   567→        other => return Err((StatusCode::BAD_REQUEST, format!(\"Unknown mode: {other}\"))),\n   568→    };\n   569→\n   570→    // Read source info from state\n   571→    let (file_path, format_str) = {\n   572→        let s = state.read().await;\n   573→        let fp = s\n   574→            .file_path\n   575→            .clone()\n   576→            .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   577→        let fmt = s\n   578→            .format\n   579→            .clone()\n   580→            .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n   581→        (fp, fmt)\n   582→    };\n   583→\n   584→    let ext = if format_str == \"mp3\" { \"mp3\" } else { \"wav\" };\n   585→\n   586→    // Create temp output file\n   587→    let tmp = tempfile::Builder::new()\n   588→        .suffix(&format!(\"_cleaned.{ext}\"))\n   589→        .tempfile()\n   590→        .map_err(|e| {\n   591→            (\n   592→                StatusCode::INTERNAL_SERVER_ERROR,\n   593→                format!(\"Temp file error: {e}\"),\n   594→            )\n   595→        })?;\n   596→    let tmp_path = tmp.into_temp_path();\n   597→    let output_path = tmp_path.to_path_buf();\n   598→    // Keep the file on disk; track for cleanup when state is dropped\n   599→    tmp_path.keep().map_err(|e| {\n   600→        (\n   601→            StatusCode::INTERNAL_SERVER_ERROR,\n   602→            format!(\"Temp path persist error: {e}\"),\n   603→        )\n   604→    })?;\n   605→\n   606→    let input_path = std::path::PathBuf::from(&file_path);\n   607→    let out = output_path.clone();\n   608→\n   609→    // Run sanitization in blocking thread (CPU-bound)\n   610→    let san_result = tokio::task::spawn_blocking(move || {\n   611→        let cfg = default_config();\n   612→        let pipeline = SanitizationPipeline::new(\n   613→            mode,\n   614→            false,\n   615→            AdvancedFlags::default(),\n   616→            cfg.fingerprint_removal,\n   617→            None,\n   618→        );\n   619→        pipeline.run(&input_path, &out)\n   620→    })\n   621→    .await\n   622→    .map_err(|e| {\n   623→        (\n   624→            StatusCode::INTERNAL_SERVER_ERROR,\n   625→            format!(\"Task join error: {e}\"),\n   626→        )\n   627→    })?\n   628→    .map_err(|e| {\n   629→        (\n   630→            StatusCode::INTERNAL_SERVER_ERROR,\n   631→            format!(\"Sanitization error: {e}\"),\n   632→        )\n   633→    })?;\n   634→\n   635→    // Load cleaned audio\n   636→    let (cleaned_buffer, cleaned_fmt) = crate::audio::load_audio(&output_path).map_err(|e| {\n   637→        (\n   638→            StatusCode::INTERNAL_SERVER_ERROR,\n   639→            format!(\"Load cleaned error: {e}\"),\n   640→        )\n   641→    })?;\n   642→\n   643→    // Run detection on original (before)\n   644→    let before = {\n   645→        let s = state.read().await;\n   646→        let buf = s.buffer.as_ref().ok_or((\n   647→            StatusCode::INTERNAL_SERVER_ERROR,\n   648→            \"Original buffer no longer available\".to_string(),\n   649→        ))?;\n   650→        let fp = s.file_path.as_ref().ok_or((\n   651→            StatusCode::INTERNAL_SERVER_ERROR,\n   652→            \"Original file path no longer available\".to_string(),\n   653→        ))?;\n   654→        let watermark = WatermarkDetector::detect_all(buf);\n   655→        let polez = PolezDetector::detect(buf);\n   656→        let statistical = StatisticalAnalyzer::analyze(buf);\n   657→        let metadata = MetadataScanner::scan(Path::new(fp)).map_err(|e| {\n   658→            (\n   659→                StatusCode::INTERNAL_SERVER_ERROR,\n   660→                format!(\"Scan error: {e}\"),\n   661→            )\n   662→        })?;\n   663→        AllAnalysisResult {\n   664→            watermark,\n   665→            polez,\n   666→            statistical,\n   667→            metadata,\n   668→        }\n   669→    };\n   670→\n   671→    // Run detection on cleaned (after)\n   672→    let output_path_str = output_path.to_string_lossy().to_string();\n   673→    let watermark = WatermarkDetector::detect_all(&cleaned_buffer);\n   674→    let polez_result = PolezDetector::detect(&cleaned_buffer);\n   675→    let statistical = StatisticalAnalyzer::analyze(&cleaned_buffer);\n   676→    let metadata = MetadataScanner::scan(&output_path).map_err(|e| {\n   677→        (\n   678→            StatusCode::INTERNAL_SERVER_ERROR,\n   679→            format!(\"Scan error: {e}\"),\n   680→        )\n   681→    })?;\n   682→    let after = AllAnalysisResult {\n   683→        watermark,\n   684→        polez: polez_result,\n   685→        statistical,\n   686→        metadata,\n   687→    };\n   688→\n   689→    // Store cleaned state and track temp file for cleanup\n   690→    {\n   691→        let mut s = state.write().await;\n   692→        s.temp_paths.push(output_path);\n   693→        s.cleaned_buffer = Some(cleaned_buffer);\n   694→        s.cleaned_file_path = Some(output_path_str);\n   695→        s.cleaned_format = Some(cleaned_fmt.to_string());\n   696→    }\n   697→\n   698→    Ok(Json(CleanResponse {\n   699→        success: san_result.success,\n   700→        metadata_removed: san_result.metadata_removed,\n   701→        patterns_found: san_result.patterns_found,\n   702→        patterns_suppressed: san_result.patterns_suppressed,\n   703→        quality_loss: san_result.quality_loss,\n   704→        processing_time: san_result.processing_time,\n   705→        before,\n   706→        after,\n   707→    }))\n   708→}\n   709→\n   710→// --- Serve cleaned audio ---\n   711→\n   712→async fn serve_cleaned_audio(\n   713→    State(state): State<SharedState>,\n   714→) -> Result<Response, (StatusCode, String)> {\n   715→    let state = state.read().await;\n   716→    let file_path = state.cleaned_file_path.as_ref().ok_or((\n   717→        StatusCode::BAD_REQUEST,\n   718→        \"No cleaned file available\".to_string(),\n   719→    ))?;\n   720→\n   721→    let bytes = std::fs::read(file_path).map_err(|e| {\n   722→        (\n   723→            StatusCode::INTERNAL_SERVER_ERROR,\n   724→            format!(\"Read error: {e}\"),\n   725→        )\n   726→    })?;\n   727→\n   728→    let content_type = if file_path.ends_with(\".mp3\") {\n   729→        \"audio/mpeg\"\n   730→    } else {\n   731→        \"audio/wav\"\n   732→    };\n   733→\n   734→    Ok(([(header::CONTENT_TYPE, content_type)], bytes).into_response())\n   735→}\n   736→\n   737→// --- Cleaned waveform endpoint ---\n   738→\n   739→async fn get_cleaned_waveform(\n   740→    State(state): State<SharedState>,\n   741→    Query(query): Query<WaveformQuery>,\n   742→) -> Result<Json<WaveformData>, (StatusCode, String)> {\n   743→    let state = state.read().await;\n   744→    let buffer = state.cleaned_buffer.as_ref().ok_or((\n   745→        StatusCode::BAD_REQUEST,\n   746→        \"No cleaned file available\".to_string(),\n   747→    ))?;\n   748→\n   749→    let samples = buffer.to_mono_samples();\n   750→    let sr = buffer.sample_rate as f64;\n   751→    let total_samples = samples.len();\n   752→    let duration_secs = total_samples as f64 / sr;\n   753→\n   754→    let start_sec = query.start.unwrap_or(0.0).max(0.0);\n   755→    let end_sec = query.end.unwrap_or(duration_secs).min(duration_secs);\n   756→    let start_idx = (start_sec * sr) as usize;\n   757→    let end_idx = ((end_sec * sr) as usize).min(total_samples);\n   758→\n   759→    if start_idx >= end_idx {\n   760→        return Err((StatusCode::BAD_REQUEST, \"Invalid time range\".to_string()));\n   761→    }\n   762→\n   763→    let slice = &samples[start_idx..end_idx];\n   764→    let width = query.width.unwrap_or(1024).max(1);\n   765→    let chunk_size = (slice.len() / width).max(1);\n   766→\n   767→    let mut min_vals = Vec::with_capacity(width);\n   768→    let mut max_vals = Vec::with_capacity(width);\n   769→\n   770→    for chunk in slice.chunks(chunk_size) {\n   771→        let mut lo = f32::MAX;\n   772→        let mut hi = f32::MIN;\n   773→        for &s in chunk {\n   774→            if s < lo {\n   775→                lo = s;\n   776→            }\n   777→            if s > hi {\n   778→                hi = s;\n   779→            }\n   780→        }\n   781→        min_vals.push(lo);\n   782→        max_vals.push(hi);\n   783→    }\n   784→\n   785→    Ok(Json(WaveformData {\n   786→        min: min_vals,\n   787→        max: max_vals,\n   788→        sample_rate: buffer.sample_rate,\n   789→        duration_secs,\n   790→        channels: buffer.num_channels(),\n   791→    }))\n   792→}\n   793→\n   794→// --- Cleaned spectrogram endpoint ---\n   795→\n   796→async fn get_cleaned_spectrogram(\n   797→    State(state): State<SharedState>,\n   798→    Query(query): Query<SpectrogramQuery>,\n   799→) -> Result<Json<SpectrogramData>, (StatusCode, String)> {\n   800→    let state = state.read().await;\n   801→    let buffer = state.cleaned_buffer.as_ref().ok_or((\n   802→        StatusCode::BAD_REQUEST,\n   803→        \"No cleaned file available\".to_string(),\n   804→    ))?;\n   805→    compute_spectrogram(buffer, &query).map(Json)\n   806→}\n   807→\n   808→// --- Save/download cleaned file ---\n   809→\n   810→async fn save_cleaned_file(\n   811→    State(state): State<SharedState>,\n   812→) -> Result<Response, (StatusCode, String)> {\n   813→    let state = state.read().await;\n   814→    let file_path = state.cleaned_file_path.as_ref().ok_or((\n   815→        StatusCode::BAD_REQUEST,\n   816→        \"No cleaned file available\".to_string(),\n   817→    ))?;\n   818→\n   819→    let bytes = std::fs::read(file_path).map_err(|e| {\n   820→        (\n   821→            StatusCode::INTERNAL_SERVER_ERROR,\n   822→            format!(\"Read error: {e}\"),\n   823→        )\n   824→    })?;\n   825→\n   826→    let ext = if file_path.ends_with(\".mp3\") {\n   827→        \"mp3\"\n   828→    } else {\n   829→        \"wav\"\n   830→    };\n   831→\n   832→    let filename = format!(\"cleaned_output.{ext}\");\n   833→    let content_type = if ext == \"mp3\" {\n   834→        \"audio/mpeg\"\n   835→    } else {\n   836→        \"audio/wav\"\n   837→    };\n   838→\n   839→    Ok((\n   840→        [\n   841→            (header::CONTENT_TYPE, content_type),\n   842→            (\n   843→                header::CONTENT_DISPOSITION,\n   844→                &format!(\"attachment; filename=\\\"{filename}\\\"\"),\n   845→            ),\n   846→        ],\n   847→        bytes,\n   848→    )\n   849→        .into_response())\n   850→}\n   851→"}]},"parent_tool_use_id":null,"session_id":"25366dd4-3fbf-4b97-9824-3bd39fcc08ab","uuid":"e5d44799-4c73-4a8d-8390-df44e29ed604","tool_use_result":{"type":"text","file":{"filePath":"/Users/captain/code/github.com/polez/src/gui/routes.rs","content":"use axum::extract::DefaultBodyLimit;\nuse axum::{\n    extract::{Multipart, Query, State},\n    http::{header, StatusCode},\n    response::{IntoResponse, Response},\n    routing::{get, post},\n    Json, Router,\n};\nuse rustfft::num_complex::Complex64;\nuse rustfft::FftPlanner;\nuse serde::Deserialize;\nuse std::io::Write;\nuse std::path::Path;\nuse tower_http::cors::{Any, CorsLayer};\n\nuse crate::config::{defaults::default_config, AdvancedFlags};\nuse crate::detection::{MetadataScanner, PolezDetector, StatisticalAnalyzer, WatermarkDetector};\nuse crate::sanitization::pipeline::SanitizationMode;\nuse crate::sanitization::SanitizationPipeline;\n\nuse super::types::{\n    AllAnalysisResult, BitPlaneData, CleanRequest, CleanResponse, FileInfo, PlaneSummary,\n    SpectrogramData, WaveformData,\n};\nuse super::SharedState;\n\npub fn create_router(state: SharedState) -> Router {\n    let cors = CorsLayer::new()\n        .allow_origin(Any)\n        .allow_methods(Any)\n        .allow_headers(Any);\n\n    Router::new()\n        .route(\"/api/health\", get(health))\n        .route(\"/api/limits\", get(get_limits))\n        .route(\"/api/load\", post(load_file))\n        .route(\"/api/upload\", post(upload_file))\n        .route(\"/api/waveform\", get(get_waveform))\n        .route(\"/api/spectrogram\", get(get_spectrogram))\n        .route(\"/api/bitplane\", get(get_bitplane))\n        .route(\"/api/audio\", get(serve_audio))\n        .route(\"/api/analyze/watermark\", post(analyze_watermark))\n        .route(\"/api/analyze/polez\", post(analyze_polez))\n        .route(\"/api/analyze/statistical\", post(analyze_statistical))\n        .route(\"/api/analyze/metadata\", post(analyze_metadata))\n        .route(\"/api/analyze/all\", post(analyze_all))\n        .route(\"/api/clean\", post(clean_file))\n        .route(\"/api/audio/cleaned\", get(serve_cleaned_audio))\n        .route(\"/api/waveform/cleaned\", get(get_cleaned_waveform))\n        .route(\"/api/spectrogram/cleaned\", get(get_cleaned_spectrogram))\n        .route(\"/api/save\", post(save_cleaned_file))\n        .fallback(get(static_handler))\n        .layer(DefaultBodyLimit::max(MAX_UPLOAD_BYTES))\n        .layer(cors)\n        .with_state(state)\n}\n\nasync fn static_handler(uri: axum::http::Uri) -> Response {\n    let path = uri.path().trim_start_matches('/');\n    let path = if path.is_empty() { \"index.html\" } else { path };\n\n    match super::Assets::get(path) {\n        Some(content) => {\n            let mime = mime_guess::from_path(path).first_or_octet_stream();\n            (\n                [(header::CONTENT_TYPE, mime.as_ref())],\n                content.data.to_vec(),\n            )\n                .into_response()\n        }\n        None => {\n            // SPA fallback: serve index.html for all non-API routes\n            match super::Assets::get(\"index.html\") {\n                Some(content) => {\n                    ([(header::CONTENT_TYPE, \"text/html\")], content.data.to_vec()).into_response()\n                }\n                None => (StatusCode::NOT_FOUND, \"Not found\").into_response(),\n            }\n        }\n    }\n}\n\nasync fn health() -> &'static str {\n    \"ok\"\n}\n\nconst MAX_UPLOAD_BYTES: usize = 500 * 1024 * 1024; // 500MB\n\nasync fn get_limits() -> Json<serde_json::Value> {\n    Json(serde_json::json!({\n        \"max_upload_bytes\": MAX_UPLOAD_BYTES,\n        \"supported_formats\": [\"wav\", \"mp3\", \"flac\", \"aac\", \"m4a\"]\n    }))\n}\n\n#[derive(Deserialize)]\nstruct LoadRequest {\n    path: String,\n}\n\nasync fn load_file(\n    State(state): State<SharedState>,\n    Json(req): Json<LoadRequest>,\n) -> Result<Json<FileInfo>, (StatusCode, String)> {\n    let path = Path::new(&req.path);\n\n    if !path.exists() {\n        return Err((\n            StatusCode::NOT_FOUND,\n            format!(\"File not found: {}\", req.path),\n        ));\n    }\n\n    let (buffer, format) = crate::audio::load_audio(path).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Load error: {e}\"),\n        )\n    })?;\n\n    let info = FileInfo {\n        file_path: req.path.clone(),\n        format: format.to_string(),\n        duration_secs: buffer.duration_secs(),\n        sample_rate: buffer.sample_rate,\n        channels: buffer.num_channels(),\n    };\n\n    let mut state = state.write().await;\n    state.file_path = Some(req.path);\n    state.format = Some(info.format.clone());\n    state.buffer = Some(buffer);\n\n    Ok(Json(info))\n}\n\nasync fn upload_file(\n    State(state): State<SharedState>,\n    mut multipart: Multipart,\n) -> Result<Json<FileInfo>, (StatusCode, String)> {\n    let field = multipart\n        .next_field()\n        .await\n        .map_err(|e| (StatusCode::BAD_REQUEST, format!(\"Multipart error: {e}\")))?\n        .ok_or((StatusCode::BAD_REQUEST, \"No file field found\".to_string()))?;\n\n    let file_name = field.file_name().unwrap_or(\"upload.wav\").to_string();\n\n    let ext = Path::new(&file_name)\n        .extension()\n        .and_then(|e| e.to_str())\n        .unwrap_or(\"wav\");\n\n    let mut tmp = tempfile::Builder::new()\n        .suffix(&format!(\".{ext}\"))\n        .tempfile()\n        .map_err(|e| {\n            (\n                StatusCode::INTERNAL_SERVER_ERROR,\n                format!(\"Temp file error: {e}\"),\n            )\n        })?;\n\n    let bytes = field\n        .bytes()\n        .await\n        .map_err(|e| (StatusCode::BAD_REQUEST, format!(\"Read error: {e}\")))?;\n\n    tmp.write_all(&bytes).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Write error: {e}\"),\n        )\n    })?;\n\n    let tmp_path = tmp.into_temp_path();\n    let persisted_path = tmp_path.to_path_buf();\n    // Keep the file on disk by persisting the TempPath (consumes it without deleting)\n    tmp_path.keep().map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Temp path persist error: {e}\"),\n        )\n    })?;\n    let path_str = persisted_path.to_string_lossy().to_string();\n\n    let (buffer, format) = crate::audio::load_audio(&persisted_path).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Load error: {e}\"),\n        )\n    })?;\n\n    let info = FileInfo {\n        file_path: file_name,\n        format: format.to_string(),\n        duration_secs: buffer.duration_secs(),\n        sample_rate: buffer.sample_rate,\n        channels: buffer.num_channels(),\n    };\n\n    let mut app_state = state.write().await;\n    app_state.temp_paths.push(persisted_path);\n    app_state.file_path = Some(path_str);\n    app_state.format = Some(info.format.clone());\n    app_state.buffer = Some(buffer);\n\n    Ok(Json(info))\n}\n\n// --- Analysis endpoints ---\n\nasync fn analyze_watermark(\n    State(state): State<SharedState>,\n) -> Result<Json<serde_json::Value>, (StatusCode, String)> {\n    let state = state.read().await;\n    let buffer = state\n        .buffer\n        .as_ref()\n        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n    let result = WatermarkDetector::detect_all(buffer);\n    let value = serde_json::to_value(result).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Serialization error: {e}\"),\n        )\n    })?;\n    Ok(Json(value))\n}\n\nasync fn analyze_polez(\n    State(state): State<SharedState>,\n) -> Result<Json<serde_json::Value>, (StatusCode, String)> {\n    let state = state.read().await;\n    let buffer = state\n        .buffer\n        .as_ref()\n        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n    let result = PolezDetector::detect(buffer);\n    let value = serde_json::to_value(result).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Serialization error: {e}\"),\n        )\n    })?;\n    Ok(Json(value))\n}\n\nasync fn analyze_statistical(\n    State(state): State<SharedState>,\n) -> Result<Json<serde_json::Value>, (StatusCode, String)> {\n    let state = state.read().await;\n    let buffer = state\n        .buffer\n        .as_ref()\n        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n    let result = StatisticalAnalyzer::analyze(buffer);\n    let value = serde_json::to_value(result).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Serialization error: {e}\"),\n        )\n    })?;\n    Ok(Json(value))\n}\n\nasync fn analyze_metadata(\n    State(state): State<SharedState>,\n) -> Result<Json<serde_json::Value>, (StatusCode, String)> {\n    let state = state.read().await;\n    let file_path = state\n        .file_path\n        .as_ref()\n        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n    let result = MetadataScanner::scan(Path::new(file_path)).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Scan error: {e}\"),\n        )\n    })?;\n    let value = serde_json::to_value(result).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Serialization error: {e}\"),\n        )\n    })?;\n    Ok(Json(value))\n}\n\nasync fn analyze_all(\n    State(state): State<SharedState>,\n) -> Result<Json<AllAnalysisResult>, (StatusCode, String)> {\n    let state = state.read().await;\n    let buffer = state\n        .buffer\n        .as_ref()\n        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n    let file_path = state\n        .file_path\n        .as_ref()\n        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n\n    let watermark = WatermarkDetector::detect_all(buffer);\n    let polez = PolezDetector::detect(buffer);\n    let statistical = StatisticalAnalyzer::analyze(buffer);\n    let metadata = MetadataScanner::scan(Path::new(file_path)).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Scan error: {e}\"),\n        )\n    })?;\n\n    Ok(Json(AllAnalysisResult {\n        watermark,\n        polez,\n        statistical,\n        metadata,\n    }))\n}\n\n// --- Waveform endpoint ---\n\n#[derive(Deserialize)]\nstruct WaveformQuery {\n    width: Option<usize>,\n    start: Option<f64>,\n    end: Option<f64>,\n}\n\nasync fn get_waveform(\n    State(state): State<SharedState>,\n    Query(query): Query<WaveformQuery>,\n) -> Result<Json<WaveformData>, (StatusCode, String)> {\n    let state = state.read().await;\n    let buffer = state\n        .buffer\n        .as_ref()\n        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n\n    let samples = buffer.to_mono_samples();\n    let sr = buffer.sample_rate as f64;\n    let total_samples = samples.len();\n    let duration_secs = total_samples as f64 / sr;\n\n    let start_sec = query.start.unwrap_or(0.0).max(0.0);\n    let end_sec = query.end.unwrap_or(duration_secs).min(duration_secs);\n    let start_idx = (start_sec * sr) as usize;\n    let end_idx = ((end_sec * sr) as usize).min(total_samples);\n\n    if start_idx >= end_idx {\n        return Err((StatusCode::BAD_REQUEST, \"Invalid time range\".to_string()));\n    }\n\n    let slice = &samples[start_idx..end_idx];\n    let width = query.width.unwrap_or(1024).max(1);\n    let chunk_size = (slice.len() / width).max(1);\n\n    let mut min_vals = Vec::with_capacity(width);\n    let mut max_vals = Vec::with_capacity(width);\n\n    for chunk in slice.chunks(chunk_size) {\n        let mut lo = f32::MAX;\n        let mut hi = f32::MIN;\n        for &s in chunk {\n            if s < lo {\n                lo = s;\n            }\n            if s > hi {\n                hi = s;\n            }\n        }\n        min_vals.push(lo);\n        max_vals.push(hi);\n    }\n\n    Ok(Json(WaveformData {\n        min: min_vals,\n        max: max_vals,\n        sample_rate: buffer.sample_rate,\n        duration_secs,\n        channels: buffer.num_channels(),\n    }))\n}\n\n// --- Spectrogram endpoint ---\n\n#[derive(Deserialize)]\nstruct SpectrogramQuery {\n    fft_size: Option<usize>,\n    freq_min: Option<f64>,\n    freq_max: Option<f64>,\n    start: Option<f64>,\n    duration: Option<f64>,\n}\n\nfn compute_spectrogram(\n    buffer: &crate::audio::AudioBuffer,\n    query: &SpectrogramQuery,\n) -> Result<SpectrogramData, (StatusCode, String)> {\n    let samples = buffer.to_mono_samples();\n    let sr = buffer.sample_rate as f64;\n    let total_duration = samples.len() as f64 / sr;\n\n    let fft_size = query.fft_size.unwrap_or(2048);\n    let hop = fft_size / 4;\n    let freq_min = query.freq_min.unwrap_or(0.0);\n    let freq_max = query.freq_max.unwrap_or(sr / 2.0);\n    let start_sec = query.start.unwrap_or(0.0).max(0.0);\n    let dur = query.duration.unwrap_or(total_duration - start_sec);\n    let end_sec = (start_sec + dur).min(total_duration);\n\n    let start_idx = (start_sec * sr) as usize;\n    let end_idx = ((end_sec * sr) as usize).min(samples.len());\n\n    if start_idx >= end_idx || end_idx - start_idx < fft_size {\n        return Err((\n            StatusCode::BAD_REQUEST,\n            \"Not enough samples for FFT\".to_string(),\n        ));\n    }\n\n    let slice = &samples[start_idx..end_idx];\n\n    // Build Hann window\n    let window: Vec<f64> = (0..fft_size)\n        .map(|i| {\n            0.5 * (1.0 - (2.0 * std::f64::consts::PI * i as f64 / (fft_size as f64 - 1.0)).cos())\n        })\n        .collect();\n\n    let mut planner = FftPlanner::<f64>::new();\n    let fft = planner.plan_fft_forward(fft_size);\n\n    // Frequency bin indices for the requested range\n    let bin_min = ((freq_min * fft_size as f64 / sr).floor() as usize).min(fft_size / 2);\n    let bin_max = ((freq_max * fft_size as f64 / sr).ceil() as usize).min(fft_size / 2);\n    let num_freq_bins = bin_max - bin_min;\n\n    if num_freq_bins == 0 {\n        return Err((\n            StatusCode::BAD_REQUEST,\n            \"Invalid frequency range\".to_string(),\n        ));\n    }\n\n    let mut magnitudes: Vec<Vec<f64>> = Vec::new();\n\n    let mut pos = 0;\n    while pos + fft_size <= slice.len() {\n        let mut fft_buf: Vec<Complex64> = slice[pos..pos + fft_size]\n            .iter()\n            .enumerate()\n            .map(|(i, &s)| Complex64::new(s as f64 * window[i], 0.0))\n            .collect();\n\n        fft.process(&mut fft_buf);\n\n        let frame: Vec<f64> = (bin_min..bin_max)\n            .map(|bin| {\n                let mag = fft_buf[bin].norm();\n                let db = 20.0 * mag.max(1e-12).log10();\n                db.max(-120.0)\n            })\n            .collect();\n\n        magnitudes.push(frame);\n        pos += hop;\n    }\n\n    let num_time_frames = magnitudes.len();\n\n    Ok(SpectrogramData {\n        magnitudes,\n        freq_min,\n        freq_max,\n        time_start: start_sec,\n        time_end: end_sec,\n        num_freq_bins,\n        num_time_frames,\n    })\n}\n\nasync fn get_spectrogram(\n    State(state): State<SharedState>,\n    Query(query): Query<SpectrogramQuery>,\n) -> Result<Json<SpectrogramData>, (StatusCode, String)> {\n    let state = state.read().await;\n    let buffer = state\n        .buffer\n        .as_ref()\n        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n    compute_spectrogram(buffer, &query).map(Json)\n}\n\n// --- Bitplane endpoint ---\n\nasync fn get_bitplane(\n    State(state): State<SharedState>,\n) -> Result<Json<BitPlaneData>, (StatusCode, String)> {\n    let state = state.read().await;\n    let buffer = state\n        .buffer\n        .as_ref()\n        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n\n    let samples = buffer.to_mono_samples();\n    let total = samples.len() as f64;\n\n    let planes: Vec<PlaneSummary> = (0..8u8)\n        .map(|bit| {\n            let mut ones = 0u64;\n            for &s in &samples {\n                let val = (s * 32767.0) as i16;\n                if (val >> bit) & 1 == 1 {\n                    ones += 1;\n                }\n            }\n            let ones_ratio = ones as f64 / total;\n            let bias = (ones_ratio - 0.5).abs();\n            PlaneSummary {\n                bit,\n                ones_ratio,\n                bias,\n            }\n        })\n        .collect();\n\n    Ok(Json(BitPlaneData { planes }))\n}\n\n// --- Audio serving endpoint ---\n\nasync fn serve_audio(State(state): State<SharedState>) -> Result<Response, (StatusCode, String)> {\n    let state = state.read().await;\n    let file_path = state\n        .file_path\n        .as_ref()\n        .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n\n    let bytes = std::fs::read(file_path).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Read error: {e}\"),\n        )\n    })?;\n\n    let content_type = if file_path.ends_with(\".mp3\") {\n        \"audio/mpeg\"\n    } else {\n        \"audio/wav\"\n    };\n\n    Ok(([(header::CONTENT_TYPE, content_type)], bytes).into_response())\n}\n\n// --- Clean endpoint ---\n\nasync fn clean_file(\n    State(state): State<SharedState>,\n    Json(req): Json<CleanRequest>,\n) -> Result<Json<CleanResponse>, (StatusCode, String)> {\n    let mode = match req.mode.as_deref().unwrap_or(\"standard\") {\n        \"fast\" => SanitizationMode::Fast,\n        \"standard\" => SanitizationMode::Standard,\n        \"preserving\" => SanitizationMode::Preserving,\n        \"aggressive\" => SanitizationMode::Aggressive,\n        other => return Err((StatusCode::BAD_REQUEST, format!(\"Unknown mode: {other}\"))),\n    };\n\n    // Read source info from state\n    let (file_path, format_str) = {\n        let s = state.read().await;\n        let fp = s\n            .file_path\n            .clone()\n            .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n        let fmt = s\n            .format\n            .clone()\n            .ok_or((StatusCode::BAD_REQUEST, \"No file loaded\".to_string()))?;\n        (fp, fmt)\n    };\n\n    let ext = if format_str == \"mp3\" { \"mp3\" } else { \"wav\" };\n\n    // Create temp output file\n    let tmp = tempfile::Builder::new()\n        .suffix(&format!(\"_cleaned.{ext}\"))\n        .tempfile()\n        .map_err(|e| {\n            (\n                StatusCode::INTERNAL_SERVER_ERROR,\n                format!(\"Temp file error: {e}\"),\n            )\n        })?;\n    let tmp_path = tmp.into_temp_path();\n    let output_path = tmp_path.to_path_buf();\n    // Keep the file on disk; track for cleanup when state is dropped\n    tmp_path.keep().map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Temp path persist error: {e}\"),\n        )\n    })?;\n\n    let input_path = std::path::PathBuf::from(&file_path);\n    let out = output_path.clone();\n\n    // Run sanitization in blocking thread (CPU-bound)\n    let san_result = tokio::task::spawn_blocking(move || {\n        let cfg = default_config();\n        let pipeline = SanitizationPipeline::new(\n            mode,\n            false,\n            AdvancedFlags::default(),\n            cfg.fingerprint_removal,\n            None,\n        );\n        pipeline.run(&input_path, &out)\n    })\n    .await\n    .map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Task join error: {e}\"),\n        )\n    })?\n    .map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Sanitization error: {e}\"),\n        )\n    })?;\n\n    // Load cleaned audio\n    let (cleaned_buffer, cleaned_fmt) = crate::audio::load_audio(&output_path).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Load cleaned error: {e}\"),\n        )\n    })?;\n\n    // Run detection on original (before)\n    let before = {\n        let s = state.read().await;\n        let buf = s.buffer.as_ref().ok_or((\n            StatusCode::INTERNAL_SERVER_ERROR,\n            \"Original buffer no longer available\".to_string(),\n        ))?;\n        let fp = s.file_path.as_ref().ok_or((\n            StatusCode::INTERNAL_SERVER_ERROR,\n            \"Original file path no longer available\".to_string(),\n        ))?;\n        let watermark = WatermarkDetector::detect_all(buf);\n        let polez = PolezDetector::detect(buf);\n        let statistical = StatisticalAnalyzer::analyze(buf);\n        let metadata = MetadataScanner::scan(Path::new(fp)).map_err(|e| {\n            (\n                StatusCode::INTERNAL_SERVER_ERROR,\n                format!(\"Scan error: {e}\"),\n            )\n        })?;\n        AllAnalysisResult {\n            watermark,\n            polez,\n            statistical,\n            metadata,\n        }\n    };\n\n    // Run detection on cleaned (after)\n    let output_path_str = output_path.to_string_lossy().to_string();\n    let watermark = WatermarkDetector::detect_all(&cleaned_buffer);\n    let polez_result = PolezDetector::detect(&cleaned_buffer);\n    let statistical = StatisticalAnalyzer::analyze(&cleaned_buffer);\n    let metadata = MetadataScanner::scan(&output_path).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Scan error: {e}\"),\n        )\n    })?;\n    let after = AllAnalysisResult {\n        watermark,\n        polez: polez_result,\n        statistical,\n        metadata,\n    };\n\n    // Store cleaned state and track temp file for cleanup\n    {\n        let mut s = state.write().await;\n        s.temp_paths.push(output_path);\n        s.cleaned_buffer = Some(cleaned_buffer);\n        s.cleaned_file_path = Some(output_path_str);\n        s.cleaned_format = Some(cleaned_fmt.to_string());\n    }\n\n    Ok(Json(CleanResponse {\n        success: san_result.success,\n        metadata_removed: san_result.metadata_removed,\n        patterns_found: san_result.patterns_found,\n        patterns_suppressed: san_result.patterns_suppressed,\n        quality_loss: san_result.quality_loss,\n        processing_time: san_result.processing_time,\n        before,\n        after,\n    }))\n}\n\n// --- Serve cleaned audio ---\n\nasync fn serve_cleaned_audio(\n    State(state): State<SharedState>,\n) -> Result<Response, (StatusCode, String)> {\n    let state = state.read().await;\n    let file_path = state.cleaned_file_path.as_ref().ok_or((\n        StatusCode::BAD_REQUEST,\n        \"No cleaned file available\".to_string(),\n    ))?;\n\n    let bytes = std::fs::read(file_path).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Read error: {e}\"),\n        )\n    })?;\n\n    let content_type = if file_path.ends_with(\".mp3\") {\n        \"audio/mpeg\"\n    } else {\n        \"audio/wav\"\n    };\n\n    Ok(([(header::CONTENT_TYPE, content_type)], bytes).into_response())\n}\n\n// --- Cleaned waveform endpoint ---\n\nasync fn get_cleaned_waveform(\n    State(state): State<SharedState>,\n    Query(query): Query<WaveformQuery>,\n) -> Result<Json<WaveformData>, (StatusCode, String)> {\n    let state = state.read().await;\n    let buffer = state.cleaned_buffer.as_ref().ok_or((\n        StatusCode::BAD_REQUEST,\n        \"No cleaned file available\".to_string(),\n    ))?;\n\n    let samples = buffer.to_mono_samples();\n    let sr = buffer.sample_rate as f64;\n    let total_samples = samples.len();\n    let duration_secs = total_samples as f64 / sr;\n\n    let start_sec = query.start.unwrap_or(0.0).max(0.0);\n    let end_sec = query.end.unwrap_or(duration_secs).min(duration_secs);\n    let start_idx = (start_sec * sr) as usize;\n    let end_idx = ((end_sec * sr) as usize).min(total_samples);\n\n    if start_idx >= end_idx {\n        return Err((StatusCode::BAD_REQUEST, \"Invalid time range\".to_string()));\n    }\n\n    let slice = &samples[start_idx..end_idx];\n    let width = query.width.unwrap_or(1024).max(1);\n    let chunk_size = (slice.len() / width).max(1);\n\n    let mut min_vals = Vec::with_capacity(width);\n    let mut max_vals = Vec::with_capacity(width);\n\n    for chunk in slice.chunks(chunk_size) {\n        let mut lo = f32::MAX;\n        let mut hi = f32::MIN;\n        for &s in chunk {\n            if s < lo {\n                lo = s;\n            }\n            if s > hi {\n                hi = s;\n            }\n        }\n        min_vals.push(lo);\n        max_vals.push(hi);\n    }\n\n    Ok(Json(WaveformData {\n        min: min_vals,\n        max: max_vals,\n        sample_rate: buffer.sample_rate,\n        duration_secs,\n        channels: buffer.num_channels(),\n    }))\n}\n\n// --- Cleaned spectrogram endpoint ---\n\nasync fn get_cleaned_spectrogram(\n    State(state): State<SharedState>,\n    Query(query): Query<SpectrogramQuery>,\n) -> Result<Json<SpectrogramData>, (StatusCode, String)> {\n    let state = state.read().await;\n    let buffer = state.cleaned_buffer.as_ref().ok_or((\n        StatusCode::BAD_REQUEST,\n        \"No cleaned file available\".to_string(),\n    ))?;\n    compute_spectrogram(buffer, &query).map(Json)\n}\n\n// --- Save/download cleaned file ---\n\nasync fn save_cleaned_file(\n    State(state): State<SharedState>,\n) -> Result<Response, (StatusCode, String)> {\n    let state = state.read().await;\n    let file_path = state.cleaned_file_path.as_ref().ok_or((\n        StatusCode::BAD_REQUEST,\n        \"No cleaned file available\".to_string(),\n    ))?;\n\n    let bytes = std::fs::read(file_path).map_err(|e| {\n        (\n            StatusCode::INTERNAL_SERVER_ERROR,\n            format!(\"Read error: {e}\"),\n        )\n    })?;\n\n    let ext = if file_path.ends_with(\".mp3\") {\n        \"mp3\"\n    } else {\n        \"wav\"\n    };\n\n    let filename = format!(\"cleaned_output.{ext}\");\n    let content_type = if ext == \"mp3\" {\n        \"audio/mpeg\"\n    } else {\n        \"audio/wav\"\n    };\n\n    Ok((\n        [\n            (header::CONTENT_TYPE, content_type),\n            (\n                header::CONTENT_DISPOSITION,\n                &format!(\"attachment; filename=\\\"{filename}\\\"\"),\n            ),\n        ],\n        bytes,\n    )\n        .into_response())\n}\n","numLines":851,"startLine":1,"totalLines":851}}}
