{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019oSFDCmk83j4eYNSV2jiZm","type":"tool_result","content":"     1→import { useState } from 'react';\n     2→import { cleanFile, saveCleanedFile } from '../api/client';\n     3→import type { CleanResponse } from '../api/client';\n     4→\n     5→interface Props {\n     6→  fileLoaded: boolean;\n     7→  onCleaned?: (result: CleanResponse) => void;\n     8→}\n     9→\n    10→function ConfidenceBar({ label, value, max = 1 }: { label: string; value: number; max?: number }) {\n    11→  const pct = (value / max) * 100;\n    12→  const color = pct > 70 ? 'bg-red-500' : pct > 40 ? 'bg-yellow-500' : 'bg-green-500';\n    13→\n    14→  return (\n    15→    <div className=\"mb-2\">\n    16→      <div className=\"flex justify-between text-sm mb-1\">\n    17→        <span className=\"text-zinc-300\">{label}</span>\n    18→        <span className=\"text-zinc-400\">{pct.toFixed(1)}%</span>\n    19→      </div>\n    20→      <div className=\"h-2 bg-zinc-700 rounded-full overflow-hidden\">\n    21→        <div className={`h-full ${color} rounded-full`} style={{ width: `${pct}%` }} />\n    22→      </div>\n    23→    </div>\n    24→  );\n    25→}\n    26→\n    27→function DetectionColumn({ title, data }: { title: string; data: any }) {\n    28→  if (!data) return null;\n    29→  return (\n    30→    <div className=\"flex-1 min-w-0\">\n    31→      <h4 className=\"text-xs font-medium text-zinc-400 mb-2 uppercase\">{title}</h4>\n    32→      {data.watermark && (\n    33→        <ConfidenceBar label=\"Watermark\" value={data.watermark.overall_confidence} />\n    34→      )}\n    35→      {data.polez && (\n    36→        <ConfidenceBar label=\"AI Watermark\" value={data.polez.detection_probability} />\n    37→      )}\n    38→      {data.statistical && (\n    39→        <ConfidenceBar label=\"AI Probability\" value={data.statistical.ai_probability} />\n    40→      )}\n    41→      {data.metadata && (\n    42→        <div className=\"text-sm text-zinc-300 mb-2\">\n    43→          Metadata: {data.metadata.tags.length} tags, {data.metadata.suspicious_chunks.length} suspicious\n    44→        </div>\n    45→      )}\n    46→    </div>\n    47→  );\n    48→}\n    49→\n    50→export function CleanPanel({ fileLoaded, onCleaned }: Props) {\n    51→  const [mode, setMode] = useState('standard');\n    52→  const [loading, setLoading] = useState(false);\n    53→  const [saving, setSaving] = useState(false);\n    54→  const [result, setResult] = useState<CleanResponse | null>(null);\n    55→  const [error, setError] = useState<string | null>(null);\n    56→\n    57→  const handleClean = async () => {\n    58→    setLoading(true);\n    59→    setError(null);\n    60→    try {\n    61→      const res = await cleanFile(mode);\n    62→      setResult(res);\n    63→      onCleaned?.(res);\n    64→    } catch (e: any) {\n    65→      setError(e.message || 'Cleaning failed');\n    66→    } finally {\n    67→      setLoading(false);\n    68→    }\n    69→  };\n    70→\n    71→  const handleSave = async () => {\n    72→    setSaving(true);\n    73→    try {\n    74→      await saveCleanedFile();\n    75→    } catch (e: any) {\n    76→      setError(e.message || 'Save failed');\n    77→    } finally {\n    78→      setSaving(false);\n    79→    }\n    80→  };\n    81→\n    82→  return (\n    83→    <div className=\"bg-zinc-900 border border-zinc-700 rounded p-4\">\n    84→      <div className=\"flex items-center justify-between mb-3\">\n    85→        <span className=\"text-zinc-400 text-sm font-medium\">CLEAN</span>\n    86→        <div className=\"flex gap-2 items-center\">\n    87→          <select\n    88→            value={mode}\n    89→            onChange={(e) => setMode(e.target.value)}\n    90→            disabled={loading}\n    91→            className=\"bg-zinc-800 text-zinc-200 border border-zinc-600 rounded px-2 py-1 text-xs\"\n    92→          >\n    93→            <option value=\"fast\">Fast</option>\n    94→            <option value=\"standard\">Standard</option>\n    95→            <option value=\"preserving\">Preserving</option>\n    96→            <option value=\"aggressive\">Aggressive</option>\n    97→          </select>\n    98→          <button\n    99→            onClick={handleClean}\n   100→            disabled={!fileLoaded || loading}\n   101→            className=\"bg-emerald-600 hover:bg-emerald-500 disabled:opacity-50 text-white px-3 py-1 rounded text-xs font-medium\"\n   102→          >\n   103→            {loading ? 'Cleaning...' : 'Clean'}\n   104→          </button>\n   105→          {result && (\n   106→            <button\n   107→              onClick={handleSave}\n   108→              disabled={saving}\n   109→              className=\"bg-blue-600 hover:bg-blue-500 disabled:opacity-50 text-white px-3 py-1 rounded text-xs font-medium\"\n   110→            >\n   111→              {saving ? 'Saving...' : 'Save File'}\n   112→            </button>\n   113→          )}\n   114→        </div>\n   115→      </div>\n   116→\n   117→      {error && (\n   118→        <p className=\"text-red-400 text-sm mb-2\">{error}</p>\n   119→      )}\n   120→\n   121→      {!result && !loading && (\n   122→        <p className=\"text-zinc-500 text-sm\">Select a mode and click Clean to sanitize the loaded file</p>\n   123→      )}\n   124→\n   125→      {loading && (\n   126→        <p className=\"text-zinc-400 text-sm\">Running sanitization pipeline...</p>\n   127→      )}\n   128→\n   129→      {result && (\n   130→        <>\n   131→          <div className=\"flex gap-4 text-xs text-zinc-400 mb-3\">\n   132→            <span>Quality loss: {result.quality_loss.toFixed(2)}%</span>\n   133→            <span>Time: {result.processing_time.toFixed(1)}s</span>\n   134→            <span>Metadata removed: {result.metadata_removed}</span>\n   135→            <span>Patterns: {result.patterns_found} found, {result.patterns_suppressed} suppressed</span>\n   136→          </div>\n   137→\n   138→          <div className=\"flex gap-4\">\n   139→            <DetectionColumn title=\"Before\" data={result.before} />\n   140→            <div className=\"w-px bg-zinc-700\" />\n   141→            <DetectionColumn title=\"After\" data={result.after} />\n   142→          </div>\n   143→        </>\n   144→      )}\n   145→    </div>\n   146→  );\n   147→}\n   148→"}]},"parent_tool_use_id":"toolu_01Y3xoGvFKwwMoz11GENWTqX","session_id":"25366dd4-3fbf-4b97-9824-3bd39fcc08ab","uuid":"1dda87a1-3b51-4026-96fa-d7a90bb8a0c0"}
