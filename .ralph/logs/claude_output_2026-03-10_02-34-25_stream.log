{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Pgncwnk3WsgdukPpsxh3ot","type":"tool_result","content":"     1→import { useState, useRef, useCallback } from 'react';\n     2→import type { FileInfo } from '../api/client';\n     3→import { uploadFile, MAX_UPLOAD_BYTES } from '../api/client';\n     4→\n     5→interface Props {\n     6→  fileInfo: FileInfo | null;\n     7→  onFileLoaded: (info: FileInfo) => void;\n     8→}\n     9→\n    10→function formatBytes(bytes: number): string {\n    11→  if (bytes < 1024) return `${bytes} B`;\n    12→  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;\n    13→  return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;\n    14→}\n    15→\n    16→export function FileHeader({ fileInfo, onFileLoaded }: Props) {\n    17→  const [loading, setLoading] = useState(false);\n    18→  const [progress, setProgress] = useState(0);\n    19→  const [error, setError] = useState<string | null>(null);\n    20→  const [dragOver, setDragOver] = useState(false);\n    21→  const inputRef = useRef<HTMLInputElement>(null);\n    22→\n    23→  const handleFile = useCallback(async (file: File) => {\n    24→    setError(null);\n    25→\n    26→    if (file.size > MAX_UPLOAD_BYTES) {\n    27→      setError(`File too large (${formatBytes(file.size)}). Maximum is ${formatBytes(MAX_UPLOAD_BYTES)}.`);\n    28→      return;\n    29→    }\n    30→\n    31→    setLoading(true);\n    32→    setProgress(0);\n    33→    try {\n    34→      const info = await uploadFile(file, (pct) => setProgress(pct));\n    35→      onFileLoaded(info);\n    36→    } catch (e: unknown) {\n    37→      setError(e instanceof Error ? e.message : String(e));\n    38→    } finally {\n    39→      setLoading(false);\n    40→      setProgress(0);\n    41→    }\n    42→  }, [onFileLoaded]);\n    43→\n    44→  const handleDrop = useCallback((e: React.DragEvent) => {\n    45→    e.preventDefault();\n    46→    setDragOver(false);\n    47→    const file = e.dataTransfer.files[0];\n    48→    if (file) handleFile(file);\n    49→  }, [handleFile]);\n    50→\n    51→  const handleDragOver = useCallback((e: React.DragEvent) => {\n    52→    e.preventDefault();\n    53→    setDragOver(true);\n    54→  }, []);\n    55→\n    56→  const handleDragLeave = useCallback(() => {\n    57→    setDragOver(false);\n    58→  }, []);\n    59→\n    60→  const handlePickerChange = useCallback((e: React.ChangeEvent<HTMLInputElement>) => {\n    61→    const file = e.target.files?.[0];\n    62→    if (file) handleFile(file);\n    63→  }, [handleFile]);\n    64→\n    65→  const formatDuration = (secs: number) => {\n    66→    const m = Math.floor(secs / 60);\n    67→    const s = Math.floor(secs % 60);\n    68→    return `${m}:${s.toString().padStart(2, '0')}`;\n    69→  };\n    70→\n    71→  if (fileInfo && !loading) {\n    72→    return (\n    73→      <div className=\"flex items-center gap-4 bg-zinc-900 border-b border-zinc-700 px-4 py-3\">\n    74→        <span className=\"text-purple-400 font-bold text-lg tracking-wider\">POLEZ</span>\n    75→        <div className=\"flex items-center gap-4 text-zinc-400 text-sm flex-1\">\n    76→          <span className=\"text-zinc-200 font-medium\">{fileInfo.file_path.split('/').pop()}</span>\n    77→          <span>{fileInfo.format.toUpperCase()}</span>\n    78→          <span>{fileInfo.sample_rate / 1000}kHz</span>\n    79→          <span>{fileInfo.channels}ch</span>\n    80→          <span>{formatDuration(fileInfo.duration_secs)}</span>\n    81→        </div>\n    82→        <button\n    83→          onClick={() => inputRef.current?.click()}\n    84→          className=\"text-zinc-400 hover:text-zinc-200 text-sm\"\n    85→        >\n    86→          Change file\n    87→        </button>\n    88→        <input\n    89→          ref={inputRef}\n    90→          type=\"file\"\n    91→          accept=\"audio/*\"\n    92→          onChange={handlePickerChange}\n    93→          className=\"hidden\"\n    94→        />\n    95→      </div>\n    96→    );\n    97→  }\n    98→\n    99→  return (\n   100→    <div\n   101→      onDrop={handleDrop}\n   102→      onDragOver={handleDragOver}\n   103→      onDragLeave={handleDragLeave}\n   104→      className={`flex flex-col items-center justify-center gap-3 border-2 border-dashed rounded-lg mx-4 my-4 py-12 transition-colors ${\n   105→        dragOver\n   106→          ? 'border-purple-400 bg-purple-500/10'\n   107→          : 'border-zinc-600 bg-zinc-900 hover:border-zinc-500'\n   108→      }`}\n   109→    >\n   110→      <div className=\"text-purple-400 font-bold text-2xl tracking-widest mb-2\">POLEZ</div>\n   111→      <div className=\"text-zinc-500 text-xs mb-4\">Audio Forensics & Sanitization Engine</div>\n   112→      {loading ? (\n   113→        <div className=\"w-64 space-y-2\">\n   114→          <div className=\"text-zinc-400 text-sm text-center\">\n   115→            Uploading... {progress}%\n   116→          </div>\n   117→          <div className=\"w-full bg-zinc-700 rounded-full h-2\">\n   118→            <div\n   119→              className=\"bg-purple-500 h-2 rounded-full transition-all duration-200\"\n   120→              style={{ width: `${progress}%` }}\n   121→            />\n   122→          </div>\n   123→        </div>\n   124→      ) : (\n   125→        <>\n   126→          <div className=\"text-zinc-400 text-sm\">\n   127→            Drag & drop an audio file here\n   128→          </div>\n   129→          <div className=\"text-zinc-500 text-xs\">or</div>\n   130→          <button\n   131→            onClick={() => inputRef.current?.click()}\n   132→            className=\"bg-purple-600 hover:bg-purple-500 text-white px-4 py-1.5 rounded text-sm font-medium\"\n   133→          >\n   134→            Choose File\n   135→          </button>\n   136→          <div className=\"text-zinc-600 text-xs mt-1\">\n   137→            Max {formatBytes(MAX_UPLOAD_BYTES)}\n   138→          </div>\n   139→          <input\n   140→            ref={inputRef}\n   141→            type=\"file\"\n   142→            accept=\"audio/*\"\n   143→            onChange={handlePickerChange}\n   144→            className=\"hidden\"\n   145→          />\n   146→        </>\n   147→      )}\n   148→      {error && <span className=\"text-red-400 text-sm\">{error}</span>}\n   149→    </div>\n   150→  );\n   151→}\n   152→"}]},"parent_tool_use_id":"toolu_01Y3xoGvFKwwMoz11GENWTqX","session_id":"25366dd4-3fbf-4b97-9824-3bd39fcc08ab","uuid":"685cf695-44b0-41c4-b873-34d61b8fbf2e"}
