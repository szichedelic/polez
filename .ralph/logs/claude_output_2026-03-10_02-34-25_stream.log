v>\n        </div>\n        <div>\n          <div className=\"text-xs text-zinc-500 mb-1\">Spectral Similarity</div>\n          <div className=\"text-sm text-zinc-200\">{(v.spectral_similarity * 100).toFixed(1)}%</div>\n        </div>\n        <div>\n          <div className=\"text-xs text-zinc-500 mb-1\">Effectiveness</div>\n          <div className=\"text-sm text-zinc-200\">{v.removal_effectiveness.toFixed(1)}%</div>\n        </div>\n      </div>\n    </div>\n  );\n}\n\nexport function CleanPanel({ fileLoaded, onCleaned }: Props) {"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":363,"cache_read_input_tokens":59045,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":363},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"25366dd4-3fbf-4b97-9824-3bd39fcc08ab","uuid":"f1991c7d-0bb4-4549-87f6-867ed813844f"}
