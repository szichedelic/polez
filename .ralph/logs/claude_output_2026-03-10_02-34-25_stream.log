{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GqeTU37UX2ord2Yd3vvTTf","type":"tool_result","content":"     1→use std::path::Path;\n     2→\n     3→use sha2::{Digest, Sha256};\n     4→\n     5→use crate::audio;\n     6→use crate::detection::{MetadataScanner, WatermarkDetector};\n     7→use crate::error::Result;\n     8→use crate::sanitization::dsp::stats;\n     9→use crate::sanitization::dsp::stft;\n    10→\n    11→/// Verification result comparing before/after sanitization.\n    12→#[derive(Debug, Clone)]\n    13→pub struct VerificationResult {\n    14→    pub original_threats: usize,\n    15→    pub remaining_threats: usize,\n    16→    pub removal_effectiveness: f64,\n    17→    pub hash_different: bool,\n    18→    pub original_hash: String,\n    19→    pub cleaned_hash: String,\n    20→    pub snr_db: f64,\n    21→    pub spectral_similarity: f64,\n    22→    pub quality_score: f64,\n    23→}\n    24→\n    25→/// Verify sanitization by comparing original and cleaned files.\n    26→pub fn verify(original: &Path, cleaned: &Path) -> Result<VerificationResult> {\n    27→    // 1. File hashes\n    28→    let orig_hash = file_hash(original)?;\n    29→    let clean_hash = file_hash(cleaned)?;\n    30→\n    31→    // 2. Metadata scan on both\n    32→    let orig_scan = MetadataScanner::scan(original)?;\n    33→    let clean_scan = MetadataScanner::scan(cleaned)?;\n    34→\n    35→    // 3. Load audio from both\n    36→    let (orig_audio, _) = audio::load_audio(original)?;\n    37→    let (clean_audio, _) = audio::load_audio(cleaned)?;\n    38→\n    39→    // 4. Run watermark detection on both\n    40→    let orig_watermarks = WatermarkDetector::detect_all(&orig_audio);\n    41→    let clean_watermarks = WatermarkDetector::detect_all(&clean_audio);\n    42→\n    43→    // 5. Count threats\n    44→    let original_threats =\n    45→        orig_scan.tags.len() + orig_scan.suspicious_chunks.len() + orig_watermarks.watermark_count;\n    46→\n    47→    let remaining_threats = clean_scan.tags.len()\n    48→        + clean_scan.suspicious_chunks.len()\n    49→        + clean_watermarks.watermark_count;\n    50→\n    51→    // 6. Calculate effectiveness\n    52→    let effectiveness = if original_threats > 0 {\n    53→        ((original_threats.saturating_sub(remaining_threats)) as f64 / original_threats as f64)\n    54→            * 100.0\n    55→    } else {\n    56→        100.0\n    57→    };\n    58→\n    59→    // 7. Calculate SNR\n    60→    let orig_mono = orig_audio.to_mono();\n    61→    let clean_mono = clean_audio.to_mono();\n    62→    let orig_ch: Vec<f32> = orig_mono.channel(0).to_vec();\n    63→    let clean_ch: Vec<f32> = clean_mono.channel(0).to_vec();\n    64→    let snr_db = calculate_snr(&orig_ch, &clean_ch);\n    65→\n    66→    // 8. Calculate spectral similarity\n    67→    let spectral_similarity = calculate_spectral_similarity(&orig_ch, &clean_ch);\n    68→\n    69→    // 9. Quality preservation score\n    70→    let quality_score = quality_preservation_score(snr_db, spectral_similarity);\n    71→\n    72→    Ok(VerificationResult {\n    73→        original_threats,\n    74→        remaining_threats,\n    75→        removal_effectiveness: effectiveness,\n    76→        hash_different: orig_hash != clean_hash,\n    77→        original_hash: orig_hash,\n    78→        cleaned_hash: clean_hash,\n    79→        snr_db,\n    80→        spectral_similarity,\n    81→        quality_score,\n    82→    })\n    83→}\n    84→\n    85→/// Calculate Signal-to-Noise Ratio between original and cleaned audio.\n    86→fn calculate_snr(original: &[f32], cleaned: &[f32]) -> f64 {\n    87→    let min_len = original.len().min(cleaned.len());\n    88→    if min_len == 0 {\n    89→        return 0.0;\n    90→    }\n    91→\n    92→    let mut signal_power = 0.0_f64;\n    93→    let mut noise_power = 0.0_f64;\n    94→\n    95→    for i in 0..min_len {\n    96→        let s = original[i] as f64;\n    97→        let n = (original[i] - cleaned[i]) as f64;\n    98→        signal_power += s * s;\n    99→        noise_power += n * n;\n   100→    }\n   101→\n   102→    signal_power /= min_len as f64;\n   103→    noise_power /= min_len as f64;\n   104→\n   105→    if noise_power > 1e-20 {\n   106→        10.0 * (signal_power / noise_power).log10()\n   107→    } else {\n   108→        f64::INFINITY\n   109→    }\n   110→}\n   111→\n   112→/// Calculate spectral similarity via Pearson correlation of FFT magnitudes.\n   113→fn calculate_spectral_similarity(original: &[f32], cleaned: &[f32]) -> f64 {\n   114→    let min_len = original.len().min(cleaned.len());\n   115→    if min_len < 64 {\n   116→        return 0.0;\n   117→    }\n   118→\n   119→    let orig_fft = stft::real_fft(&original[..min_len]);\n   120→    let clean_fft = stft::real_fft(&cleaned[..min_len]);\n   121→\n   122→    let orig_mag: Vec<f64> = orig_fft.iter().map(|c| c.norm() as f64).collect();\n   123→    let clean_mag: Vec<f64> = clean_fft.iter().map(|c| c.norm() as f64).collect();\n   124→\n   125→    stats::pearson_correlation(&orig_mag, &clean_mag)\n   126→}\n   127→\n   128→/// Compute a quality preservation score from SNR and spectral similarity.\n   129→pub fn quality_preservation_score(snr_db: f64, spectral_similarity: f64) -> f64 {\n   130→    let snr_score = if snr_db > 40.0 {\n   131→        1.0\n   132→    } else if snr_db > 20.0 {\n   133→        0.8\n   134→    } else if snr_db > 10.0 {\n   135→        0.6\n   136→    } else {\n   137→        0.4\n   138→    };\n   139→\n   140→    snr_score * (1.0 + spectral_similarity) / 2.0\n   141→}\n   142→\n   143→/// Determine verdict text and color based on effectiveness and SNR.\n   144→pub fn verdict(effectiveness: f64, snr_db: f64) -> (&'static str, &'static str) {\n   145→    match (effectiveness, snr_db) {\n   146→        (e, s) if e > 90.0 && s > 30.0 => (\"EXCELLENT\", \"green\"),\n   147→        (e, s) if e > 70.0 && s > 20.0 => (\"GOOD\", \"yellow\"),\n   148→        (e, s) if e > 50.0 && s > 10.0 => (\"ACCEPTABLE\", \"yellow\"),\n   149→        _ => (\"POOR\", \"red\"),\n   150→    }\n   151→}\n   152→\n   153→fn file_hash(path: &Path) -> Result<String> {\n   154→    let data = std::fs::read(path)?;\n   155→    let mut hasher = Sha256::new();\n   156→    hasher.update(&data);\n   157→    Ok(format!(\"{:x}\", hasher.finalize()))\n   158→}\n   159→"}]},"parent_tool_use_id":null,"session_id":"25366dd4-3fbf-4b97-9824-3bd39fcc08ab","uuid":"5ba74e5b-6027-4342-97d5-50abc89b9af5","tool_use_result":{"type":"text","file":{"filePath":"/Users/captain/code/github.com/polez/src/verification/mod.rs","content":"use std::path::Path;\n\nuse sha2::{Digest, Sha256};\n\nuse crate::audio;\nuse crate::detection::{MetadataScanner, WatermarkDetector};\nuse crate::error::Result;\nuse crate::sanitization::dsp::stats;\nuse crate::sanitization::dsp::stft;\n\n/// Verification result comparing before/after sanitization.\n#[derive(Debug, Clone)]\npub struct VerificationResult {\n    pub original_threats: usize,\n    pub remaining_threats: usize,\n    pub removal_effectiveness: f64,\n    pub hash_different: bool,\n    pub original_hash: String,\n    pub cleaned_hash: String,\n    pub snr_db: f64,\n    pub spectral_similarity: f64,\n    pub quality_score: f64,\n}\n\n/// Verify sanitization by comparing original and cleaned files.\npub fn verify(original: &Path, cleaned: &Path) -> Result<VerificationResult> {\n    // 1. File hashes\n    let orig_hash = file_hash(original)?;\n    let clean_hash = file_hash(cleaned)?;\n\n    // 2. Metadata scan on both\n    let orig_scan = MetadataScanner::scan(original)?;\n    let clean_scan = MetadataScanner::scan(cleaned)?;\n\n    // 3. Load audio from both\n    let (orig_audio, _) = audio::load_audio(original)?;\n    let (clean_audio, _) = audio::load_audio(cleaned)?;\n\n    // 4. Run watermark detection on both\n    let orig_watermarks = WatermarkDetector::detect_all(&orig_audio);\n    let clean_watermarks = WatermarkDetector::detect_all(&clean_audio);\n\n    // 5. Count threats\n    let original_threats =\n        orig_scan.tags.len() + orig_scan.suspicious_chunks.len() + orig_watermarks.watermark_count;\n\n    let remaining_threats = clean_scan.tags.len()\n        + clean_scan.suspicious_chunks.len()\n        + clean_watermarks.watermark_count;\n\n    // 6. Calculate effectiveness\n    let effectiveness = if original_threats > 0 {\n        ((original_threats.saturating_sub(remaining_threats)) as f64 / original_threats as f64)\n            * 100.0\n    } else {\n        100.0\n    };\n\n    // 7. Calculate SNR\n    let orig_mono = orig_audio.to_mono();\n    let clean_mono = clean_audio.to_mono();\n    let orig_ch: Vec<f32> = orig_mono.channel(0).to_vec();\n    let clean_ch: Vec<f32> = clean_mono.channel(0).to_vec();\n    let snr_db = calculate_snr(&orig_ch, &clean_ch);\n\n    // 8. Calculate spectral similarity\n    let spectral_similarity = calculate_spectral_similarity(&orig_ch, &clean_ch);\n\n    // 9. Quality preservation score\n    let quality_score = quality_preservation_score(snr_db, spectral_similarity);\n\n    Ok(VerificationResult {\n        original_threats,\n        remaining_threats,\n        removal_effectiveness: effectiveness,\n        hash_different: orig_hash != clean_hash,\n        original_hash: orig_hash,\n        cleaned_hash: clean_hash,\n        snr_db,\n        spectral_similarity,\n        quality_score,\n    })\n}\n\n/// Calculate Signal-to-Noise Ratio between original and cleaned audio.\nfn calculate_snr(original: &[f32], cleaned: &[f32]) -> f64 {\n    let min_len = original.len().min(cleaned.len());\n    if min_len == 0 {\n        return 0.0;\n    }\n\n    let mut signal_power = 0.0_f64;\n    let mut noise_power = 0.0_f64;\n\n    for i in 0..min_len {\n        let s = original[i] as f64;\n        let n = (original[i] - cleaned[i]) as f64;\n        signal_power += s * s;\n        noise_power += n * n;\n    }\n\n    signal_power /= min_len as f64;\n    noise_power /= min_len as f64;\n\n    if noise_power > 1e-20 {\n        10.0 * (signal_power / noise_power).log10()\n    } else {\n        f64::INFINITY\n    }\n}\n\n/// Calculate spectral similarity via Pearson correlation of FFT magnitudes.\nfn calculate_spectral_similarity(original: &[f32], cleaned: &[f32]) -> f64 {\n    let min_len = original.len().min(cleaned.len());\n    if min_len < 64 {\n        return 0.0;\n    }\n\n    let orig_fft = stft::real_fft(&original[..min_len]);\n    let clean_fft = stft::real_fft(&cleaned[..min_len]);\n\n    let orig_mag: Vec<f64> = orig_fft.iter().map(|c| c.norm() as f64).collect();\n    let clean_mag: Vec<f64> = clean_fft.iter().map(|c| c.norm() as f64).collect();\n\n    stats::pearson_correlation(&orig_mag, &clean_mag)\n}\n\n/// Compute a quality preservation score from SNR and spectral similarity.\npub fn quality_preservation_score(snr_db: f64, spectral_similarity: f64) -> f64 {\n    let snr_score = if snr_db > 40.0 {\n        1.0\n    } else if snr_db > 20.0 {\n        0.8\n    } else if snr_db > 10.0 {\n        0.6\n    } else {\n        0.4\n    };\n\n    snr_score * (1.0 + spectral_similarity) / 2.0\n}\n\n/// Determine verdict text and color based on effectiveness and SNR.\npub fn verdict(effectiveness: f64, snr_db: f64) -> (&'static str, &'static str) {\n    match (effectiveness, snr_db) {\n        (e, s) if e > 90.0 && s > 30.0 => (\"EXCELLENT\", \"green\"),\n        (e, s) if e > 70.0 && s > 20.0 => (\"GOOD\", \"yellow\"),\n        (e, s) if e > 50.0 && s > 10.0 => (\"ACCEPTABLE\", \"yellow\"),\n        _ => (\"POOR\", \"red\"),\n    }\n}\n\nfn file_hash(path: &Path) -> Result<String> {\n    let data = std::fs::read(path)?;\n    let mut hasher = Sha256::new();\n    hasher.update(&data);\n    Ok(format!(\"{:x}\", hasher.finalize()))\n}\n","numLines":159,"startLine":1,"totalLines":159}}}
