{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015kHzw3fWRKrskCdxGWq6nZ","type":"tool_result","content":"     1→const BASE = '';\n     2→\n     3→export const MAX_UPLOAD_BYTES = 500 * 1024 * 1024; // 500MB\n     4→\n     5→export interface FileInfo {\n     6→  file_path: string;\n     7→  format: string;\n     8→  duration_secs: number;\n     9→  sample_rate: number;\n    10→  channels: number;\n    11→}\n    12→\n    13→export interface ServerLimits {\n    14→  max_upload_bytes: number;\n    15→  supported_formats: string[];\n    16→}\n    17→\n    18→export async function getLimits(): Promise<ServerLimits> {\n    19→  const res = await fetch(`${BASE}/api/limits`);\n    20→  if (!res.ok) throw new Error(await res.text());\n    21→  return res.json();\n    22→}\n    23→\n    24→export interface WaveformData {\n    25→  min: number[];\n    26→  max: number[];\n    27→  sample_rate: number;\n    28→  duration_secs: number;\n    29→  channels: number;\n    30→}\n    31→\n    32→export interface SpectrogramData {\n    33→  magnitudes: number[][];\n    34→  freq_min: number;\n    35→  freq_max: number;\n    36→  time_start: number;\n    37→  time_end: number;\n    38→  num_freq_bins: number;\n    39→  num_time_frames: number;\n    40→}\n    41→\n    42→export interface PlaneSummary {\n    43→  bit: number;\n    44→  ones_ratio: number;\n    45→  bias: number;\n    46→}\n    47→\n    48→export interface BitPlaneData {\n    49→  planes: PlaneSummary[];\n    50→}\n    51→\n    52→export function uploadFile(\n    53→  file: File,\n    54→  onProgress?: (percent: number) => void,\n    55→): Promise<FileInfo> {\n    56→  return new Promise((resolve, reject) => {\n    57→    const xhr = new XMLHttpRequest();\n    58→    xhr.open('POST', `${BASE}/api/upload`);\n    59→\n    60→    if (onProgress) {\n    61→      xhr.upload.addEventListener('progress', (e) => {\n    62→        if (e.lengthComputable) {\n    63→          onProgress(Math.round((e.loaded / e.total) * 100));\n    64→        }\n    65→      });\n    66→    }\n    67→\n    68→    xhr.addEventListener('load', () => {\n    69→      if (xhr.status >= 200 && xhr.status < 300) {\n    70→        resolve(JSON.parse(xhr.responseText));\n    71→      } else {\n    72→        reject(new Error(xhr.responseText || `Upload failed (${xhr.status})`));\n    73→      }\n    74→    });\n    75→\n    76→    xhr.addEventListener('error', () => reject(new Error('Upload failed')));\n    77→    xhr.addEventListener('abort', () => reject(new Error('Upload cancelled')));\n    78→\n    79→    const form = new FormData();\n    80→    form.append('file', file);\n    81→    xhr.send(form);\n    82→  });\n    83→}\n    84→\n    85→export async function loadFile(path: string): Promise<FileInfo> {\n    86→  const res = await fetch(`${BASE}/api/load`, {\n    87→    method: 'POST',\n    88→    headers: { 'Content-Type': 'application/json' },\n    89→    body: JSON.stringify({ path }),\n    90→  });\n    91→  if (!res.ok) throw new Error(await res.text());\n    92→  return res.json();\n    93→}\n    94→\n    95→export async function getWaveform(width = 1200, start?: number, end?: number): Promise<WaveformData> {\n    96→  const params = new URLSearchParams({ width: String(width) });\n    97→  if (start !== undefined) params.set('start', String(start));\n    98→  if (end !== undefined) params.set('end', String(end));\n    99→  const res = await fetch(`${BASE}/api/waveform?${params}`);\n   100→  if (!res.ok) throw new Error(await res.text());\n   101→  return res.json();\n   102→}\n   103→\n   104→export async function getSpectrogram(opts?: {\n   105→  fft_size?: number;\n   106→  freq_min?: number;\n   107→  freq_max?: number;\n   108→  start?: number;\n   109→  duration?: number;\n   110→}): Promise<SpectrogramData> {\n   111→  const params = new URLSearchParams();\n   112→  if (opts?.fft_size) params.set('fft_size', String(opts.fft_size));\n   113→  if (opts?.freq_min !== undefined) params.set('freq_min', String(opts.freq_min));\n   114→  if (opts?.freq_max !== undefined) params.set('freq_max', String(opts.freq_max));\n   115→  if (opts?.start !== undefined) params.set('start', String(opts.start));\n   116→  if (opts?.duration !== undefined) params.set('duration', String(opts.duration));\n   117→  const res = await fetch(`${BASE}/api/spectrogram?${params}`);\n   118→  if (!res.ok) throw new Error(await res.text());\n   119→  return res.json();\n   120→}\n   121→\n   122→export async function getBitPlane(): Promise<BitPlaneData> {\n   123→  const res = await fetch(`${BASE}/api/bitplane`);\n   124→  if (!res.ok) throw new Error(await res.text());\n   125→  return res.json();\n   126→}\n   127→\n   128→export async function analyzeAll(): Promise<any> {\n   129→  const res = await fetch(`${BASE}/api/analyze/all`, { method: 'POST' });\n   130→  if (!res.ok) throw new Error(await res.text());\n   131→  return res.json();\n   132→}\n   133→\n   134→export async function analyzeWatermark(): Promise<any> {\n   135→  const res = await fetch(`${BASE}/api/analyze/watermark`, { method: 'POST' });\n   136→  if (!res.ok) throw new Error(await res.text());\n   137→  return res.json();\n   138→}\n   139→\n   140→export async function analyzePolez(): Promise<any> {\n   141→  const res = await fetch(`${BASE}/api/analyze/polez`, { method: 'POST' });\n   142→  if (!res.ok) throw new Error(await res.text());\n   143→  return res.json();\n   144→}\n   145→\n   146→export async function analyzeStatistical(): Promise<any> {\n   147→  const res = await fetch(`${BASE}/api/analyze/statistical`, { method: 'POST' });\n   148→  if (!res.ok) throw new Error(await res.text());\n   149→  return res.json();\n   150→}\n   151→\n   152→export async function analyzeMetadata(): Promise<any> {\n   153→  const res = await fetch(`${BASE}/api/analyze/metadata`, { method: 'POST' });\n   154→  if (!res.ok) throw new Error(await res.text());\n   155→  return res.json();\n   156→}\n   157→\n   158→export function getAudioUrl(): string {\n   159→  return `${BASE}/api/audio`;\n   160→}\n   161→\n   162→export interface CleanResponse {\n   163→  success: boolean;\n   164→  metadata_removed: number;\n   165→  patterns_found: number;\n   166→  patterns_suppressed: number;\n   167→  quality_loss: number;\n   168→  processing_time: number;\n   169→  before: any;\n   170→  after: any;\n   171→}\n   172→\n   173→export async function cleanFile(mode?: string): Promise<CleanResponse> {\n   174→  const res = await fetch(`${BASE}/api/clean`, {\n   175→    method: 'POST',\n   176→    headers: { 'Content-Type': 'application/json' },\n   177→    body: JSON.stringify({ mode: mode || 'standard' }),\n   178→  });\n   179→  if (!res.ok) throw new Error(await res.text());\n   180→  return res.json();\n   181→}\n   182→\n   183→export async function getCleanedWaveform(width = 1200, start?: number, end?: number): Promise<WaveformData> {\n   184→  const params = new URLSearchParams({ width: String(width) });\n   185→  if (start !== undefined) params.set('start', String(start));\n   186→  if (end !== undefined) params.set('end', String(end));\n   187→  const res = await fetch(`${BASE}/api/waveform/cleaned?${params}`);\n   188→  if (!res.ok) throw new Error(await res.text());\n   189→  return res.json();\n   190→}\n   191→\n   192→export function getCleanedAudioUrl(): string {\n   193→  return `${BASE}/api/audio/cleaned`;\n   194→}\n   195→\n   196→export async function saveCleanedFile(): Promise<void> {\n   197→  const res = await fetch(`${BASE}/api/save`, { method: 'POST' });\n   198→  if (!res.ok) throw new Error(await res.text());\n   199→  const blob = await res.blob();\n   200→  const url = URL.createObjectURL(blob);\n   201→  const a = document.createElement('a');\n   202→  a.href = url;\n   203→  a.download = 'cleaned_output.wav';\n   204→  a.click();\n   205→  URL.revokeObjectURL(url);\n   206→}\n   207→"}]},"parent_tool_use_id":null,"session_id":"25366dd4-3fbf-4b97-9824-3bd39fcc08ab","uuid":"3e997d55-8192-49fe-b603-28e5d7c30c25","tool_use_result":{"type":"text","file":{"filePath":"/Users/captain/code/github.com/polez/gui/src/api/client.ts","content":"const BASE = '';\n\nexport const MAX_UPLOAD_BYTES = 500 * 1024 * 1024; // 500MB\n\nexport interface FileInfo {\n  file_path: string;\n  format: string;\n  duration_secs: number;\n  sample_rate: number;\n  channels: number;\n}\n\nexport interface ServerLimits {\n  max_upload_bytes: number;\n  supported_formats: string[];\n}\n\nexport async function getLimits(): Promise<ServerLimits> {\n  const res = await fetch(`${BASE}/api/limits`);\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport interface WaveformData {\n  min: number[];\n  max: number[];\n  sample_rate: number;\n  duration_secs: number;\n  channels: number;\n}\n\nexport interface SpectrogramData {\n  magnitudes: number[][];\n  freq_min: number;\n  freq_max: number;\n  time_start: number;\n  time_end: number;\n  num_freq_bins: number;\n  num_time_frames: number;\n}\n\nexport interface PlaneSummary {\n  bit: number;\n  ones_ratio: number;\n  bias: number;\n}\n\nexport interface BitPlaneData {\n  planes: PlaneSummary[];\n}\n\nexport function uploadFile(\n  file: File,\n  onProgress?: (percent: number) => void,\n): Promise<FileInfo> {\n  return new Promise((resolve, reject) => {\n    const xhr = new XMLHttpRequest();\n    xhr.open('POST', `${BASE}/api/upload`);\n\n    if (onProgress) {\n      xhr.upload.addEventListener('progress', (e) => {\n        if (e.lengthComputable) {\n          onProgress(Math.round((e.loaded / e.total) * 100));\n        }\n      });\n    }\n\n    xhr.addEventListener('load', () => {\n      if (xhr.status >= 200 && xhr.status < 300) {\n        resolve(JSON.parse(xhr.responseText));\n      } else {\n        reject(new Error(xhr.responseText || `Upload failed (${xhr.status})`));\n      }\n    });\n\n    xhr.addEventListener('error', () => reject(new Error('Upload failed')));\n    xhr.addEventListener('abort', () => reject(new Error('Upload cancelled')));\n\n    const form = new FormData();\n    form.append('file', file);\n    xhr.send(form);\n  });\n}\n\nexport async function loadFile(path: string): Promise<FileInfo> {\n  const res = await fetch(`${BASE}/api/load`, {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ path }),\n  });\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport async function getWaveform(width = 1200, start?: number, end?: number): Promise<WaveformData> {\n  const params = new URLSearchParams({ width: String(width) });\n  if (start !== undefined) params.set('start', String(start));\n  if (end !== undefined) params.set('end', String(end));\n  const res = await fetch(`${BASE}/api/waveform?${params}`);\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport async function getSpectrogram(opts?: {\n  fft_size?: number;\n  freq_min?: number;\n  freq_max?: number;\n  start?: number;\n  duration?: number;\n}): Promise<SpectrogramData> {\n  const params = new URLSearchParams();\n  if (opts?.fft_size) params.set('fft_size', String(opts.fft_size));\n  if (opts?.freq_min !== undefined) params.set('freq_min', String(opts.freq_min));\n  if (opts?.freq_max !== undefined) params.set('freq_max', String(opts.freq_max));\n  if (opts?.start !== undefined) params.set('start', String(opts.start));\n  if (opts?.duration !== undefined) params.set('duration', String(opts.duration));\n  const res = await fetch(`${BASE}/api/spectrogram?${params}`);\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport async function getBitPlane(): Promise<BitPlaneData> {\n  const res = await fetch(`${BASE}/api/bitplane`);\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport async function analyzeAll(): Promise<any> {\n  const res = await fetch(`${BASE}/api/analyze/all`, { method: 'POST' });\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport async function analyzeWatermark(): Promise<any> {\n  const res = await fetch(`${BASE}/api/analyze/watermark`, { method: 'POST' });\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport async function analyzePolez(): Promise<any> {\n  const res = await fetch(`${BASE}/api/analyze/polez`, { method: 'POST' });\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport async function analyzeStatistical(): Promise<any> {\n  const res = await fetch(`${BASE}/api/analyze/statistical`, { method: 'POST' });\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport async function analyzeMetadata(): Promise<any> {\n  const res = await fetch(`${BASE}/api/analyze/metadata`, { method: 'POST' });\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport function getAudioUrl(): string {\n  return `${BASE}/api/audio`;\n}\n\nexport interface CleanResponse {\n  success: boolean;\n  metadata_removed: number;\n  patterns_found: number;\n  patterns_suppressed: number;\n  quality_loss: number;\n  processing_time: number;\n  before: any;\n  after: any;\n}\n\nexport async function cleanFile(mode?: string): Promise<CleanResponse> {\n  const res = await fetch(`${BASE}/api/clean`, {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ mode: mode || 'standard' }),\n  });\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport async function getCleanedWaveform(width = 1200, start?: number, end?: number): Promise<WaveformData> {\n  const params = new URLSearchParams({ width: String(width) });\n  if (start !== undefined) params.set('start', String(start));\n  if (end !== undefined) params.set('end', String(end));\n  const res = await fetch(`${BASE}/api/waveform/cleaned?${params}`);\n  if (!res.ok) throw new Error(await res.text());\n  return res.json();\n}\n\nexport function getCleanedAudioUrl(): string {\n  return `${BASE}/api/audio/cleaned`;\n}\n\nexport async function saveCleanedFile(): Promise<void> {\n  const res = await fetch(`${BASE}/api/save`, { method: 'POST' });\n  if (!res.ok) throw new Error(await res.text());\n  const blob = await res.blob();\n  const url = URL.createObjectURL(blob);\n  const a = document.createElement('a');\n  a.href = url;\n  a.download = 'cleaned_output.wav';\n  a.click();\n  URL.revokeObjectURL(url);\n}\n","numLines":207,"startLine":1,"totalLines":207}}}
