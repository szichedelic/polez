{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01F7CabuNR8HYKgLDiJG8tuW","type":"tool_result","content":"     1→import { useState } from 'react';\n     2→import { analyzeAll, analyzeWatermark, analyzePolez, analyzeStatistical, analyzeMetadata } from '../api/client';\n     3→\n     4→interface Props {\n     5→  fileLoaded: boolean;\n     6→}\n     7→\n     8→function ConfidenceBar({ label, value, max = 1 }: { label: string; value: number; max?: number }) {\n     9→  const pct = (value / max) * 100;\n    10→  const color = pct > 70 ? 'bg-red-500' : pct > 40 ? 'bg-yellow-500' : 'bg-green-500';\n    11→\n    12→  return (\n    13→    <div className=\"mb-2\">\n    14→      <div className=\"flex justify-between text-sm mb-1\">\n    15→        <span className=\"text-zinc-300\">{label}</span>\n    16→        <span className=\"text-zinc-400\">{(pct).toFixed(1)}%</span>\n    17→      </div>\n    18→      <div className=\"h-2 bg-zinc-700 rounded-full overflow-hidden\">\n    19→        <div className={`h-full ${color} rounded-full`} style={{ width: `${pct}%` }} />\n    20→      </div>\n    21→    </div>\n    22→  );\n    23→}\n    24→\n    25→// eslint-disable-next-line @typescript-eslint/no-explicit-any\n    26→type AnalysisResults = Record<string, any>;\n    27→\n    28→export function DetectionPanel({ fileLoaded }: Props) {\n    29→  const [results, setResults] = useState<AnalysisResults | null>(null);\n    30→  const [loading, setLoading] = useState<string | null>(null);\n    31→\n    32→  const runAnalysis = async (type: string) => {\n    33→    setLoading(type);\n    34→    try {\n    35→      let result: AnalysisResults;\n    36→      switch (type) {\n    37→        case 'all': result = await analyzeAll(); break;\n    38→        case 'watermark': result = { watermark: await analyzeWatermark() }; break;\n    39→        case 'polez': result = { polez: await analyzePolez() }; break;\n    40→        case 'statistical': result = { statistical: await analyzeStatistical() }; break;\n    41→        case 'metadata': result = { metadata: await analyzeMetadata() }; break;\n    42→        default: return;\n    43→      }\n    44→      setResults((prev) => ({ ...prev, ...result }));\n    45→    } finally {\n    46→      setLoading(null);\n    47→    }\n    48→  };\n    49→\n    50→  return (\n    51→    <div className=\"bg-zinc-900 border border-zinc-700 rounded p-4\">\n    52→      <div className=\"flex items-center justify-between mb-3\">\n    53→        <span className=\"text-zinc-400 text-sm font-medium\">DETECTION</span>\n    54→        <div className=\"flex gap-2\">\n    55→          <button\n    56→            onClick={() => runAnalysis('all')}\n    57→            disabled={!fileLoaded || !!loading}\n    58→            className=\"bg-purple-600 hover:bg-purple-500 disabled:opacity-50 text-white px-3 py-1 rounded text-xs font-medium\"\n    59→          >\n    60→            {loading === 'all' ? 'Running...' : 'Run All'}\n    61→          </button>\n    62→          <select\n    63→            onChange={(e) => { if (e.target.value) runAnalysis(e.target.value); e.target.value = ''; }}\n    64→            disabled={!fileLoaded || !!loading}\n    65→            className=\"bg-zinc-800 text-zinc-200 border border-zinc-600 rounded px-2 py-1 text-xs\"\n    66→          >\n    67→            <option value=\"\">Pick Analysis...</option>\n    68→            <option value=\"watermark\">Watermark</option>\n    69→            <option value=\"polez\">Polez</option>\n    70→            <option value=\"statistical\">Statistical</option>\n    71→            <option value=\"metadata\">Metadata</option>\n    72→          </select>\n    73→        </div>\n    74→      </div>\n    75→\n    76→      {!results && (\n    77→        <p className=\"text-zinc-500 text-sm\">Load a file and run analysis</p>\n    78→      )}\n    79→\n    80→      {results?.watermark && (\n    81→        <ConfidenceBar label=\"Watermark\" value={results.watermark.overall_confidence} />\n    82→      )}\n    83→      {results?.polez && (\n    84→        <>\n    85→          <ConfidenceBar label=\"AI Watermark\" value={results.polez.detection_probability} />\n    86→          <div className=\"text-xs text-zinc-500 mb-2 ml-2\">\n    87→            Ultrasonic: {(results.polez.signals.ultrasonic_score * 100).toFixed(0)}% |\n    88→            Bit Planes: {results.polez.signals.biased_planes}/8 |\n    89→            Autocorr: {(results.polez.signals.autocorr_score * 100).toFixed(0)}%\n    90→          </div>\n    91→        </>\n    92→      )}\n    93→      {results?.statistical && (\n    94→        <ConfidenceBar label=\"AI Probability\" value={results.statistical.ai_probability} />\n    95→      )}\n    96→      {results?.metadata && (\n    97→        <div className=\"text-sm text-zinc-300 mb-2\">\n    98→          Metadata: {results.metadata.tags.length} tags, {results.metadata.suspicious_chunks.length} suspicious chunks\n    99→        </div>\n   100→      )}\n   101→\n   102→      {results?.watermark?.method_results && (\n   103→        <details className=\"mt-3\">\n   104→          <summary className=\"text-zinc-500 text-xs cursor-pointer hover:text-zinc-300\">\n   105→            Expand method details...\n   106→          </summary>\n   107→          <div className=\"mt-2 space-y-1\">\n   108→            {Object.entries(results.watermark.method_results as Record<string, { detected: boolean; confidence: number }>).map(([name, mr]) => (\n   109→              <div key={name} className=\"flex justify-between text-xs\">\n   110→                <span className={mr.detected ? 'text-red-400' : 'text-zinc-500'}>{name}</span>\n   111→                <span className=\"text-zinc-400\">{(mr.confidence * 100).toFixed(1)}%</span>\n   112→              </div>\n   113→            ))}\n   114→          </div>\n   115→        </details>\n   116→      )}\n   117→    </div>\n   118→  );\n   119→}\n   120→"}]},"parent_tool_use_id":"toolu_01Y3xoGvFKwwMoz11GENWTqX","session_id":"25366dd4-3fbf-4b97-9824-3bd39fcc08ab","uuid":"d9f36d0f-c260-4b48-a313-4d7ea6729927"}
