{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SkYmNCShJhwXhKyc6U9iRg","type":"tool_result","content":"     1→import { useEffect, useRef, useState } from 'react';\n     2→import { getSpectrogram, type SpectrogramData } from '../api/client';\n     3→\n     4→interface Props {\n     5→  fileLoaded: boolean;\n     6→}\n     7→\n     8→export function Spectrogram({ fileLoaded }: Props) {\n     9→  const canvasRef = useRef<HTMLCanvasElement>(null);\n    10→  const [data, setData] = useState<SpectrogramData | null>(null);\n    11→  const [loading, setLoading] = useState(false);\n    12→  const [freqMax, setFreqMax] = useState(24000);\n    13→\n    14→  useEffect(() => {\n    15→    if (!fileLoaded) return;\n    16→    fetchSpectrogram();\n    17→  }, [fileLoaded, freqMax]);\n    18→\n    19→  const fetchSpectrogram = async () => {\n    20→    setLoading(true);\n    21→    try {\n    22→      const d = await getSpectrogram({ freq_max: freqMax });\n    23→      setData(d);\n    24→    } finally {\n    25→      setLoading(false);\n    26→    }\n    27→  };\n    28→\n    29→  useEffect(() => {\n    30→    if (!data || !canvasRef.current) return;\n    31→    const canvas = canvasRef.current;\n    32→    const ctx = canvas.getContext('2d');\n    33→    if (!ctx) return;\n    34→\n    35→    const { magnitudes, num_time_frames, num_freq_bins } = data;\n    36→    canvas.width = num_time_frames;\n    37→    canvas.height = num_freq_bins;\n    38→\n    39→    let minDb = 0, maxDb = -120;\n    40→    for (const row of magnitudes) {\n    41→      for (const val of row) {\n    42→        if (val > maxDb) maxDb = val;\n    43→        if (val < minDb && val > -120) minDb = val;\n    44→      }\n    45→    }\n    46→\n    47→    const imageData = ctx.createImageData(num_time_frames, num_freq_bins);\n    48→\n    49→    for (let t = 0; t < num_time_frames; t++) {\n    50→      for (let f = 0; f < num_freq_bins; f++) {\n    51→        const val = magnitudes[t][f];\n    52→        const norm = Math.max(0, Math.min(1, (val - minDb) / (maxDb - minDb)));\n    53→\n    54→        const r = Math.floor(norm * 255);\n    55→        const g = Math.floor(norm * 128 + (1 - norm) * 20);\n    56→        const b = Math.floor((1 - norm) * 200 + norm * 50);\n    57→\n    58→        const y = num_freq_bins - 1 - f;\n    59→        const idx = (y * num_time_frames + t) * 4;\n    60→        imageData.data[idx] = r;\n    61→        imageData.data[idx + 1] = g;\n    62→        imageData.data[idx + 2] = b;\n    63→        imageData.data[idx + 3] = 255;\n    64→      }\n    65→    }\n    66→\n    67→    ctx.putImageData(imageData, 0, 0);\n    68→  }, [data]);\n    69→\n    70→  return (\n    71→    <div className=\"bg-zinc-900 border border-zinc-700 rounded p-4\">\n    72→      <div className=\"flex items-center justify-between mb-2\">\n    73→        <span className=\"text-zinc-400 text-sm font-medium\">SPECTROGRAM</span>\n    74→        <div className=\"flex items-center gap-2\">\n    75→          <label className=\"text-zinc-500 text-xs\">Max Freq:</label>\n    76→          <select\n    77→            value={freqMax}\n    78→            onChange={(e) => setFreqMax(Number(e.target.value))}\n    79→            className=\"bg-zinc-800 text-zinc-200 border border-zinc-600 rounded px-2 py-1 text-xs\"\n    80→          >\n    81→            <option value={8000}>8 kHz</option>\n    82→            <option value={16000}>16 kHz</option>\n    83→            <option value={22050}>22 kHz</option>\n    84→            <option value={24000}>24 kHz</option>\n    85→          </select>\n    86→          {loading && <span className=\"text-purple-400 text-xs\">Loading...</span>}\n    87→        </div>\n    88→      </div>\n    89→      <canvas\n    90→        ref={canvasRef}\n    91→        className=\"w-full h-48 rounded\"\n    92→        style={{ imageRendering: 'pixelated' }}\n    93→      />\n    94→      {data && (\n    95→        <div className=\"flex justify-between text-zinc-500 text-xs mt-1\">\n    96→          <span>{data.time_start.toFixed(1)}s</span>\n    97→          <span>{data.freq_min / 1000}kHz - {data.freq_max / 1000}kHz</span>\n    98→          <span>{data.time_end.toFixed(1)}s</span>\n    99→        </div>\n   100→      )}\n   101→    </div>\n   102→  );\n   103→}\n   104→"}]},"parent_tool_use_id":"toolu_01Y3xoGvFKwwMoz11GENWTqX","session_id":"25366dd4-3fbf-4b97-9824-3bd39fcc08ab","uuid":"3fa18a7f-2dfb-41ab-a76b-6c20cc0a17d4"}
