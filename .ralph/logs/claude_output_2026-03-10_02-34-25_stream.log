{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HsBP73X5zUm7QEpiogP3c3","type":"tool_result","content":"     1→use serde::{Deserialize, Serialize};\n     2→\n     3→use crate::detection::{\n     4→    metadata_scan::MetadataScanResult, polez::PolezDetectionResult, statistical::StatisticalResult,\n     5→    watermark::WatermarkResult,\n     6→};\n     7→\n     8→#[derive(Serialize)]\n     9→pub struct FileInfo {\n    10→    pub file_path: String,\n    11→    pub format: String,\n    12→    pub duration_secs: f64,\n    13→    pub sample_rate: u32,\n    14→    pub channels: usize,\n    15→}\n    16→\n    17→#[derive(Serialize)]\n    18→pub struct AllAnalysisResult {\n    19→    pub watermark: WatermarkResult,\n    20→    pub polez: PolezDetectionResult,\n    21→    pub statistical: StatisticalResult,\n    22→    pub metadata: MetadataScanResult,\n    23→}\n    24→\n    25→#[derive(Serialize)]\n    26→pub struct WaveformData {\n    27→    pub min: Vec<f32>,\n    28→    pub max: Vec<f32>,\n    29→    pub sample_rate: u32,\n    30→    pub duration_secs: f64,\n    31→    pub channels: usize,\n    32→}\n    33→\n    34→#[derive(Serialize)]\n    35→pub struct SpectrogramData {\n    36→    pub magnitudes: Vec<Vec<f64>>,\n    37→    pub freq_min: f64,\n    38→    pub freq_max: f64,\n    39→    pub time_start: f64,\n    40→    pub time_end: f64,\n    41→    pub num_freq_bins: usize,\n    42→    pub num_time_frames: usize,\n    43→}\n    44→\n    45→#[derive(Serialize)]\n    46→pub struct BitPlaneData {\n    47→    pub planes: Vec<PlaneSummary>,\n    48→}\n    49→\n    50→#[derive(Serialize)]\n    51→pub struct PlaneSummary {\n    52→    pub bit: u8,\n    53→    pub ones_ratio: f64,\n    54→    pub bias: f64,\n    55→}\n    56→\n    57→#[derive(Deserialize)]\n    58→pub struct CleanRequest {\n    59→    pub mode: Option<String>,\n    60→}\n    61→\n    62→#[derive(Serialize)]\n    63→pub struct CleanResponse {\n    64→    pub success: bool,\n    65→    pub metadata_removed: usize,\n    66→    pub patterns_found: usize,\n    67→    pub patterns_suppressed: usize,\n    68→    pub quality_loss: f64,\n    69→    pub processing_time: f64,\n    70→    pub before: AllAnalysisResult,\n    71→    pub after: AllAnalysisResult,\n    72→}\n    73→"}]},"parent_tool_use_id":null,"session_id":"25366dd4-3fbf-4b97-9824-3bd39fcc08ab","uuid":"6ac54cb7-e460-4059-8224-850e374c3b02","tool_use_result":{"type":"text","file":{"filePath":"/Users/captain/code/github.com/polez/src/gui/types.rs","content":"use serde::{Deserialize, Serialize};\n\nuse crate::detection::{\n    metadata_scan::MetadataScanResult, polez::PolezDetectionResult, statistical::StatisticalResult,\n    watermark::WatermarkResult,\n};\n\n#[derive(Serialize)]\npub struct FileInfo {\n    pub file_path: String,\n    pub format: String,\n    pub duration_secs: f64,\n    pub sample_rate: u32,\n    pub channels: usize,\n}\n\n#[derive(Serialize)]\npub struct AllAnalysisResult {\n    pub watermark: WatermarkResult,\n    pub polez: PolezDetectionResult,\n    pub statistical: StatisticalResult,\n    pub metadata: MetadataScanResult,\n}\n\n#[derive(Serialize)]\npub struct WaveformData {\n    pub min: Vec<f32>,\n    pub max: Vec<f32>,\n    pub sample_rate: u32,\n    pub duration_secs: f64,\n    pub channels: usize,\n}\n\n#[derive(Serialize)]\npub struct SpectrogramData {\n    pub magnitudes: Vec<Vec<f64>>,\n    pub freq_min: f64,\n    pub freq_max: f64,\n    pub time_start: f64,\n    pub time_end: f64,\n    pub num_freq_bins: usize,\n    pub num_time_frames: usize,\n}\n\n#[derive(Serialize)]\npub struct BitPlaneData {\n    pub planes: Vec<PlaneSummary>,\n}\n\n#[derive(Serialize)]\npub struct PlaneSummary {\n    pub bit: u8,\n    pub ones_ratio: f64,\n    pub bias: f64,\n}\n\n#[derive(Deserialize)]\npub struct CleanRequest {\n    pub mode: Option<String>,\n}\n\n#[derive(Serialize)]\npub struct CleanResponse {\n    pub success: bool,\n    pub metadata_removed: usize,\n    pub patterns_found: usize,\n    pub patterns_suppressed: usize,\n    pub quality_loss: f64,\n    pub processing_time: f64,\n    pub before: AllAnalysisResult,\n    pub after: AllAnalysisResult,\n}\n","numLines":73,"startLine":1,"totalLines":73}}}
